{% extends 'base.html.twig' %}

{% block title %}Patients — Admin{% endblock %}

{% block body %}

    {# ── Header ─────────────────────────────────────────────────────────────── #}
    <div class="border-b border-gray-200 bg-white sticky top-0 z-50 shadow-sm">
        <div class="mx-auto max-w-7xl px-4 sm:px-6 py-3 sm:py-4">
            <div class="flex items-center justify-between gap-3 sm:gap-6">

                <div class="flex items-center gap-3">
                    <div class="flex items-center justify-center w-8 h-8 sm:w-9 sm:h-9 bg-blue-700 rounded-xl flex-shrink-0">
                        <svg class="w-[16px] h-[16px] sm:w-[18px] sm:h-[18px] text-white" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0"/>
