                    </div>
                    <div>
                        <h1 class="text-sm sm:text-lg font-semibold text-gray-900 leading-none">Patients</h1>
                    </div>
                </div>


            </div>
        </div>
    </div>

    {# ── Content ─────────────────────────────────────────────────────────────── #}
    <div class="mx-auto max-w-7xl px-4 sm:px-6 py-5 sm:py-8">
        {{ component('AdminPatientList') }}
    </div>

{% endblock %}
