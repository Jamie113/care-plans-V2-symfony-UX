{% extends 'base.html.twig' %}

{% block title %}Patient Care Plans — Admin{% endblock %}

{% block body %}

    {# ── Header ─────────────────────────────────────────────────────────────── #}
    <div class="border-b border-gray-200 bg-white sticky top-0 z-50 shadow-sm">
        <div class="mx-auto max-w-7xl px-4 sm:px-6 py-3 sm:py-4">
            <div class="flex items-center justify-between gap-3 sm:gap-6">

                <div class="flex items-center gap-3">
                    <div class="flex items-center justify-center w-8 h-8 sm:w-9 sm:h-9 bg-blue-700 rounded-xl flex-shrink-0">
                        <svg class="w-[16px] h-[16px] sm:w-[18px] sm:h-[18px] text-white" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0"/>
                        </svg>
                    </div>
                    <div>
                        <h1 class="text-sm sm:text-lg font-semibold text-gray-900 leading-none">Patient Care Plans</h1>
                        <p class="hidden sm:block text-xs text-gray-500 mt-1">
                            {{ stats.active }} active
                            <span class="text-gray-300 mx-1">·</span>
                            {{ stats.paused }} paused
                            <span class="text-gray-300 mx-1">·</span>
                            {{ stats.pending }} pending
                        </p>
                    </div>
                </div>

                <div class="flex items-center gap-2 sm:gap-3">
                    <a
                        href="{{ path('plan_new') }}"
                        class="inline-flex items-center gap-2 px-3 sm:px-5 py-2 text-sm font-semibold rounded-xl bg-blue-700 text-white hover:bg-blue-800 shadow-sm transition-colors"
                    >
                        <svg class="w-[15px] h-[15px] flex-shrink-0" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" d="M12 4v16m8-8H4"/>
                        </svg>
                        <span class="hidden sm:inline">New Plan</span>
                        <span class="sm:hidden">New</span>
                    </a>
                </div>

            </div>
        </div>
    </div>

    {# ── Content ─────────────────────────────────────────────────────────────── #}
    <div class="mx-auto max-w-7xl px-4 sm:px-6 py-5 sm:py-8">
        {{ component('AdminPlanList') }}
    </div>

{% endblock %}
