{% extends 'base.html.twig' %}

{% block title %}{{ plan.patientName }} — Plan Detail{% endblock %}

{% block body %}

    {# ── Header ─────────────────────────────────────────────────────────────── #}
    <div class="border-b border-gray-200 bg-white sticky top-0 z-50 shadow-sm">
        <div class="mx-auto max-w-7xl px-4 sm:px-6 py-3 sm:py-4">
            <div class="flex items-center justify-between gap-3">

                <div class="flex items-center gap-3 min-w-0">
                    {# Back link #}
                    <a href="{{ path('admin_plan_list') }}" class="flex items-center justify-center w-8 h-8 bg-gray-100 rounded-xl text-gray-500 hover:bg-gray-200 transition-colors flex-shrink-0">
                        <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" d="M15 19l-7-7 7-7"/>
                        </svg>
                    </a>
                    <div class="min-w-0">
                        <div class="flex items-center gap-2 flex-wrap">
                            <h1 class="text-sm sm:text-lg font-semibold text-gray-900 leading-none truncate">{{ plan.patientName }}</h1>
                            {# Status badge #}
                            {% if plan.status == 'active' %}
                                <span class="inline-flex items-center gap-1 px-2 py-0.5 rounded-full text-xs font-medium bg-green-50 text-green-700 border border-green-200">
                                    <span class="w-1.5 h-1.5 rounded-full bg-green-500"></span>Active
                                </span>
                            {% elseif plan.status == 'requested-renew' %}
                                <span class="inline-flex items-center gap-1 px-2 py-0.5 rounded-full text-xs font-medium bg-amber-50 text-amber-700 border border-amber-200">
                                    <span class="w-1.5 h-1.5 rounded-full bg-amber-500"></span>Renewal requested
                                </span>
                            {% elseif plan.status == 'requested-change' %}
                                <span class="inline-flex items-center gap-1 px-2 py-0.5 rounded-full text-xs font-medium bg-blue-50 text-blue-700 border border-blue-200">
                                    <span class="w-1.5 h-1.5 rounded-full bg-blue-500"></span>Change requested
                                </span>
                            {% elseif plan.status == 'requested-approve' %}
                                <span class="inline-flex items-center gap-1 px-2 py-0.5 rounded-full text-xs font-medium bg-purple-50 text-purple-700 border border-purple-200">
                                    <span class="w-1.5 h-1.5 rounded-full bg-purple-500"></span>Approval required
                                </span>
                            {% elseif plan.status == 'deactivated' %}
                                <span class="inline-flex items-center gap-1 px-2 py-0.5 rounded-full text-xs font-medium bg-red-50 text-red-700 border border-red-200">
                                    <span class="w-1.5 h-1.5 rounded-full bg-red-500"></span>Deactivated
                                </span>
                            {% elseif plan.status == 'expired' %}
                                <span class="inline-flex items-center gap-1 px-2 py-0.5 rounded-full text-xs font-medium bg-gray-100 text-gray-500 border border-gray-200">
                                    <span class="w-1.5 h-1.5 rounded-full bg-gray-400"></span>Expired
                                </span>
                            {% else %}
                                <span class="inline-flex items-center gap-1 px-2 py-0.5 rounded-full text-xs font-medium bg-gray-100 text-gray-500 border border-gray-200">
                                    <span class="w-1.5 h-1.5 rounded-full bg-gray-400"></span>{{ plan.status }}
                                </span>
                            {% endif %}
                        </div>
                        <p class="hidden sm:block text-xs text-gray-500 mt-1 truncate">{{ plan.planName }} · {{ plan.medication }} {{ plan.variant }}</p>
                    </div>
                </div>

            </div>
        </div>
    </div>

    {# ── Payment failed banner ────────────────────────────────────────────────── #}
    {% if plan.paymentFailed %}
        <div class="bg-red-600">
            <div class="mx-auto max-w-7xl px-4 sm:px-6 py-3">
                <div class="flex items-center justify-between gap-4">
                    <div class="flex items-center gap-3 min-w-0">
                        <svg class="w-5 h-5 text-white flex-shrink-0" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z"/>
                        </svg>
                        <p class="text-sm font-medium text-white">
                            Payment failed — The last payment of £{{ plan.lastPaymentAmount|number_format(2) }} could not be collected. Retry or update billing details.
                        </p>
                    </div>
                    <button type="button" class="flex-shrink-0 px-3 py-1.5 bg-white text-red-600 rounded-lg text-xs font-semibold hover:bg-red-50 transition-colors">
                        Retry payment
                    </button>
                </div>
            </div>
        </div>
    {% endif %}

    {# ── Summary strip ───────────────────────────────────────────────────────── #}
    <div class="bg-white border-b border-gray-200">
        <div class="mx-auto max-w-7xl px-4 sm:px-6 py-3">
            <div class="grid grid-cols-2 sm:grid-cols-4 gap-4 sm:gap-6 divide-x divide-gray-100">
                <div class="px-0 sm:px-4 first:pl-0">
                    <p class="text-xs text-gray-500 mb-0.5">Orders</p>
                    <p class="text-sm font-semibold text-gray-900">{{ plan.ordersCompleted }} / {{ plan.ordersTotal }} completed</p>
                </div>
                <div class="px-4">
                    <p class="text-xs text-gray-500 mb-0.5">Current dose</p>
                    <p class="text-sm font-semibold text-gray-900">{{ plan.currentDose ?? 'Not started' }}</p>
                    <p class="text-xs text-gray-400 mt-0.5">
                        {% if plan.nextDose and plan.nextDose != plan.currentDose %}
                            Next: {{ plan.nextDose }}
                        {% elseif plan.currentDose %}
                            Stable
                        {% endif %}
                    </p>
                </div>
                <div class="px-0 sm:px-4">
                    <p class="text-xs text-gray-500 mb-0.5">Next order</p>
                    <p class="text-sm font-semibold text-gray-900">
                        {% if plan.nextOrderDate %}{{ plan.nextOrderDate|date('d M Y') }}{% else %}—{% endif %}
                    </p>
                </div>
                <div class="px-4">
                    <p class="text-xs text-gray-500 mb-0.5">Renewal point</p>
                    <p class="text-sm font-semibold text-gray-900">
                        {% if plan.renewalDate %}{{ plan.renewalDate|date('d M Y') }}{% else %}—{% endif %}
                    </p>
                </div>
            </div>
        </div>
    </div>

    {# ── Body ────────────────────────────────────────────────────────────────── #}
    <div class="mx-auto max-w-7xl px-4 sm:px-6 py-5 sm:py-8">
        <div class="grid grid-cols-12 gap-5 sm:gap-8">

            {# ── Left column — details + activity ──────────────────────────────── #}
            <div class="col-span-12 lg:col-span-8 space-y-5">

                {# Patient info #}
                <div class="bg-white rounded-2xl border border-gray-200 shadow-sm overflow-hidden">
                    <div class="flex items-center gap-3 px-4 sm:px-6 py-3 sm:py-4 border-b border-gray-100">
                        <div class="flex items-center justify-center w-8 h-8 bg-gray-100 rounded-xl text-gray-500 flex-shrink-0">
                            <svg class="w-[17px] h-[17px]" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"/>
                            </svg>
                        </div>
                        <div>
                            <h2 class="text-sm font-semibold text-gray-900">Patient details</h2>
                            <p class="text-xs text-gray-500">Contact and personal information</p>
                        </div>
                    </div>
                    <div class="p-4 sm:p-6 grid grid-cols-1 sm:grid-cols-3 gap-4">
                        <div>
                            <p class="text-xs text-gray-500 mb-1">Full name</p>
                            <p class="text-sm font-medium text-gray-900">{{ plan.patientName }}</p>
                        </div>
                        <div>
                            <p class="text-xs text-gray-500 mb-1">Email</p>
                            <p class="text-sm text-gray-900">{{ plan.patientEmail }}</p>
                        </div>
                        <div>
                            <p class="text-xs text-gray-500 mb-1">Phone</p>
                            <p class="text-sm text-gray-900">{{ plan.patientPhone }}</p>
                        </div>
                        <div>
                            <p class="text-xs text-gray-500 mb-1">Date of birth</p>
                            <p class="text-sm text-gray-900">{{ plan.patientDob|date('d M Y') }}</p>
                        </div>
                        <div>
                            <p class="text-xs text-gray-500 mb-1">Plan started</p>
                            <p class="text-sm text-gray-900">{{ plan.startDate|date('d M Y') }}</p>
                        </div>
                        <div>
                            <p class="text-xs text-gray-500 mb-1">Monthly price</p>
                            <p class="text-sm font-medium text-gray-900">
                                £{{ plan.price|number_format(2) }}
                                {% if plan.discount %}
                                    <span class="ml-1.5 text-xs font-normal text-green-600 bg-green-50 border border-green-200 px-1.5 py-0.5 rounded-full">{{ plan.discount }}</span>
                                {% endif %}
                            </p>
                        </div>
                    </div>
                </div>

                {# Plan summary #}
                <div class="bg-white rounded-2xl border border-gray-200 shadow-sm overflow-hidden">
                    <div class="flex items-center gap-3 px-4 sm:px-6 py-3 sm:py-4 border-b border-gray-100">
                        <div class="flex items-center justify-center w-8 h-8 bg-gray-100 rounded-xl text-gray-500 flex-shrink-0">
                            <svg class="w-[17px] h-[17px]" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2"/>
                            </svg>
                        </div>
                        <div>
                            <h2 class="text-sm font-semibold text-gray-900">Plan summary</h2>
                            <p class="text-xs text-gray-500">{{ plan.planName }}</p>
                        </div>
                    </div>
                    <div class="p-4 sm:p-6 grid grid-cols-2 sm:grid-cols-3 gap-4">
                        <div>
                            <p class="text-xs text-gray-500 mb-1">Medication</p>
                            <p class="text-sm font-medium text-gray-900">{{ plan.medication }}</p>
                        </div>
                        <div>
                            <p class="text-xs text-gray-500 mb-1">Current dose</p>
                            <p class="text-sm text-gray-900">{{ plan.currentDose ?? 'Not started' }}</p>
                        </div>
                        <div>
                            <p class="text-xs text-gray-500 mb-1">Next dispatch dose</p>
                            <p class="text-sm text-gray-900">
                                {% if plan.nextDose and plan.nextDose != plan.currentDose %}
                                    {{ plan.nextDose }} (titration)
                                {% elseif plan.nextDose %}
                                    {{ plan.nextDose }} (stable)
                                {% else %}
                                    —
                                {% endif %}
                            </p>
                        </div>
                        <div>
                            <p class="text-xs text-gray-500 mb-1">Orders</p>
                            <p class="text-sm text-gray-900">{{ plan.ordersCompleted }} of {{ plan.ordersTotal }} dispatched</p>
                        </div>
                        <div>
                            <p class="text-xs text-gray-500 mb-1">Dispatch cycle</p>
                            <p class="text-sm text-gray-900">Every {{ plan.cycleDays }} days</p>
                        </div>
                        <div>
                            <p class="text-xs text-gray-500 mb-1">Last order</p>
                            <p class="text-sm text-gray-900">
                                {% if plan.lastOrderDate %}{{ plan.lastOrderDate|date('d M Y') }}{% else %}None yet{% endif %}
                            </p>
                        </div>
                        <div>
                            <p class="text-xs text-gray-500 mb-1">Last payment</p>
                            <p class="text-sm text-gray-900 flex items-center gap-1.5">
                                £{{ plan.lastPaymentAmount|number_format(2) }}
                                {% if plan.paymentFailed %}
                                    <span class="text-xs font-medium text-red-600 bg-red-50 border border-red-200 px-1.5 py-0.5 rounded-full">Failed</span>
                                {% endif %}
                            </p>
                        </div>
                        <div>
                            <p class="text-xs text-gray-500 mb-1">Renewal point</p>
                            <p class="text-sm text-gray-900">
                                {% if plan.renewalDate %}{{ plan.renewalDate|date('d M Y') }}{% else %}—{% endif %}
                            </p>
                        </div>
                    </div>
                </div>

                {# Shipments #}
                <div class="bg-white rounded-2xl border border-gray-200 shadow-sm overflow-hidden">
                    <div class="flex items-center gap-3 px-4 sm:px-6 py-3 sm:py-4 border-b border-gray-100">
                        <div class="flex items-center justify-center w-8 h-8 bg-gray-100 rounded-xl text-gray-500 flex-shrink-0">
                            <svg class="w-[17px] h-[17px]" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" d="M9 17a2 2 0 11-4 0 2 2 0 014 0zM19 17a2 2 0 11-4 0 2 2 0 014 0z"/>
                                <path stroke-linecap="round" stroke-linejoin="round" d="M13 16V6a1 1 0 00-1-1H4a1 1 0 00-1 1v10l2 1m8-1h1m0-4l-3-4H9m4 4V9"/>
                            </svg>
                        </div>
                        <div>
                            <h2 class="text-sm font-semibold text-gray-900">Shipments</h2>
                            <p class="text-xs text-gray-500">Recent order dispatches</p>
                        </div>
                    </div>
                    {% if plan.shipments is empty %}
                        <div class="px-4 sm:px-6 py-8 text-center">
                            <p class="text-sm text-gray-400">No shipments yet</p>
                        </div>
                    {% else %}
                        <div class="overflow-x-auto">
                            <table class="min-w-full divide-y divide-gray-100">
                                <thead>
                                    <tr class="bg-gray-50">
                                        <th class="px-4 sm:px-6 py-2.5 text-left text-xs font-semibold text-gray-500 uppercase tracking-wide">Order</th>
                                        <th class="px-4 py-2.5 text-left text-xs font-semibold text-gray-500 uppercase tracking-wide">Items</th>
                                        <th class="px-4 py-2.5 text-left text-xs font-semibold text-gray-500 uppercase tracking-wide">Status</th>
                                        <th class="px-4 py-2.5 text-left text-xs font-semibold text-gray-500 uppercase tracking-wide hidden sm:table-cell">Date</th>
                                        <th class="px-4 py-2.5 text-left text-xs font-semibold text-gray-500 uppercase tracking-wide hidden md:table-cell">Tracking</th>
                                        <th class="px-4 sm:px-6 py-2.5 text-right text-xs font-semibold text-gray-500 uppercase tracking-wide"></th>
                                    </tr>
                                </thead>
                                <tbody class="divide-y divide-gray-100">
                                    {% for shipment in plan.shipments %}
                                        <tr class="hover:bg-gray-50 transition-colors">
                                            <td class="px-4 sm:px-6 py-3">
                                                <p class="text-sm font-medium text-gray-900">{{ shipment.orderNumber }}</p>
                                            </td>
                                            <td class="px-4 py-3">
                                                <p class="text-sm text-gray-700">{{ shipment.items }}</p>
                                            </td>
                                            <td class="px-4 py-3">
                                                {% if shipment.status == 'processing' %}
                                                    <span class="inline-flex items-center gap-1 px-2 py-0.5 rounded-full text-xs font-medium bg-gray-100 text-gray-600 border border-gray-200">Processing</span>
                                                {% elseif shipment.status == 'dispatched' %}
                                                    <span class="inline-flex items-center gap-1 px-2 py-0.5 rounded-full text-xs font-medium bg-blue-50 text-blue-700 border border-blue-200">Dispatched</span>
                                                {% elseif shipment.status == 'in-transit' %}
                                                    <span class="inline-flex items-center gap-1 px-2 py-0.5 rounded-full text-xs font-medium bg-indigo-50 text-indigo-700 border border-indigo-200">In Transit</span>
                                                {% elseif shipment.status == 'delivered' %}
                                                    <span class="inline-flex items-center gap-1 px-2 py-0.5 rounded-full text-xs font-medium bg-green-50 text-green-700 border border-green-200">Delivered</span>
                                                {% elseif shipment.status == 'failed' %}
                                                    <span class="inline-flex items-center gap-1 px-2 py-0.5 rounded-full text-xs font-medium bg-red-50 text-red-700 border border-red-200">Failed</span>
                                                {% else %}
                                                    <span class="inline-flex items-center gap-1 px-2 py-0.5 rounded-full text-xs font-medium bg-gray-100 text-gray-500 border border-gray-200">{{ shipment.status }}</span>
                                                {% endif %}
                                            </td>
                                            <td class="px-4 py-3 hidden sm:table-cell">
                                                <p class="text-sm text-gray-700">{{ shipment.date|date('d M Y') }}</p>
                                            </td>
                                            <td class="px-4 py-3 hidden md:table-cell">
                                                <p class="text-sm text-gray-500 font-mono text-xs">{{ shipment.trackingRef ?? '—' }}</p>
                                            </td>
                                            <td class="px-4 sm:px-6 py-3 text-right">
                                                <a href="#" class="text-xs font-medium text-blue-600 hover:text-blue-800 transition-colors">Track →</a>
                                            </td>
                                        </tr>
                                    {% endfor %}
                                </tbody>
                            </table>
                        </div>
                    {% endif %}
                </div>

                {# Upcoming events #}
                {% if upcomingEvents is not empty %}
                    <div class="bg-white rounded-2xl border border-gray-200 shadow-sm overflow-hidden">
                        <div class="flex items-center gap-3 px-4 sm:px-6 py-3 sm:py-4 border-b border-gray-100">
                            <div class="flex items-center justify-center w-8 h-8 bg-gray-100 rounded-xl text-gray-500 flex-shrink-0">
                                <svg class="w-[17px] h-[17px]" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                                    <path stroke-linecap="round" stroke-linejoin="round" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"/>
                                </svg>
                            </div>
                            <div>
                                <h2 class="text-sm font-semibold text-gray-900">Upcoming events</h2>
                                <p class="text-xs text-gray-500">Scheduled dates for this plan</p>
                            </div>
                        </div>
                        <div class="divide-y divide-gray-100">
                            {% for event in upcomingEvents %}
                                <div class="flex items-center justify-between px-4 sm:px-6 py-3">
                                    <p class="text-sm text-gray-700">{{ event.label }}</p>
                                    <p class="text-sm font-medium text-gray-900">{{ event.date|date('d M Y') }}</p>
                                </div>
                            {% endfor %}
                        </div>
                    </div>
                {% endif %}

                {# Activity timeline #}
                <div class="bg-white rounded-2xl border border-gray-200 shadow-sm overflow-hidden">
                    <div class="flex items-center gap-3 px-4 sm:px-6 py-3 sm:py-4 border-b border-gray-100">
                        <div class="flex items-center justify-center w-8 h-8 bg-gray-100 rounded-xl text-gray-500 flex-shrink-0">
                            <svg class="w-[17px] h-[17px]" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"/>
                            </svg>
                        </div>
                        <div>
                            <h2 class="text-sm font-semibold text-gray-900">Recent activity</h2>
                            <p class="text-xs text-gray-500">Changes and events on this plan</p>
                        </div>
                    </div>
                    <div class="px-4 sm:px-6 py-4">
                        {% if plan.activity is empty %}
                            <p class="text-sm text-gray-400 py-4 text-center">No activity recorded yet</p>
                        {% else %}
                            <ol class="relative border-l border-gray-200 space-y-5 ml-2">
                                {% for item in plan.activity %}
                                    <li class="ml-5">
                                        {# Timeline dot #}
                                        <span class="absolute -left-[7px] flex h-3.5 w-3.5 items-center justify-center rounded-full
                                            {% if item.type == 'plan_cancelled' %}bg-red-100 border border-red-300
                                            {% elseif item.type == 'plan_paused' %}bg-amber-100 border border-amber-300
                                            {% elseif item.type == 'discount_applied' %}bg-green-100 border border-green-300
                                            {% elseif item.type == 'plan_started' or item.type == 'plan_created' %}bg-blue-100 border border-blue-300
                                            {% else %}bg-white border border-gray-300
                                            {% endif %}">
                                        </span>
                                        <p class="text-sm text-gray-800 leading-snug">{{ item.description }}</p>
                                        <p class="text-xs text-gray-400 mt-0.5">{{ item.date|date('d M Y') }} · {{ item.agent }}</p>
                                    </li>
                                {% endfor %}
                            </ol>
                        {% endif %}
                    </div>
                </div>

            </div>

            {# ── Right column — actions (sticky) ───────────────────────────────── #}
            <div class="col-span-12 lg:col-span-4">
                <div class="lg:sticky lg:top-[73px] space-y-5">

                    {# Actions card #}
                    <div class="bg-white rounded-2xl border border-gray-200 shadow-sm overflow-hidden">
                        <div class="flex items-center gap-3 px-4 sm:px-6 py-3 sm:py-4 border-b border-gray-100">
                            <div class="flex items-center justify-center w-8 h-8 bg-gray-100 rounded-xl text-gray-500 flex-shrink-0">
                                <svg class="w-[17px] h-[17px]" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                                    <path stroke-linecap="round" stroke-linejoin="round" d="M13 10V3L4 14h7v7l9-11h-7z"/>
                                </svg>
                            </div>
                            <div>
                                <h2 class="text-sm font-semibold text-gray-900">Actions</h2>
                                <p class="text-xs text-gray-500">Manage this plan</p>
                            </div>
                        </div>

                        <div class="p-4 sm:p-5 space-y-2">

                            {# Change order date #}
                            <details class="group rounded-xl border border-gray-200 overflow-hidden">
                                <summary class="flex items-center gap-3 px-4 py-3 cursor-pointer bg-gray-50 hover:bg-gray-100 transition-colors [&::-webkit-details-marker]:hidden list-none">
                                    <div class="w-7 h-7 bg-white border border-gray-200 rounded-lg flex items-center justify-center flex-shrink-0 group-open:border-gray-300">
                                        <svg class="w-4 h-4 text-gray-600" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                                            <path stroke-linecap="round" stroke-linejoin="round" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"/>
                                        </svg>
                                    </div>
                                    <div class="flex-1 min-w-0">
                                        <p class="text-sm font-medium text-gray-800">Change order date</p>
                                        <p class="text-xs text-gray-500">Reschedule the next dispatch date</p>
                                    </div>
                                    <svg class="w-4 h-4 text-gray-400 flex-shrink-0 transition-transform group-open:rotate-90" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                                        <path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7"/>
                                    </svg>
                                </summary>
                                <div class="px-4 py-3 bg-white border-t border-gray-100 space-y-2">
                                    <p class="text-xs text-gray-600">Pick a new dispatch date within the allowed window. The patient will receive an updated delivery notification.</p>
                                    <p class="text-xs text-gray-400"><span class="font-medium text-gray-500">Would collect:</span> New dispatch date · Reason for change (optional)</p>
                                    <div class="flex items-center gap-2 pt-1">
                                        <button type="button" class="px-3 py-1.5 bg-gray-900 text-white rounded-lg text-xs font-medium hover:bg-gray-700 transition-colors">Continue →</button>
                                        <span class="text-xs text-gray-400 italic">Not wired in prototype</span>
                                    </div>
                                </div>
                            </details>

                            {# Change billing date #}
                            <details class="group rounded-xl border border-gray-200 overflow-hidden">
                                <summary class="flex items-center gap-3 px-4 py-3 cursor-pointer bg-gray-50 hover:bg-gray-100 transition-colors [&::-webkit-details-marker]:hidden list-none">
                                    <div class="w-7 h-7 bg-white border border-gray-200 rounded-lg flex items-center justify-center flex-shrink-0 group-open:border-gray-300">
                                        <svg class="w-4 h-4 text-gray-600" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                                            <path stroke-linecap="round" stroke-linejoin="round" d="M3 10h18M7 15h1m4 0h1m-7 4h12a3 3 0 003-3V8a3 3 0 00-3-3H6a3 3 0 00-3 3v8a3 3 0 003 3z"/>
                                        </svg>
                                    </div>
                                    <div class="flex-1 min-w-0">
                                        <p class="text-sm font-medium text-gray-800">Change billing date</p>
                                        <p class="text-xs text-gray-500">Move the next payment collection date</p>
                                    </div>
                                    <svg class="w-4 h-4 text-gray-400 flex-shrink-0 transition-transform group-open:rotate-90" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                                        <path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7"/>
                                    </svg>
                                </summary>
                                <div class="px-4 py-3 bg-white border-t border-gray-100 space-y-2">
                                    <p class="text-xs text-gray-600">Shift when the next payment is collected. Useful for aligning billing with a patient's pay cycle.</p>
                                    <p class="text-xs text-gray-400"><span class="font-medium text-gray-500">Would collect:</span> New billing date · One-time or permanent change</p>
                                    <div class="flex items-center gap-2 pt-1">
                                        <button type="button" class="px-3 py-1.5 bg-gray-900 text-white rounded-lg text-xs font-medium hover:bg-gray-700 transition-colors">Continue →</button>
                                        <span class="text-xs text-gray-400 italic">Not wired in prototype</span>
                                    </div>
                                </div>
                            </details>

                            {# Change plan #}
                            <details class="group rounded-xl border border-gray-200 overflow-hidden">
                                <summary class="flex items-center gap-3 px-4 py-3 cursor-pointer bg-gray-50 hover:bg-gray-100 transition-colors [&::-webkit-details-marker]:hidden list-none">
                                    <div class="w-7 h-7 bg-white border border-gray-200 rounded-lg flex items-center justify-center flex-shrink-0 group-open:border-gray-300">
                                        <svg class="w-4 h-4 text-gray-600" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                                            <path stroke-linecap="round" stroke-linejoin="round" d="M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2m15.357 2H15"/>
                                        </svg>
                                    </div>
                                    <div class="flex-1 min-w-0">
                                        <p class="text-sm font-medium text-gray-800">Change plan</p>
                                        <p class="text-xs text-gray-500">Switch to a different care plan configuration</p>
                                    </div>
                                    <svg class="w-4 h-4 text-gray-400 flex-shrink-0 transition-transform group-open:rotate-90" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                                        <path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7"/>
                                    </svg>
                                </summary>
                                <div class="px-4 py-3 bg-white border-t border-gray-100 space-y-2">
                                    <p class="text-xs text-gray-600">Move the patient to a different plan template — for example from a 3-month to a 6-month plan. Remaining orders and billing are recalculated.</p>
                                    <p class="text-xs text-gray-400"><span class="font-medium text-gray-500">Would collect:</span> New plan selection · Effective from (next cycle or immediately) · Confirmation</p>
                                    <div class="flex items-center gap-2 pt-1">
                                        <button type="button" class="px-3 py-1.5 bg-gray-900 text-white rounded-lg text-xs font-medium hover:bg-gray-700 transition-colors">Continue →</button>
                                        <span class="text-xs text-gray-400 italic">Not wired in prototype</span>
                                    </div>
                                </div>
                            </details>

                            {# Change offer & billing #}
                            <details class="group rounded-xl border border-gray-200 overflow-hidden">
                                <summary class="flex items-center gap-3 px-4 py-3 cursor-pointer bg-gray-50 hover:bg-gray-100 transition-colors [&::-webkit-details-marker]:hidden list-none">
                                    <div class="w-7 h-7 bg-white border border-gray-200 rounded-lg flex items-center justify-center flex-shrink-0 group-open:border-gray-300">
                                        <svg class="w-4 h-4 text-gray-600" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                                            <path stroke-linecap="round" stroke-linejoin="round" d="M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/>
                                        </svg>
                                    </div>
                                    <div class="flex-1 min-w-0">
                                        <p class="text-sm font-medium text-gray-800">Change offer &amp; billing</p>
                                        <p class="text-xs text-gray-500">Switch plan tier, promotion or billing cycle</p>
                                    </div>
                                    <svg class="w-4 h-4 text-gray-400 flex-shrink-0 transition-transform group-open:rotate-90" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                                        <path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7"/>
                                    </svg>
                                </summary>
                                <div class="px-4 py-3 bg-white border-t border-gray-100 space-y-2">
                                    <p class="text-xs text-gray-600">Apply a different offer to this patient's plan. Choose from available promotions, change the billing frequency, or move to a different pricing tier.</p>
                                    <p class="text-xs text-gray-400"><span class="font-medium text-gray-500">Would collect:</span> Offer selection from available offers · New billing cycle · Effective date</p>
                                    <div class="flex items-center gap-2 pt-1">
                                        <button type="button" class="px-3 py-1.5 bg-gray-900 text-white rounded-lg text-xs font-medium hover:bg-gray-700 transition-colors">Continue →</button>
                                        <span class="text-xs text-gray-400 italic">Not wired in prototype</span>
                                    </div>
                                </div>
                            </details>

                            {# Add / adjust discount #}
                            <details class="group rounded-xl border border-gray-200 overflow-hidden">
                                <summary class="flex items-center gap-3 px-4 py-3 cursor-pointer bg-gray-50 hover:bg-gray-100 transition-colors [&::-webkit-details-marker]:hidden list-none">
                                    <div class="w-7 h-7 bg-white border border-gray-200 rounded-lg flex items-center justify-center flex-shrink-0 group-open:border-gray-300">
                                        <svg class="w-4 h-4 text-gray-600" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                                            <path stroke-linecap="round" stroke-linejoin="round" d="M7 7h.01M17 17h.01M7 17L17 7M7.5 7.5h.01m9 9h.01"/>
                                        </svg>
                                    </div>
                                    <div class="flex-1 min-w-0">
                                        <p class="text-sm font-medium text-gray-800">Add / adjust discount</p>
                                        <p class="text-xs text-gray-500">Apply a percentage or fixed amount off the plan price</p>
                                    </div>
                                    <svg class="w-4 h-4 text-gray-400 flex-shrink-0 transition-transform group-open:rotate-90" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                                        <path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7"/>
                                    </svg>
                                </summary>
                                <div class="px-4 py-3 bg-white border-t border-gray-100 space-y-2">
                                    <p class="text-xs text-gray-600">Add a discount to future billing cycles. Can be set as a percentage, fixed amount, or limited to a number of cycles.</p>
                                    <p class="text-xs text-gray-400"><span class="font-medium text-gray-500">Would collect:</span> Discount type (% / fixed) · Amount · Duration (permanent / N cycles) · Reason</p>
                                    <div class="flex items-center gap-2 pt-1">
                                        <button type="button" class="px-3 py-1.5 bg-gray-900 text-white rounded-lg text-xs font-medium hover:bg-gray-700 transition-colors">Continue →</button>
                                        <span class="text-xs text-gray-400 italic">Not wired in prototype</span>
                                    </div>
                                </div>
                            </details>

                            {# Send one-off order #}
                            <details class="group rounded-xl border border-gray-200 overflow-hidden">
                                <summary class="flex items-center gap-3 px-4 py-3 cursor-pointer bg-gray-50 hover:bg-gray-100 transition-colors [&::-webkit-details-marker]:hidden list-none">
                                    <div class="w-7 h-7 bg-white border border-gray-200 rounded-lg flex items-center justify-center flex-shrink-0 group-open:border-gray-300">
                                        <svg class="w-4 h-4 text-gray-600" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                                            <path stroke-linecap="round" stroke-linejoin="round" d="M20 7l-8-4-8 4m16 0l-8 4m8-4v10l-8 4m0-10L4 7m8 4v10M4 7v10l8 4"/>
                                        </svg>
                                    </div>
                                    <div class="flex-1 min-w-0">
                                        <p class="text-sm font-medium text-gray-800">Send one-off order</p>
                                        <p class="text-xs text-gray-500">Dispatch a single order outside the regular cycle</p>
                                    </div>
                                    <svg class="w-4 h-4 text-gray-400 flex-shrink-0 transition-transform group-open:rotate-90" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                                        <path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7"/>
                                    </svg>
                                </summary>
                                <div class="px-4 py-3 bg-white border-t border-gray-100 space-y-2">
                                    <p class="text-xs text-gray-600">Send an additional order to the patient immediately or on a specified date. This does not affect the regular dispatch schedule.</p>
                                    <p class="text-xs text-gray-400"><span class="font-medium text-gray-500">Would collect:</span> Product and variant selection · Dispatch date · Billing (charge or complimentary)</p>
                                    <div class="flex items-center gap-2 pt-1">
                                        <button type="button" class="px-3 py-1.5 bg-gray-900 text-white rounded-lg text-xs font-medium hover:bg-gray-700 transition-colors">Continue →</button>
                                        <span class="text-xs text-gray-400 italic">Not wired in prototype</span>
                                    </div>
                                </div>
                            </details>

                        </div>

                        {# Deactivate plan — separated, destructive #}
                        <div class="px-4 sm:px-5 pb-4 sm:pb-5 border-t border-gray-100 pt-3">
                            <details class="group rounded-xl border border-red-200 overflow-hidden">
                                <summary class="flex items-center gap-3 px-4 py-3 cursor-pointer bg-red-50 hover:bg-red-100 transition-colors [&::-webkit-details-marker]:hidden list-none">
                                    <div class="w-7 h-7 bg-white border border-red-200 rounded-lg flex items-center justify-center flex-shrink-0 group-open:border-red-300">
                                        <svg class="w-4 h-4 text-red-600" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                                            <path stroke-linecap="round" stroke-linejoin="round" d="M10 14l2-2m0 0l2-2m-2 2l-2-2m2 2l2 2m7-2a9 9 0 11-18 0 9 9 0 0118 0z"/>
                                        </svg>
                                    </div>
                                    <div class="flex-1 min-w-0">
                                        <p class="text-sm font-medium text-red-700">Deactivate plan</p>
                                        <p class="text-xs text-red-500">Stop all orders and billing immediately</p>
                                    </div>
                                    <svg class="w-4 h-4 text-red-400 flex-shrink-0 transition-transform group-open:rotate-90" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                                        <path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7"/>
                                    </svg>
                                </summary>
                                <div class="px-4 py-3 bg-white border-t border-red-100 space-y-2">
                                    <p class="text-xs text-gray-600">Marks the plan as deactivated. No further orders or payments will be triggered. The patient will be notified. This action can be reversed by an admin.</p>
                                    <p class="text-xs text-gray-400"><span class="font-medium text-gray-500">Would collect:</span> Reason for deactivation · Notification preference · Confirm</p>
                                    <div class="flex items-center gap-2 pt-1">
                                        <button type="button" class="px-3 py-1.5 bg-red-600 text-white rounded-lg text-xs font-medium hover:bg-red-700 transition-colors">Deactivate →</button>
                                        <span class="text-xs text-gray-400 italic">Not wired in prototype</span>
                                    </div>
                                </div>
                            </details>
                        </div>

                    </div>

                </div>
            </div>

        </div>
    </div>

{% endblock %}
