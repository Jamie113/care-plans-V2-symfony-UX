{% extends 'base.html.twig' %}

{% block title %}{{ plan.planName }} — Plan Detail{% endblock %}

{% block body %}

    {# ── Macros ──────────────────────────────────────────────────────────────── #}
    {% macro statusBadge(status, size) %}
        {% set base = size == 'lg'
            ? 'inline-flex items-center gap-1.5 px-3 py-1 rounded-full text-sm font-semibold border'
            : 'inline-flex items-center gap-1 px-2 py-0.5 rounded-full text-xs font-medium border' %}
        {% set dotSize = size == 'lg' ? 'w-2 h-2' : 'w-1.5 h-1.5' %}
        {% if status == 'active' %}
            <span class="{{ base }} bg-green-50 text-green-700 border-green-200">
                <span class="{{ dotSize }} rounded-full bg-green-500"></span>active
            </span>
        {% elseif status == 'requested-renew' %}
            <span class="{{ base }} bg-amber-50 text-amber-700 border-amber-200">
                <span class="{{ dotSize }} rounded-full bg-amber-500"></span>requested-renew
            </span>
        {% elseif status == 'requested-change' %}
            <span class="{{ base }} bg-blue-50 text-blue-700 border-blue-200">
                <span class="{{ dotSize }} rounded-full bg-blue-500"></span>requested-change
            </span>
        {% elseif status == 'requested-approve' %}
            <span class="{{ base }} bg-purple-50 text-purple-700 border-purple-200">
                <span class="{{ dotSize }} rounded-full bg-purple-500"></span>requested-approve
            </span>
        {% elseif status == 'deactivated' %}
            <span class="{{ base }} bg-red-50 text-red-700 border-red-200">
                <span class="{{ dotSize }} rounded-full bg-red-500"></span>deactivated
            </span>
        {% elseif status == 'expired' %}
            <span class="{{ base }} bg-gray-100 text-gray-500 border-gray-200">
                <span class="{{ dotSize }} rounded-full bg-gray-400"></span>expired
            </span>
        {% else %}
            <span class="{{ base }} bg-gray-100 text-gray-500 border-gray-200">
                <span class="{{ dotSize }} rounded-full bg-gray-400"></span>{{ status }}
            </span>
        {% endif %}
    {% endmacro %}

    {# ── Header ─────────────────────────────────────────────────────────────── #}
    <div class="border-b border-gray-200 bg-white sticky top-0 z-50 shadow-sm">
        <div class="mx-auto max-w-7xl px-4 sm:px-6 py-4">
            <div class="flex items-start justify-between gap-4">

                <div class="flex items-start gap-3 min-w-0">
                    <a href="{{ path('admin_patient_detail', {customerId: plan.customerId}) }}"
                       class="mt-0.5 flex items-center justify-center w-8 h-8 bg-gray-100 rounded-xl text-gray-500 hover:bg-gray-200 transition-colors flex-shrink-0"
                       title="Back to {{ plan.patientName }}">
                        <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" d="M15 19l-7-7 7-7"/>
                        </svg>
                    </a>
                    <div class="min-w-0">
                        <h1 class="text-lg sm:text-xl font-bold text-gray-900 leading-tight truncate" title="{{ plan.planName }}">{{ plan.planName }}</h1>
                        <p class="text-xs text-gray-400 mt-0.5">
                            <span class="font-mono">{{ plan.planId }}</span>
                            <span class="text-gray-300 mx-1.5">·</span>
                            {{ plan.patientName }}
                        </p>
                    </div>
                </div>

                <div class="flex-shrink-0 pt-0.5">
                    {{ _self.statusBadge(plan.status, 'lg') }}
                </div>

            </div>
        </div>
    </div>

    {# ── Payment failed banner ────────────────────────────────────────────────── #}
    {% if plan.paymentFailed %}
        <div class="bg-red-600">
            <div class="mx-auto max-w-7xl px-4 sm:px-6 py-3">
                <div class="flex items-center justify-between gap-4">
                    <div class="flex items-center gap-3 min-w-0">
                        <svg class="w-5 h-5 text-white flex-shrink-0" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z"/>
                        </svg>
                        <p class="text-sm font-medium text-white">
                            Payment failed — The last payment of £{{ plan.lastPaymentAmount|number_format(2) }} could not be collected. Retry or update billing details.
                        </p>
                    </div>
                    <button type="button" class="flex-shrink-0 px-3 py-1.5 bg-white text-red-600 rounded-lg text-xs font-semibold hover:bg-red-50 transition-colors">
                        Retry payment
                    </button>
                </div>
            </div>
        </div>
    {% endif %}

    {# ── Body ────────────────────────────────────────────────────────────────── #}
    <div class="mx-auto max-w-7xl px-4 sm:px-6 py-5 sm:py-8">
        <div class="grid grid-cols-12 gap-5 sm:gap-8">

            {# ── Left column ───────────────────────────────────────────────────── #}
            <div class="col-span-12 lg:col-span-8 space-y-5">

                {# ══ 1. Plan ══════════════════════════════════════════════════════ #}
                <div class="bg-white rounded-2xl border border-gray-200 shadow-sm overflow-hidden">

                    {# Card header #}
                    <div class="flex items-center justify-between gap-3 px-4 sm:px-6 py-4 border-b border-gray-100">
                        <div class="flex items-center gap-3 min-w-0">
                            <div class="flex items-center justify-center w-8 h-8 bg-gray-100 rounded-xl text-gray-500 flex-shrink-0">
                                <svg class="w-[17px] h-[17px]" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                                    <path stroke-linecap="round" stroke-linejoin="round" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2"/>
                                </svg>
                            </div>
                            <h2 class="text-sm font-semibold text-gray-900">Plan</h2>
                        </div>
                        <span class="inline-flex items-center px-2 py-0.5 rounded text-xs font-medium bg-gray-100 text-gray-600">{{ plan.category }}</span>
                    </div>

                    {# Key details grid #}
                    <div class="px-4 sm:px-6 py-4 border-b border-gray-100 grid grid-cols-2 sm:grid-cols-4 gap-x-6 gap-y-4">
                        <div>
                            <p class="text-xs text-gray-500 mb-1">Duration</p>
                            <p class="text-sm font-semibold text-gray-900">~{{ (plan.cycleDays * plan.ordersTotal / 30)|round }} months</p>
                            <p class="text-xs text-gray-400">{{ plan.ordersTotal }} orders · every {{ plan.cycleDays }} days</p>
                        </div>
                        <div>
                            <p class="text-xs text-gray-500 mb-1">Renewal date</p>
                            <p class="text-sm font-semibold text-gray-900">
                                {% if plan.renewalDate %}{{ plan.renewalDate|date('d M Y') }}{% else %}<span class="text-gray-400">—</span>{% endif %}
                            </p>
                        </div>
                        <div>
                            <p class="text-xs text-gray-500 mb-1">Orders shipped</p>
                            <p class="text-sm font-semibold text-gray-900">{{ plan.ordersCompleted }} / {{ plan.ordersTotal }}</p>
                            <p class="text-xs text-gray-400">{{ plan.ordersTotal - plan.ordersCompleted }} remaining</p>
                        </div>
                        <div>
                            <p class="text-xs text-gray-500 mb-1">Start date</p>
                            <p class="text-sm font-semibold text-gray-900">{{ plan.startDate|date('d M Y') }}</p>
                        </div>
                    </div>

                    {# Prescribed medications #}
                    <div class="px-4 sm:px-6 py-4 border-b border-gray-100">
                        <p class="text-xs font-semibold text-gray-500 uppercase tracking-wide mb-3">Prescribed medications</p>
                        {% if plan.medications is not empty %}
                            <ul class="space-y-2">
                                {% for med in plan.medications %}
                                    <li class="flex items-start gap-3 px-3 py-2.5 bg-gray-50 rounded-xl">
                                        <svg class="w-4 h-4 text-gray-400 mt-0.5 flex-shrink-0" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                                            <path stroke-linecap="round" stroke-linejoin="round" d="M19.5 12c0-1.232-.046-2.453-.138-3.662a4.006 4.006 0 00-3.7-3.7 48.678 48.678 0 00-7.324 0 4.006 4.006 0 00-3.7 3.7c-.017.22-.032.441-.046.662M19.5 12l3-3m-3 3l-3-3m-12 3c0 1.232.046 2.453.138 3.662a4.006 4.006 0 003.7 3.7 48.656 48.656 0 007.324 0 4.006 4.006 0 003.7-3.7c.017-.22.032-.441.046-.662M4.5 12l3 3m-3-3l-3 3"/>
                                        </svg>
                                        <div class="flex-1 min-w-0">
                                            <p class="text-sm font-medium text-gray-900">{{ med.name }} {{ med.variant }}</p>
                                            <p class="text-xs text-gray-500 mt-0.5 flex items-center gap-2 flex-wrap">
                                                <span>Current dose: <span class="font-medium text-gray-700">{{ med.currentDose ?? 'Not started' }}</span></span>
                                                {% if med.nextDose and med.nextDose != med.currentDose %}
                                                    <span class="inline-flex items-center gap-1 px-1.5 py-0.5 rounded text-xs font-medium bg-amber-50 text-amber-700 border border-amber-200">
                                                        titrating → {{ med.nextDose }}
                                                    </span>
                                                {% elseif med.currentDose %}
                                                    <span class="inline-flex items-center px-1.5 py-0.5 rounded text-xs font-medium bg-green-50 text-green-700 border border-green-200">stable</span>
                                                {% endif %}
                                            </p>
                                        </div>
                                    </li>
                                {% endfor %}
                            </ul>
                        {% else %}
                            <p class="text-sm text-gray-400">No medications recorded</p>
                        {% endif %}
                    </div>

                    {# Inclusions #}
                    <div class="px-4 sm:px-6 py-4">
                        <p class="text-xs font-semibold text-gray-500 uppercase tracking-wide mb-3">Inclusions</p>
                        {% if plan.inclusions is not empty %}
                            <ul class="space-y-2">
                                {% for item in plan.inclusions %}
                                    <li class="flex items-start gap-3 px-3 py-2 bg-gray-50 rounded-xl">
                                        <svg class="w-4 h-4 text-green-500 mt-0.5 flex-shrink-0" fill="currentColor" viewBox="0 0 20 20">
                                            <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/>
                                        </svg>
                                        <p class="text-sm text-gray-700">{{ item }}</p>
                                    </li>
                                {% endfor %}
                            </ul>
                        {% else %}
                            <p class="text-sm text-gray-400">No inclusions recorded for this plan</p>
                        {% endif %}
                    </div>

                </div>

                {# ══ 2. Shipments ════════════════════════════════════════════════ #}
                <div class="bg-white rounded-2xl border border-gray-200 shadow-sm overflow-hidden">
                    <div class="flex items-center gap-3 px-4 sm:px-6 py-4 border-b border-gray-100">
                        <div class="flex items-center justify-center w-8 h-8 bg-gray-100 rounded-xl text-gray-500 flex-shrink-0">
                            <svg class="w-[17px] h-[17px]" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" d="M9 17a2 2 0 11-4 0 2 2 0 014 0zM19 17a2 2 0 11-4 0 2 2 0 014 0z"/>
                                <path stroke-linecap="round" stroke-linejoin="round" d="M13 16V6a1 1 0 00-1-1H4a1 1 0 00-1 1v10l2 1m8-1h1m0-4l-3-4H9m4 4V9"/>
                            </svg>
                        </div>
                        <h2 class="text-sm font-semibold text-gray-900">Shipments</h2>
                    </div>

                    <div class="divide-y divide-gray-100">

                        {# Next order #}
                        <div class="px-4 sm:px-6 py-4">
                            <p class="text-xs font-semibold text-gray-500 uppercase tracking-wide mb-3">Next order</p>
                            {% if plan.nextOrderDate %}
                                <p class="text-sm font-medium text-gray-900 mb-1.5">{{ plan.nextOrderDate|date('d M Y') }}</p>
                                <ul class="space-y-1">
                                    {% for med in plan.medications %}
                                        {% set dispatchDose = (med.nextDose and med.nextDose != med.currentDose) ? med.nextDose : med.currentDose %}
                                        <li class="text-xs text-gray-500">
                                            <span class="font-medium text-gray-700">{{ med.name }}</span>
                                            {% if dispatchDose %} {{ dispatchDose }}{% endif %} ×1
                                        </li>
                                    {% endfor %}
                                </ul>
                            {% else %}
                                <p class="text-sm text-gray-400">No order currently scheduled</p>
                            {% endif %}
                        </div>

                        {# Last order #}
                        <div class="px-4 sm:px-6 py-4">
                            <p class="text-xs font-semibold text-gray-500 uppercase tracking-wide mb-3">Last order</p>
                            {% if plan.lastOrderDate and plan.shipments is not empty %}
                                {% set last = plan.shipments[0] %}
                                <div class="flex items-start justify-between gap-4">
                                    <div>
                                        <p class="text-sm font-medium text-gray-900">{{ plan.lastOrderDate|date('d M Y') }}</p>
                                        <p class="text-xs text-gray-500 mt-0.5">{{ last.items }}</p>
                                    </div>
                                    {% if last.status == 'delivered' %}
                                        <span class="inline-flex items-center gap-1 px-2 py-0.5 rounded-full text-xs font-medium bg-green-50 text-green-700 border border-green-200 flex-shrink-0">Delivered</span>
                                    {% elseif last.status == 'in-transit' %}
                                        <span class="inline-flex items-center gap-1 px-2 py-0.5 rounded-full text-xs font-medium bg-indigo-50 text-indigo-700 border border-indigo-200 flex-shrink-0">In Transit</span>
                                    {% elseif last.status == 'processing' %}
                                        <span class="inline-flex items-center gap-1 px-2 py-0.5 rounded-full text-xs font-medium bg-gray-100 text-gray-600 border border-gray-200 flex-shrink-0">Processing</span>
                                    {% elseif last.status == 'failed' %}
                                        <span class="inline-flex items-center gap-1 px-2 py-0.5 rounded-full text-xs font-medium bg-red-50 text-red-700 border border-red-200 flex-shrink-0">Failed</span>
                                    {% elseif last.status == 'cancelled' %}
                                        <span class="inline-flex items-center gap-1 px-2 py-0.5 rounded-full text-xs font-medium bg-gray-100 text-gray-500 border border-gray-200 flex-shrink-0">Cancelled</span>
                                    {% else %}
                                        <span class="inline-flex items-center gap-1 px-2 py-0.5 rounded-full text-xs font-medium bg-gray-100 text-gray-500 border border-gray-200 flex-shrink-0">{{ last.status }}</span>
                                    {% endif %}
                                </div>
                            {% elseif plan.lastOrderDate %}
                                <p class="text-sm font-medium text-gray-900">{{ plan.lastOrderDate|date('d M Y') }}</p>
                            {% else %}
                                <p class="text-sm text-gray-400">No orders dispatched yet</p>
                            {% endif %}
                        </div>

                    </div>

                    {# Footer — view all orders link #}
                    <div class="px-4 sm:px-6 py-3 bg-gray-50 border-t border-gray-100">
                        <a href="#" class="inline-flex items-center gap-1 text-xs font-medium text-blue-600 hover:text-blue-800 transition-colors">
                            View all orders for this plan
                            <svg class="w-3 h-3" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7"/></svg>
                        </a>
                    </div>
                </div>

                {# ══ 3. Upsells ══════════════════════════════════════════════════ #}
                <div class="bg-white rounded-2xl border border-gray-200 shadow-sm overflow-hidden">
                    <div class="flex items-center gap-3 px-4 sm:px-6 py-4 border-b border-gray-100">
                        <div class="flex items-center justify-center w-8 h-8 bg-gray-100 rounded-xl text-gray-500 flex-shrink-0">
                            <svg class="w-[17px] h-[17px]" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" d="M5 3v4M3 5h4M6 17v4m-2-2h4m5-16l2.286 6.857L21 12l-5.714 2.143L13 21l-2.286-6.857L5 12l5.714-2.143L13 3z"/>
                            </svg>
                        </div>
                        <div>
                            <h2 class="text-sm font-semibold text-gray-900">Upsells</h2>
                            <p class="text-xs text-gray-500">Add-ons active on this plan</p>
                        </div>
                    </div>
                    {% if plan.upsells is not empty %}
                        <ul class="divide-y divide-gray-100">
                            {% for upsell in plan.upsells %}
                                <li class="flex items-center justify-between px-4 sm:px-6 py-3 gap-4">
                                    <div>
                                        <p class="text-sm font-medium text-gray-900">{{ upsell.name }}</p>
                                        <p class="text-xs text-gray-500">£{{ upsell.price|number_format(2) }} / month</p>
                                    </div>
                                    <div class="flex items-center gap-3 flex-shrink-0">
                                        <span class="inline-flex items-center gap-1 px-2 py-0.5 rounded-full text-xs font-medium bg-green-50 text-green-700 border border-green-200">
                                            <span class="w-1.5 h-1.5 rounded-full bg-green-500"></span>{{ upsell.status }}
                                        </span>
                                        <a href="#" class="text-xs font-medium text-gray-500 hover:text-gray-800 transition-colors">View →</a>
                                    </div>
                                </li>
                            {% endfor %}
                        </ul>
                    {% else %}
                        <div class="px-4 sm:px-6 py-8 text-center">
                            <p class="text-sm text-gray-400">No active upsells on this plan</p>
                            <p class="text-xs text-gray-300 mt-1">Add-ons will appear here when active</p>
                        </div>
                    {% endif %}
                </div>

                {# ══ 4. Activity ═════════════════════════════════════════════════ #}
                <div class="bg-white rounded-2xl border border-gray-200 shadow-sm overflow-hidden">
                    <div class="flex items-center gap-3 px-4 sm:px-6 py-4 border-b border-gray-100">
                        <div class="flex items-center justify-center w-8 h-8 bg-gray-100 rounded-xl text-gray-500 flex-shrink-0">
                            <svg class="w-[17px] h-[17px]" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"/>
                            </svg>
                        </div>
                        <div>
                            <h2 class="text-sm font-semibold text-gray-900">Activity</h2>
                            <p class="text-xs text-gray-500">Changes and events on this plan</p>
                        </div>
                    </div>
                    <div class="px-4 sm:px-6 py-4">
                        {% if plan.activity is empty %}
                            <p class="text-sm text-gray-400 py-4 text-center">No activity recorded yet</p>
                        {% else %}
                            <ol class="relative border-l border-gray-200 space-y-5 ml-2">
                                {% for item in plan.activity %}
                                    <li class="ml-5">
                                        <span class="absolute -left-[7px] flex h-3.5 w-3.5 items-center justify-center rounded-full
                                            {% if item.type == 'plan_cancelled' %}bg-red-100 border border-red-300
                                            {% elseif item.type == 'plan_paused' %}bg-amber-100 border border-amber-300
                                            {% elseif item.type == 'discount_applied' %}bg-green-100 border border-green-300
                                            {% elseif item.type in ['plan_started', 'plan_created'] %}bg-blue-100 border border-blue-300
                                            {% else %}bg-white border border-gray-300
                                            {% endif %}">
                                        </span>
                                        <p class="text-sm text-gray-800 leading-snug">{{ item.description }}</p>
                                        <p class="text-xs text-gray-400 mt-0.5">{{ item.date|date('d M Y') }} · {{ item.agent }}</p>
                                    </li>
                                {% endfor %}
                            </ol>
                        {% endif %}
                    </div>
                </div>

            </div>

            {# ── Right column ──────────────────────────────────────────────────── #}
            <div class="col-span-12 lg:col-span-4">
                <div class="lg:sticky lg:top-[73px] space-y-5">

                    {# ══ Billing ══════════════════════════════════════════════════ #}
                    <div class="bg-white rounded-2xl border border-gray-200 shadow-sm overflow-hidden">
                        <div class="flex items-center gap-3 px-4 sm:px-6 py-4 border-b border-gray-100">
                            <div class="flex items-center justify-center w-8 h-8 bg-gray-100 rounded-xl text-gray-500 flex-shrink-0">
                                <svg class="w-[17px] h-[17px]" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                                    <path stroke-linecap="round" stroke-linejoin="round" d="M3 10h18M7 15h1m4 0h1m-7 4h12a3 3 0 003-3V8a3 3 0 00-3-3H6a3 3 0 00-3 3v8a3 3 0 003 3z"/>
                                </svg>
                            </div>
                            <h2 class="text-sm font-semibold text-gray-900">Billing</h2>
                        </div>

                        <div class="divide-y divide-gray-100">

                            {# Next payment #}
                            <div class="px-4 sm:px-6 py-4">
                                <p class="text-xs font-semibold text-gray-500 uppercase tracking-wide mb-3">Next payment</p>
                                {% if plan.status in ['deactivated', 'expired'] %}
                                    <p class="text-sm text-gray-400 italic">No upcoming payment — plan is {{ plan.status }}</p>
                                {% else %}
                                    <div class="flex items-baseline gap-2 mb-1">
                                        <span class="text-2xl font-bold {{ plan.paymentFailed ? 'text-red-600' : 'text-gray-900' }}">£{{ plan.nextPaymentAmount|number_format(2) }}</span>
                                        {% if plan.discount %}
                                            <span class="text-sm text-gray-400 line-through">£{{ plan.price|number_format(2) }}</span>
                                        {% endif %}
                                        {% if plan.paymentFailed %}
                                            <span class="inline-flex items-center px-2 py-0.5 rounded-full text-xs font-medium bg-red-50 text-red-700 border border-red-200">Failed</span>
                                        {% endif %}
                                    </div>
                                    {% if plan.discount %}
                                        <div class="flex items-center gap-1.5 mb-1.5">
                                            <span class="inline-flex items-center px-2 py-0.5 rounded-full text-xs font-medium bg-green-50 text-green-700 border border-green-200">{{ plan.discount }}</span>
                                            <span class="text-xs text-gray-500">saving £{{ (plan.price - plan.nextPaymentAmount)|number_format(2) }}</span>
                                        </div>
                                    {% else %}
                                        <p class="text-xs text-gray-400 mb-1.5">No discount applied</p>
                                    {% endif %}
                                    {% if plan.nextBillingDate %}
                                        <p class="text-xs text-gray-500">Due <span class="font-medium text-gray-700">{{ plan.nextBillingDate|date('d M Y') }}</span></p>
                                    {% endif %}
                                {% endif %}
                            </div>

                            {# Billing frequency #}
                            <div class="px-4 sm:px-6 py-4">
                                <p class="text-xs font-semibold text-gray-500 uppercase tracking-wide mb-3">Billing frequency</p>
                                <div class="space-y-3">
                                    <div>
                                        <p class="text-xs text-gray-500 mb-0.5">Basket value</p>
                                        <p class="text-sm font-medium text-gray-900">£{{ plan.price|number_format(2) }} per order</p>
                                    </div>
                                    <div>
                                        <p class="text-xs text-gray-500 mb-0.5">Billing cycle</p>
                                        <p class="text-sm font-medium text-gray-900">Every {{ plan.billingCycleDays }} days</p>
                                        {% if plan.billingMatchesOrder %}
                                            <p class="text-xs text-gray-400">Billed with each order dispatch</p>
                                        {% else %}
                                            <p class="text-xs text-amber-600">Separate from order cycle (every {{ plan.cycleDays }} days)</p>
                                        {% endif %}
                                    </div>
                                </div>
                            </div>

                            {# Last payment #}
                            <div class="px-4 sm:px-6 py-4">
                                <p class="text-xs font-semibold text-gray-500 uppercase tracking-wide mb-3">Last payment</p>
                                <div class="flex items-center gap-3">
                                    <p class="text-sm font-medium text-gray-900">£{{ plan.lastPaymentAmount|number_format(2) }}</p>
                                    {% if plan.paymentFailed %}
                                        <span class="inline-flex items-center px-2 py-0.5 rounded-full text-xs font-medium bg-red-50 text-red-700 border border-red-200">Failed</span>
                                    {% elseif plan.lastPaymentAmount > 0 %}
                                        <span class="inline-flex items-center px-2 py-0.5 rounded-full text-xs font-medium bg-green-50 text-green-700 border border-green-200">Paid</span>
                                    {% endif %}
                                    {% if plan.lastBillingDate %}
                                        <span class="text-xs text-gray-500">{{ plan.lastBillingDate|date('d M Y') }}</span>
                                    {% endif %}
                                </div>
                            </div>

                        </div>
                    </div>

                    {# ══ Actions ══════════════════════════════════════════════════ #}
                    <div class="bg-white rounded-2xl border border-gray-200 shadow-sm overflow-hidden">
                        <div class="flex items-center gap-3 px-4 sm:px-6 py-4 border-b border-gray-100">
                            <div class="flex items-center justify-center w-8 h-8 bg-gray-100 rounded-xl text-gray-500 flex-shrink-0">
                                <svg class="w-[17px] h-[17px]" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                                    <path stroke-linecap="round" stroke-linejoin="round" d="M13 10V3L4 14h7v7l9-11h-7z"/>
                                </svg>
                            </div>
                            <div>
                                <h2 class="text-sm font-semibold text-gray-900">Actions</h2>
                                <p class="text-xs text-gray-500">Manage this plan</p>
                            </div>
                        </div>

                        <div class="p-4 sm:p-5 space-y-2">

                            {# Change order date #}
                            <details class="group rounded-xl border border-gray-200 overflow-hidden">
                                <summary class="flex items-center gap-3 px-4 py-3 cursor-pointer bg-gray-50 hover:bg-gray-100 transition-colors [&::-webkit-details-marker]:hidden list-none">
                                    <div class="w-7 h-7 bg-white border border-gray-200 rounded-lg flex items-center justify-center flex-shrink-0 group-open:border-gray-300">
                                        <svg class="w-4 h-4 text-gray-600" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                                            <path stroke-linecap="round" stroke-linejoin="round" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"/>
                                        </svg>
                                    </div>
                                    <div class="flex-1 min-w-0">
                                        <p class="text-sm font-medium text-gray-800">Change order date</p>
                                        <p class="text-xs text-gray-500">Patient wants their next delivery on a different day</p>
                                    </div>
                                    <svg class="w-4 h-4 text-gray-400 flex-shrink-0 transition-transform group-open:rotate-90" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                                        <path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7"/>
                                    </svg>
                                </summary>
                                <div class="px-4 py-3 bg-white border-t border-gray-100 space-y-2">
                                    <p class="text-xs text-gray-600">Use this if a patient calls asking to receive their next delivery on a different day — for example, they're going on holiday or won't be home to accept it.</p>
                                    <p class="text-xs text-gray-400"><span class="font-medium text-gray-500">You'll need:</span> The new date they'd like · A brief reason if they gave one</p>
                                    <div class="flex items-center gap-2 pt-1">
                                        <button type="button" class="px-3 py-1.5 bg-gray-900 text-white rounded-lg text-xs font-medium hover:bg-gray-700 transition-colors">Continue →</button>
                                        <span class="text-xs text-gray-400 italic">Not wired in prototype</span>
                                    </div>
                                </div>
                            </details>

                            {# Change billing date #}
                            <details class="group rounded-xl border border-gray-200 overflow-hidden">
                                <summary class="flex items-center gap-3 px-4 py-3 cursor-pointer bg-gray-50 hover:bg-gray-100 transition-colors [&::-webkit-details-marker]:hidden list-none">
                                    <div class="w-7 h-7 bg-white border border-gray-200 rounded-lg flex items-center justify-center flex-shrink-0 group-open:border-gray-300">
                                        <svg class="w-4 h-4 text-gray-600" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                                            <path stroke-linecap="round" stroke-linejoin="round" d="M3 10h18M7 15h1m4 0h1m-7 4h12a3 3 0 003-3V8a3 3 0 00-3-3H6a3 3 0 00-3 3v8a3 3 0 003 3z"/>
                                        </svg>
                                    </div>
                                    <div class="flex-1 min-w-0">
                                        <p class="text-sm font-medium text-gray-800">Change billing date</p>
                                        <p class="text-xs text-gray-500">Patient wants their payment taken on a different date</p>
                                    </div>
                                    <svg class="w-4 h-4 text-gray-400 flex-shrink-0 transition-transform group-open:rotate-90" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                                        <path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7"/>
                                    </svg>
                                </summary>
                                <div class="px-4 py-3 bg-white border-t border-gray-100 space-y-2">
                                    <p class="text-xs text-gray-600">Use this if a patient wants to change when their payment comes out — for example, to match their payday or avoid a busy period in their account.</p>
                                    <p class="text-xs text-gray-400"><span class="font-medium text-gray-500">You'll need:</span> The new date they'd like · Whether this is a one-off change or permanent</p>
                                    <div class="flex items-center gap-2 pt-1">
                                        <button type="button" class="px-3 py-1.5 bg-gray-900 text-white rounded-lg text-xs font-medium hover:bg-gray-700 transition-colors">Continue →</button>
                                        <span class="text-xs text-gray-400 italic">Not wired in prototype</span>
                                    </div>
                                </div>
                            </details>

                            {# Change plan #}
                            <details class="group rounded-xl border border-gray-200 overflow-hidden">
                                <summary class="flex items-center gap-3 px-4 py-3 cursor-pointer bg-gray-50 hover:bg-gray-100 transition-colors [&::-webkit-details-marker]:hidden list-none">
                                    <div class="w-7 h-7 bg-white border border-gray-200 rounded-lg flex items-center justify-center flex-shrink-0 group-open:border-gray-300">
                                        <svg class="w-4 h-4 text-gray-600" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                                            <path stroke-linecap="round" stroke-linejoin="round" d="M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2m15.357 2H15"/>
                                        </svg>
                                    </div>
                                    <div class="flex-1 min-w-0">
                                        <p class="text-sm font-medium text-gray-800">Change plan</p>
                                        <p class="text-xs text-gray-500">Patient wants to move to a different plan</p>
                                    </div>
                                    <svg class="w-4 h-4 text-gray-400 flex-shrink-0 transition-transform group-open:rotate-90" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                                        <path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7"/>
                                    </svg>
                                </summary>
                                <div class="px-4 py-3 bg-white border-t border-gray-100 space-y-2">
                                    <p class="text-xs text-gray-600">Use this if a patient wants to move to a longer or shorter plan — for example, upgrading from a 3-month to a 6-month plan. Only use this with approval from a clinician or supervisor if the medication is changing.</p>
                                    <p class="text-xs text-gray-400"><span class="font-medium text-gray-500">You'll need:</span> Which plan they're moving to · When to switch (straight away or at the next renewal)</p>
                                    <div class="flex items-center gap-2 pt-1">
                                        <button type="button" class="px-3 py-1.5 bg-gray-900 text-white rounded-lg text-xs font-medium hover:bg-gray-700 transition-colors">Continue →</button>
                                        <span class="text-xs text-gray-400 italic">Not wired in prototype</span>
                                    </div>
                                </div>
                            </details>

                            {# Change offer & billing #}
                            <details class="group rounded-xl border border-gray-200 overflow-hidden">
                                <summary class="flex items-center gap-3 px-4 py-3 cursor-pointer bg-gray-50 hover:bg-gray-100 transition-colors [&::-webkit-details-marker]:hidden list-none">
                                    <div class="w-7 h-7 bg-white border border-gray-200 rounded-lg flex items-center justify-center flex-shrink-0 group-open:border-gray-300">
                                        <svg class="w-4 h-4 text-gray-600" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                                            <path stroke-linecap="round" stroke-linejoin="round" d="M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/>
                                        </svg>
                                    </div>
                                    <div class="flex-1 min-w-0">
                                        <p class="text-sm font-medium text-gray-800">Change offer &amp; billing</p>
                                        <p class="text-xs text-gray-500">Patient is on the wrong deal or wants different pricing</p>
                                    </div>
                                    <svg class="w-4 h-4 text-gray-400 flex-shrink-0 transition-transform group-open:rotate-90" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                                        <path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7"/>
                                    </svg>
                                </summary>
                                <div class="px-4 py-3 bg-white border-t border-gray-100 space-y-2">
                                    <p class="text-xs text-gray-600">Use this to move a patient onto a different deal — for example, if they've been offered a loyalty price, want to pay monthly instead of upfront, or were signed up on the wrong promotion.</p>
                                    <p class="text-xs text-gray-400"><span class="font-medium text-gray-500">You'll need:</span> The offer or price they should be on · When the change should take effect</p>
                                    <div class="flex items-center gap-2 pt-1">
                                        <button type="button" class="px-3 py-1.5 bg-gray-900 text-white rounded-lg text-xs font-medium hover:bg-gray-700 transition-colors">Continue →</button>
                                        <span class="text-xs text-gray-400 italic">Not wired in prototype</span>
                                    </div>
                                </div>
                            </details>

                            {# Add / adjust discount #}
                            <details class="group rounded-xl border border-gray-200 overflow-hidden">
                                <summary class="flex items-center gap-3 px-4 py-3 cursor-pointer bg-gray-50 hover:bg-gray-100 transition-colors [&::-webkit-details-marker]:hidden list-none">
                                    <div class="w-7 h-7 bg-white border border-gray-200 rounded-lg flex items-center justify-center flex-shrink-0 group-open:border-gray-300">
                                        <svg class="w-4 h-4 text-gray-600" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                                            <path stroke-linecap="round" stroke-linejoin="round" d="M7 7h.01M17 17h.01M7 17L17 7M7.5 7.5h.01m9 9h.01"/>
                                        </svg>
                                    </div>
                                    <div class="flex-1 min-w-0">
                                        <p class="text-sm font-medium text-gray-800">Add / adjust discount</p>
                                        <p class="text-xs text-gray-500">Patient needs a reduction applied to their payments</p>
                                    </div>
                                    <svg class="w-4 h-4 text-gray-400 flex-shrink-0 transition-transform group-open:rotate-90" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                                        <path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7"/>
                                    </svg>
                                </summary>
                                <div class="px-4 py-3 bg-white border-t border-gray-100 space-y-2">
                                    <p class="text-xs text-gray-600">Use this to reduce what a patient is charged — for example, as a goodwill gesture after a service issue, or to apply a promotional reduction that's been approved by your supervisor. Do not apply discounts without authorisation.</p>
                                    <p class="text-xs text-gray-400"><span class="font-medium text-gray-500">You'll need:</span> The discount amount or percentage · How many payments it applies to · The reason</p>
                                    <div class="flex items-center gap-2 pt-1">
                                        <button type="button" class="px-3 py-1.5 bg-gray-900 text-white rounded-lg text-xs font-medium hover:bg-gray-700 transition-colors">Continue →</button>
                                        <span class="text-xs text-gray-400 italic">Not wired in prototype</span>
                                    </div>
                                </div>
                            </details>

                            {# Send one-off order #}
                            <details class="group rounded-xl border border-gray-200 overflow-hidden">
                                <summary class="flex items-center gap-3 px-4 py-3 cursor-pointer bg-gray-50 hover:bg-gray-100 transition-colors [&::-webkit-details-marker]:hidden list-none">
                                    <div class="w-7 h-7 bg-white border border-gray-200 rounded-lg flex items-center justify-center flex-shrink-0 group-open:border-gray-300">
                                        <svg class="w-4 h-4 text-gray-600" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                                            <path stroke-linecap="round" stroke-linejoin="round" d="M20 7l-8-4-8 4m16 0l-8 4m8-4v10l-8 4m0-10L4 7m8 4v10M4 7v10l8 4"/>
                                        </svg>
                                    </div>
                                    <div class="flex-1 min-w-0">
                                        <p class="text-sm font-medium text-gray-800">Send one-off order</p>
                                        <p class="text-xs text-gray-500">Patient needs an extra delivery outside their usual schedule</p>
                                    </div>
                                    <svg class="w-4 h-4 text-gray-400 flex-shrink-0 transition-transform group-open:rotate-90" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                                        <path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7"/>
                                    </svg>
                                </summary>
                                <div class="px-4 py-3 bg-white border-t border-gray-100 space-y-2">
                                    <p class="text-xs text-gray-600">Use this to send an extra delivery that isn't part of the patient's regular plan — for example, if their last order was lost in the post, arrived damaged, or they urgently need a replacement. This won't change their regular schedule.</p>
                                    <p class="text-xs text-gray-400"><span class="font-medium text-gray-500">You'll need:</span> What to send and the dose · When to send it · Whether to charge the patient or send it free of charge</p>
                                    <div class="flex items-center gap-2 pt-1">
                                        <button type="button" class="px-3 py-1.5 bg-gray-900 text-white rounded-lg text-xs font-medium hover:bg-gray-700 transition-colors">Continue →</button>
                                        <span class="text-xs text-gray-400 italic">Not wired in prototype</span>
                                    </div>
                                </div>
                            </details>

                        </div>

                        {# Deactivate — separated, destructive #}
                        <div class="px-4 sm:px-5 pb-4 sm:pb-5 border-t border-gray-100 pt-3">
                            <details class="group rounded-xl border border-red-200 overflow-hidden">
                                <summary class="flex items-center gap-3 px-4 py-3 cursor-pointer bg-red-50 hover:bg-red-100 transition-colors [&::-webkit-details-marker]:hidden list-none">
                                    <div class="w-7 h-7 bg-white border border-red-200 rounded-lg flex items-center justify-center flex-shrink-0 group-open:border-red-300">
                                        <svg class="w-4 h-4 text-red-600" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                                            <path stroke-linecap="round" stroke-linejoin="round" d="M10 14l2-2m0 0l2-2m-2 2l-2-2m2 2l2 2m7-2a9 9 0 11-18 0 9 9 0 0118 0z"/>
                                        </svg>
                                    </div>
                                    <div class="flex-1 min-w-0">
                                        <p class="text-sm font-medium text-red-700">Deactivate plan</p>
                                        <p class="text-xs text-red-500">Fully stops the plan — no more deliveries or payments</p>
                                    </div>
                                    <svg class="w-4 h-4 text-red-400 flex-shrink-0 transition-transform group-open:rotate-90" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                                        <path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7"/>
                                    </svg>
                                </summary>
                                <div class="px-4 py-3 bg-white border-t border-red-100 space-y-2">
                                    <p class="text-xs text-gray-600">Use this only if the patient has asked to cancel, or if you've been instructed to by a clinician or supervisor. Deactivating stops all future orders and payments immediately. It can be reversed if needed.</p>
                                    <p class="text-xs text-gray-400"><span class="font-medium text-gray-500">You'll need:</span> The reason for deactivating · Confirmation that the patient has been informed</p>
                                    <div class="flex items-center gap-2 pt-1">
                                        <button type="button" class="px-3 py-1.5 bg-red-600 text-white rounded-lg text-xs font-medium hover:bg-red-700 transition-colors">Continue →</button>
                                        <span class="text-xs text-gray-400 italic">Not wired in prototype</span>
                                    </div>
                                </div>
                            </details>
                        </div>

                    </div>

                </div>
            </div>

        </div>
    </div>

{% endblock %}
