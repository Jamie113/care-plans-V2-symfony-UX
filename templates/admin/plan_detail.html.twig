{% extends 'base.html.twig' %}

{% block title %}{{ plan.planName }} — Plan Detail{% endblock %}

{% block body %}

    {# ── Macros ──────────────────────────────────────────────────────────────── #}
    {% macro statusBadge(status, size) %}
        {% set base = size == 'lg'
            ? 'inline-flex items-center gap-1.5 px-3 py-1 rounded-full text-sm font-semibold border'
            : 'inline-flex items-center gap-1 px-2 py-0.5 rounded-full text-xs font-medium border' %}
        {% set dotSize = size == 'lg' ? 'w-2 h-2' : 'w-1.5 h-1.5' %}
        {% if status == 'active' %}
            <span class="{{ base }} bg-green-50 text-green-700 border-green-200">
                <span class="{{ dotSize }} rounded-full bg-green-500"></span>active
            </span>
        {% elseif status == 'requested-renew' %}
            <span class="{{ base }} bg-amber-50 text-amber-700 border-amber-200">
                <span class="{{ dotSize }} rounded-full bg-amber-500"></span>requested-renew
            </span>
        {% elseif status == 'requested-change' %}
            <span class="{{ base }} bg-blue-50 text-blue-700 border-blue-200">
                <span class="{{ dotSize }} rounded-full bg-blue-500"></span>requested-change
            </span>
        {% elseif status == 'requested-approve' %}
            <span class="{{ base }} bg-purple-50 text-purple-700 border-purple-200">
                <span class="{{ dotSize }} rounded-full bg-purple-500"></span>requested-approve
            </span>
        {% elseif status == 'deactivated' %}
            <span class="{{ base }} bg-red-50 text-red-700 border-red-200">
                <span class="{{ dotSize }} rounded-full bg-red-500"></span>deactivated
            </span>
        {% elseif status == 'expired' %}
            <span class="{{ base }} bg-gray-100 text-gray-500 border-gray-200">
                <span class="{{ dotSize }} rounded-full bg-gray-400"></span>expired
            </span>
        {% else %}
            <span class="{{ base }} bg-gray-100 text-gray-500 border-gray-200">
                <span class="{{ dotSize }} rounded-full bg-gray-400"></span>{{ status }}
            </span>
        {% endif %}
    {% endmacro %}

    {# ── Header ─────────────────────────────────────────────────────────────── #}
    <div class="border-b border-gray-200 bg-white sticky top-0 z-50 shadow-sm">
        <div class="mx-auto max-w-7xl px-4 sm:px-6 py-4">
            <div class="flex items-start justify-between gap-4">

                <div class="flex items-start gap-3 min-w-0">
                    <a href="{{ path('admin_patient_detail', {customerId: plan.customerId}) }}"
                       class="mt-0.5 flex items-center justify-center w-8 h-8 bg-gray-100 rounded-xl text-gray-500 hover:bg-gray-200 transition-colors flex-shrink-0"
                       title="Back to {{ plan.patientName }}">
                        <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" d="M15 19l-7-7 7-7"/>
                        </svg>
                    </a>
                    <div class="min-w-0">
                        <h1 class="text-lg sm:text-xl font-bold text-gray-900 leading-tight truncate" title="{{ plan.planName }}">{{ plan.planName }}</h1>
                        <p class="text-xs text-gray-400 mt-0.5">
                            <span class="font-mono">{{ plan.planId }}</span>
                            <span class="text-gray-300 mx-1.5">·</span>
                            {{ plan.patientName }}
                        </p>
                    </div>
                </div>

                <div class="flex-shrink-0 pt-0.5">
                    {{ _self.statusBadge(plan.status, 'lg') }}
                </div>

            </div>
        </div>
    </div>

    {# ── Payment failed banner ────────────────────────────────────────────────── #}
    {% if plan.paymentFailed %}
        <div class="bg-red-600">
            <div class="mx-auto max-w-7xl px-4 sm:px-6 py-3">
                <div class="flex items-center justify-between gap-4">
                    <div class="flex items-center gap-3 min-w-0">
                        <svg class="w-5 h-5 text-white flex-shrink-0" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z"/>
                        </svg>
                        <p class="text-sm font-medium text-white">
                            Payment failed — The last payment of £{{ plan.lastPaymentAmount|number_format(2) }} could not be collected. Retry or update billing details.
                        </p>
                    </div>
                    <button type="button" class="flex-shrink-0 px-3 py-1.5 bg-white text-red-600 rounded-lg text-xs font-semibold hover:bg-red-50 transition-colors">
                        Retry payment
                    </button>
                </div>
            </div>
        </div>
    {% endif %}

    {# ── Body ────────────────────────────────────────────────────────────────── #}
    <div class="mx-auto max-w-7xl px-4 sm:px-6 py-5 sm:py-8">
        <div class="grid grid-cols-12 gap-5 sm:gap-8">

            {# ── Left column ───────────────────────────────────────────────────── #}
            <div class="col-span-12 lg:col-span-8 space-y-5">

                {# ══ 1. Plan ══════════════════════════════════════════════════════ #}
                <div class="bg-white rounded-2xl border border-gray-200 shadow-sm overflow-hidden">

                    {# Card header #}
                    <div class="flex items-center justify-between gap-3 px-4 sm:px-6 py-4 border-b border-gray-100">
                        <div class="flex items-center gap-3 min-w-0">
                            <div class="flex items-center justify-center w-8 h-8 bg-gray-100 rounded-xl text-gray-500 flex-shrink-0">
                                <svg class="w-[17px] h-[17px]" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                                    <path stroke-linecap="round" stroke-linejoin="round" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2"/>
                                </svg>
                            </div>
                            <h2 class="text-sm font-semibold text-gray-900">Plan</h2>
                        </div>
                        <span class="inline-flex items-center px-2 py-0.5 rounded text-xs font-medium bg-gray-100 text-gray-600">{{ plan.category }}</span>
                    </div>

                    {# Key details grid #}
                    <div class="px-4 sm:px-6 py-4 border-b border-gray-100 grid grid-cols-2 sm:grid-cols-3 lg:grid-cols-5 gap-x-6 gap-y-4">
                        <div>
                            <p class="text-xs text-gray-500 mb-1">Duration</p>
                            <p class="text-sm font-semibold text-gray-900">~{{ (plan.cycleDays * plan.ordersTotal / 30)|round }} months</p>
                        </div>
                        <div>
                            <p class="text-xs text-gray-500 mb-1">Shipment frequency</p>
                            <p class="text-sm font-semibold text-gray-900">Every {{ plan.cycleDays }} days</p>
                        </div>
                        <div>
                            <p class="text-xs text-gray-500 mb-1">Renewal date</p>
                            <p class="text-sm font-semibold text-gray-900">
                                {% if plan.renewalDate %}{{ plan.renewalDate|date('d M Y') }}{% else %}<span class="text-gray-400">—</span>{% endif %}
                            </p>
                        </div>
                        <div>
                            <p class="text-xs text-gray-500 mb-1">Start date</p>
                            <p class="text-sm font-semibold text-gray-900">{{ plan.startDate|date('d M Y') }}</p>
                        </div>
                    </div>

                    {# Tabs: Medications / Inclusions / Shipments / Titration #}
                    {% set isTitrating = false %}
                    {% for med in plan.medications %}
                        {% if med.isTitrating %}{% set isTitrating = true %}{% endif %}
                    {% endfor %}

                    <div x-data="{ tab: 'medications' }">

                        {# Tab bar #}
                        <div class="flex border-b border-gray-100">
                            <button
                                type="button"
                                @click="tab = 'medications'"
                                :class="tab === 'medications'
                                    ? 'border-b-2 border-gray-900 text-gray-900 font-semibold'
                                    : 'text-gray-500 hover:text-gray-700'"
                                class="px-4 sm:px-6 py-3 text-sm transition-colors -mb-px"
                            >Medications</button>
                            <button
                                type="button"
                                @click="tab = 'inclusions'"
                                :class="tab === 'inclusions'
                                    ? 'border-b-2 border-gray-900 text-gray-900 font-semibold'
                                    : 'text-gray-500 hover:text-gray-700'"
                                class="px-4 sm:px-6 py-3 text-sm transition-colors -mb-px"
                            >Inclusions</button>
                            <button
                                type="button"
                                @click="tab = 'shipments'"
                                :class="tab === 'shipments'
                                    ? 'border-b-2 border-gray-900 text-gray-900 font-semibold'
                                    : 'text-gray-500 hover:text-gray-700'"
                                class="px-4 sm:px-6 py-3 text-sm transition-colors -mb-px"
                            >Shipments</button>
                            {% if isTitrating %}
                            <button
                                type="button"
                                @click="tab = 'titration'"
                                :class="tab === 'titration'
                                    ? 'border-b-2 border-amber-500 text-amber-700 font-semibold'
                                    : 'text-gray-500 hover:text-gray-700'"
                                class="px-4 sm:px-6 py-3 text-sm transition-colors -mb-px flex items-center gap-1.5"
                            >
                                Titration
                                <span class="inline-flex items-center px-1.5 py-0.5 rounded text-xs font-medium bg-amber-100 text-amber-700">active</span>
                            </button>
                            {% endif %}
                        </div>

                        {# Medications panel #}
                        <div x-show="tab === 'medications'" class="px-4 sm:px-6 py-4">
                            {% if plan.medications is not empty %}
                                <ul class="space-y-2">
                                    {% for med in plan.medications %}
                                        <li class="flex items-center gap-3 px-3 py-2.5 bg-gray-50 rounded-xl">
                                            <svg class="w-4 h-4 text-gray-400 flex-shrink-0" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                                                <path stroke-linecap="round" stroke-linejoin="round" d="M19.5 12c0-1.232-.046-2.453-.138-3.662a4.006 4.006 0 00-3.7-3.7 48.678 48.678 0 00-7.324 0 4.006 4.006 0 00-3.7 3.7c-.017.22-.032.441-.046.662M19.5 12l3-3m-3 3l-3-3m-12 3c0 1.232.046 2.453.138 3.662a4.006 4.006 0 003.7 3.7 48.656 48.656 0 007.324 0 4.006 4.006 0 003.7-3.7c.017-.22.032-.441.046-.662M4.5 12l3 3m-3-3l-3 3"/>
                                            </svg>
                                            <p class="text-sm font-medium text-gray-900">{{ med.name }}</p>
                                        </li>
                                    {% endfor %}
                                </ul>
                            {% else %}
                                <p class="text-sm text-gray-400">No medications recorded</p>
                            {% endif %}
                        </div>

                        {# Inclusions panel #}
                        <div x-show="tab === 'inclusions'" class="px-4 sm:px-6 py-4">
                            {% if plan.inclusions is not empty %}
                                <ul class="space-y-2">
                                    {% for item in plan.inclusions %}
                                        <li class="flex items-start gap-3 px-3 py-2 bg-gray-50 rounded-xl">
                                            <svg class="w-4 h-4 text-green-500 mt-0.5 flex-shrink-0" fill="currentColor" viewBox="0 0 20 20">
                                                <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/>
                                            </svg>
                                            <p class="text-sm text-gray-700">{{ item }}</p>
                                        </li>
                                    {% endfor %}
                                </ul>
                            {% else %}
                                <p class="text-sm text-gray-400">No inclusions recorded for this plan</p>
                            {% endif %}
                        </div>

                        {# Shipments panel #}
                        <div x-show="tab === 'shipments'" class="px-4 sm:px-6 py-4 space-y-4">
                            <div class="grid grid-cols-2 gap-4">
                                <div class="px-4 py-3 bg-gray-50 rounded-xl">
                                    <p class="text-xs text-gray-500 mb-1">Next shipment</p>
                                    <p class="text-sm font-semibold text-gray-900">
                                        {% if plan.nextOrderDate %}{{ plan.nextOrderDate|date('d M Y') }}{% else %}<span class="text-gray-400">—</span>{% endif %}
                                    </p>
                                </div>
                                <div class="px-4 py-3 bg-gray-50 rounded-xl">
                                    <p class="text-xs text-gray-500 mb-1">Last shipment</p>
                                    <p class="text-sm font-semibold text-gray-900">
                                        {% if plan.lastOrderDate %}{{ plan.lastOrderDate|date('d M Y') }}{% else %}<span class="text-gray-400">—</span>{% endif %}
                                    </p>
                                </div>
                            </div>
                            <a href="https://shop.staging.joinvoy-com.dev/likeaboss/customers/2057745/orders" target="_blank" rel="noopener noreferrer" class="inline-flex items-center gap-1.5 px-4 py-2.5 text-sm font-medium text-blue-700 border border-dashed border-blue-300 rounded-xl hover:bg-blue-50 hover:border-blue-400 transition-colors w-full justify-center">
                                View all orders for this plan
                                <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14"/></svg>
                            </a>
                        </div>

                        {# Titration panel #}
                        {% if isTitrating %}
                        <div x-show="tab === 'titration'" class="px-4 sm:px-6 py-4 space-y-6">
                            {% for med in plan.medications %}
                                {% if med.isTitrating and med.titrationSchedule is not empty %}
                                <div>
                                    <p class="text-xs font-semibold text-gray-500 uppercase tracking-wide mb-3">{{ med.name }}</p>
                                    <ol class="space-y-1">
                                        {% for dose in med.titrationSchedule %}
                                            {% set isCurrent   = dose == med.currentDose %}
                                            {% set isNext      = dose == med.nextDose %}
                                            {% set isRequested = med.patientRequestedDose is not null and dose == med.patientRequestedDose %}
                                            {% set isPast      = med.titrationSchedule|slice(0, loop.index0)|filter(d => d == med.currentDose)|length > 0 or isCurrent %}
                                            <li class="flex items-center gap-3 px-3 py-2.5 rounded-xl
                                                {% if isCurrent %}bg-green-50 border border-green-200
                                                {% elseif isNext %}bg-amber-50 border border-amber-200
                                                {% elseif isRequested %}bg-purple-50 border border-purple-200
                                                {% else %}bg-gray-50
                                                {% endif %}">

                                                {# Dot #}
                                                <span class="w-2.5 h-2.5 rounded-full flex-shrink-0
                                                    {% if isCurrent %}bg-green-500
                                                    {% elseif isNext %}bg-amber-400
                                                    {% elseif isRequested %}bg-purple-500
                                                    {% else %}bg-gray-300
                                                    {% endif %}"></span>

                                                {# Dose label #}
                                                <span class="text-sm flex-1
                                                    {% if isCurrent %}font-semibold text-green-800
                                                    {% elseif isNext %}font-semibold text-amber-800
                                                    {% elseif isRequested %}font-semibold text-purple-800
                                                    {% else %}text-gray-400
                                                    {% endif %}">
                                                    {{ med.name }} {{ dose }}
                                                </span>

                                                {# Badge #}
                                                {% if isCurrent %}
                                                    <span class="inline-flex items-center px-2 py-0.5 rounded-full text-xs font-medium bg-green-100 text-green-700 flex-shrink-0">Current dose</span>
                                                {% elseif isNext and isRequested %}
                                                    <span class="inline-flex items-center px-2 py-0.5 rounded-full text-xs font-medium bg-amber-100 text-amber-700 flex-shrink-0">Next dose</span>
                                                {% elseif isNext %}
                                                    <span class="inline-flex items-center px-2 py-0.5 rounded-full text-xs font-medium bg-amber-100 text-amber-700 flex-shrink-0">Next dose</span>
                                                {% elseif isRequested %}
                                                    <span class="inline-flex items-center px-2 py-0.5 rounded-full text-xs font-medium bg-purple-100 text-purple-700 flex-shrink-0">Patient requested</span>
                                                {% endif %}
                                            </li>
                                        {% endfor %}
                                    </ol>
                                </div>
                                {% endif %}
                            {% endfor %}
                        </div>
                        {% endif %}

                    </div>

                </div>

                {# ══ 3. Upsells ══════════════════════════════════════════════════ #}
                <div class="bg-white rounded-2xl border border-gray-200 shadow-sm overflow-hidden">
                    <div class="flex items-center gap-3 px-4 sm:px-6 py-4 border-b border-gray-100">
                        <div class="flex items-center justify-center w-8 h-8 bg-gray-100 rounded-xl text-gray-500 flex-shrink-0">
                            <svg class="w-[17px] h-[17px]" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" d="M5 3v4M3 5h4M6 17v4m-2-2h4m5-16l2.286 6.857L21 12l-5.714 2.143L13 21l-2.286-6.857L5 12l5.714-2.143L13 3z"/>
                            </svg>
                        </div>
                        <div>
                            <h2 class="text-sm font-semibold text-gray-900">Upsells</h2>
                            <p class="text-xs text-gray-500">Add-ons active on this plan</p>
                        </div>
                    </div>
                    {% if plan.upsells is not empty %}
                        <div class="divide-y divide-gray-100">
                            {% for upsell in plan.upsells %}
                                <div class="px-4 sm:px-6 py-4">

                                    {# Header row: name + status badge #}
                                    <div class="flex items-start justify-between gap-3 mb-3">
                                        <div>
                                            <p class="text-sm font-semibold text-gray-900">{{ upsell.name }}</p>
                                            <p class="text-sm text-gray-700 mt-0.5">£{{ upsell.price|number_format(2) }} / month</p>
                                        </div>
                                        <span class="inline-flex items-center gap-1 px-2 py-0.5 rounded-full text-xs font-medium bg-green-50 text-green-700 border border-green-200 flex-shrink-0 mt-0.5">
                                            <span class="w-1.5 h-1.5 rounded-full bg-green-500"></span>{{ upsell.status }}
                                        </span>
                                    </div>

                                    {# Next order date #}
                                    <div class="flex items-center gap-2 mb-3">
                                        <svg class="w-3.5 h-3.5 text-gray-400 flex-shrink-0" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                                            <path stroke-linecap="round" stroke-linejoin="round" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"/>
                                        </svg>
                                        <p class="text-xs text-gray-500">
                                            Next order:
                                            <span class="font-medium text-gray-700">
                                                {% if upsell.nextOrderDate %}{{ upsell.nextOrderDate|date('d M Y') }}{% else %}Not scheduled{% endif %}
                                            </span>
                                        </p>
                                    </div>

                                    {# Actions #}
                                    <div class="flex items-center gap-2">
                                        <details class="group relative flex-1">
                                            <summary class="flex items-center justify-center gap-1.5 px-3 py-1.5 text-xs font-medium text-gray-700 bg-gray-50 border border-gray-200 rounded-lg hover:bg-gray-100 cursor-pointer transition-colors [&::-webkit-details-marker]:hidden list-none">
                                                <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                                                    <path stroke-linecap="round" stroke-linejoin="round" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"/>
                                                </svg>
                                                Move order date
                                            </summary>
                                            <div class="mt-2 p-3 bg-gray-50 rounded-xl border border-gray-200 space-y-2">
                                                <p class="text-xs text-gray-600">Choose a new date for the next order on this add-on.</p>
                                                <p class="text-xs text-gray-400"><span class="font-medium text-gray-500">You'll need:</span> The new date the patient wants</p>
                                                <div class="flex items-center gap-2 pt-0.5">
                                                    <button type="button" class="px-3 py-1.5 bg-gray-900 text-white rounded-lg text-xs font-medium hover:bg-gray-700 transition-colors">Continue →</button>
                                                    <span class="text-xs text-gray-400 italic">Not wired in prototype</span>
                                                </div>
                                            </div>
                                        </details>

                                        <details class="group relative flex-1">
                                            <summary class="flex items-center justify-center gap-1.5 px-3 py-1.5 text-xs font-medium text-red-600 bg-red-50 border border-red-200 rounded-lg hover:bg-red-100 cursor-pointer transition-colors [&::-webkit-details-marker]:hidden list-none">
                                                <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                                                    <path stroke-linecap="round" stroke-linejoin="round" d="M10 14l2-2m0 0l2-2m-2 2l-2-2m2 2l2 2m7-2a9 9 0 11-18 0 9 9 0 0118 0z"/>
                                                </svg>
                                                Cancel add-on
                                            </summary>
                                            <div class="mt-2 p-3 bg-red-50 rounded-xl border border-red-200 space-y-2">
                                                <p class="text-xs text-gray-600">This will stop future orders and payments for this add-on. Only do this if the patient has asked to cancel it.</p>
                                                <p class="text-xs text-gray-400"><span class="font-medium text-gray-500">You'll need:</span> Confirmation the patient has requested cancellation</p>
                                                <div class="flex items-center gap-2 pt-0.5">
                                                    <button type="button" class="px-3 py-1.5 bg-red-600 text-white rounded-lg text-xs font-medium hover:bg-red-700 transition-colors">Continue →</button>
                                                    <span class="text-xs text-gray-400 italic">Not wired in prototype</span>
                                                </div>
                                            </div>
                                        </details>
                                    </div>

                                </div>
                            {% endfor %}
                        </div>
                    {% else %}
                        <div class="px-4 sm:px-6 py-8 text-center">
                            <p class="text-sm text-gray-400">No active upsells on this plan</p>
                            <p class="text-xs text-gray-300 mt-1">Add-ons will appear here when active</p>
                        </div>
                    {% endif %}
                </div>

                {# ══ 4. Change log ═══════════════════════════════════════════════ #}
                {% set changeLogItems = plan.activity|filter(a => a.agent != 'System') %}
                <div class="bg-white rounded-2xl border border-gray-200 shadow-sm overflow-hidden">
                    <div class="flex items-center gap-3 px-4 sm:px-6 py-4 border-b border-gray-100">
                        <div class="flex items-center justify-center w-8 h-8 bg-gray-100 rounded-xl text-gray-500 flex-shrink-0">
                            <svg class="w-[17px] h-[17px]" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2m-6 9l2 2 4-4"/>
                            </svg>
                        </div>
                        <div>
                            <h2 class="text-sm font-semibold text-gray-900">Change log</h2>
                            <p class="text-xs text-gray-500">Admin changes made to this plan</p>
                        </div>
                    </div>
                    <div class="px-4 sm:px-6 py-4">
                        {% if changeLogItems is empty %}
                            <p class="text-sm text-gray-400 py-4 text-center">No changes recorded yet</p>
                        {% else %}
                            <ol class="relative border-l border-gray-200 space-y-5 ml-2">
                                {% for item in changeLogItems %}
                                    <li class="ml-5">
                                        <span class="absolute -left-[7px] flex h-3.5 w-3.5 items-center justify-center rounded-full
                                            {% if item.type == 'plan_cancelled' %}bg-red-100 border border-red-300
                                            {% elseif item.type == 'plan_paused' %}bg-amber-100 border border-amber-300
                                            {% elseif item.type == 'discount_applied' %}bg-green-100 border border-green-300
                                            {% else %}bg-blue-100 border border-blue-300
                                            {% endif %}">
                                        </span>
                                        <p class="text-sm text-gray-800 leading-snug">{{ item.description }}</p>
                                        <p class="text-xs text-gray-400 mt-0.5">{{ item.date|date('d M Y') }} · {{ item.agent }}</p>
                                    </li>
                                {% endfor %}
                            </ol>
                        {% endif %}
                    </div>
                </div>

            </div>

            {# ── Right column ──────────────────────────────────────────────────── #}
            <div class="col-span-12 lg:col-span-4">
                <div class="lg:sticky lg:top-[73px] space-y-5">

                    {# ══ Billing ══════════════════════════════════════════════════ #}
                    <div class="bg-white rounded-2xl border border-gray-200 shadow-sm overflow-hidden">
                        <div class="flex items-center gap-3 px-4 sm:px-6 py-4 border-b border-gray-100">
                            <div class="flex items-center justify-center w-8 h-8 bg-gray-100 rounded-xl text-gray-500 flex-shrink-0">
                                <svg class="w-[17px] h-[17px]" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                                    <path stroke-linecap="round" stroke-linejoin="round" d="M3 10h18M7 15h1m4 0h1m-7 4h12a3 3 0 003-3V8a3 3 0 00-3-3H6a3 3 0 00-3 3v8a3 3 0 003 3z"/>
                                </svg>
                            </div>
                            <h2 class="text-sm font-semibold text-gray-900">Billing</h2>
                        </div>

                        <div class="divide-y divide-gray-100">

                            {# Billing type + next amount #}
                            <div class="px-4 sm:px-6 py-4">
                                <div class="flex items-center gap-2 mb-3">
                                    {% if plan.billingMatchesOrder %}
                                        <span class="inline-flex items-center px-2.5 py-1 rounded-full text-xs font-medium bg-blue-50 text-blue-700 border border-blue-200">Per order billing</span>
                                    {% else %}
                                        <span class="inline-flex items-center px-2.5 py-1 rounded-full text-xs font-medium bg-violet-50 text-violet-700 border border-violet-200">Commitment based billing</span>
                                    {% endif %}
                                    {% if plan.discount %}
                                        <span class="inline-flex items-center px-2 py-0.5 rounded-full text-xs font-medium bg-green-50 text-green-700 border border-green-200">{{ plan.discount }}</span>
                                    {% endif %}
                                </div>
                                {% if plan.status in ['deactivated', 'expired'] %}
                                    <p class="text-sm text-gray-400 italic">No upcoming payment — plan is {{ plan.status }}</p>
                                {% else %}
                                    <div class="flex items-baseline gap-2">
                                        <span class="text-2xl font-bold {{ plan.paymentFailed ? 'text-red-600' : 'text-gray-900' }}">£{{ plan.nextPaymentAmount|number_format(2) }}</span>
                                        {% if plan.discount %}
                                            <span class="text-sm text-gray-400 line-through">£{{ plan.price|number_format(2) }}</span>
                                        {% endif %}
                                        {% if plan.paymentFailed %}
                                            <span class="inline-flex items-center px-2 py-0.5 rounded-full text-xs font-medium bg-red-50 text-red-700 border border-red-200">Failed</span>
                                        {% endif %}
                                    </div>
                                    {% if plan.discount %}
                                        <p class="text-xs text-gray-500 mt-0.5">saving £{{ (plan.price - plan.nextPaymentAmount)|number_format(2) }}</p>
                                    {% endif %}
                                {% endif %}
                            </div>

                            {# Billing frequency #}
                            <div class="px-4 sm:px-6 py-4 space-y-2.5">
                                <div class="flex items-center justify-between">
                                    <span class="text-xs text-gray-500">Billing cycle</span>
                                    <span class="text-sm font-medium text-gray-900">Every {{ plan.billingCycleDays }} days</span>
                                </div>
                                {% if not plan.billingMatchesOrder %}
                                    <div class="flex items-center justify-between">
                                        <span class="text-xs text-gray-500">Order cycle</span>
                                        <span class="text-sm font-medium text-gray-900">Every {{ plan.cycleDays }} days</span>
                                    </div>
                                {% endif %}
                                {% if plan.nextBillingDate and plan.status not in ['deactivated', 'expired'] %}
                                    <div class="flex items-center justify-between">
                                        <span class="text-xs text-gray-500">Next billing date</span>
                                        <span class="text-sm font-medium text-gray-900">{{ plan.nextBillingDate|date('d M Y') }}</span>
                                    </div>
                                {% endif %}
                            </div>

                            {# Last payment #}
                            <div class="px-4 sm:px-6 py-4">
                                <div class="flex items-center justify-between">
                                    <div class="flex items-center gap-2">
                                        <span class="text-xs text-gray-500">Last payment</span>
                                        {% if plan.paymentFailed %}
                                            <span class="inline-flex items-center px-2 py-0.5 rounded-full text-xs font-medium bg-red-50 text-red-700 border border-red-200">Failed</span>
                                        {% elseif plan.lastPaymentAmount > 0 %}
                                            <span class="inline-flex items-center px-2 py-0.5 rounded-full text-xs font-medium bg-green-50 text-green-700 border border-green-200">Paid</span>
                                        {% endif %}
                                    </div>
                                    <div class="text-right">
                                        <p class="text-sm font-medium text-gray-900">£{{ plan.lastPaymentAmount|number_format(2) }}</p>
                                        {% if plan.lastBillingDate %}
                                            <p class="text-xs text-gray-500">{{ plan.lastBillingDate|date('d M Y') }}</p>
                                        {% endif %}
                                    </div>
                                </div>
                            </div>

                        </div>
                    </div>

                    {# ══ Tags ════════════════════════════════════════════════════ #}
                    <div class="bg-white rounded-2xl border border-gray-200 shadow-sm overflow-hidden">
                        <div class="flex items-center justify-between gap-3 px-4 sm:px-6 py-4 border-b border-gray-100">
                            <div class="flex items-center gap-3">
                                <div class="flex items-center justify-center w-8 h-8 bg-gray-100 rounded-xl text-gray-500 flex-shrink-0">
                                    <svg class="w-[17px] h-[17px]" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                                        <path stroke-linecap="round" stroke-linejoin="round" d="M7 7h.01M17 17h.01M7 17L17 7M7.5 7.5h.01m9 9h.01"/>
                                    </svg>
                                </div>
                                <div>
                                    <h2 class="text-sm font-semibold text-gray-900">Tags</h2>
                                    <p class="text-xs text-gray-500">Attributes associated with this plan</p>
                                </div>
                            </div>
                        </div>

                        <div class="px-4 sm:px-6 py-4">
                            {% if plan.tags is not empty %}
                                <div class="flex flex-wrap gap-2">
                                    {% for tag in plan.tags %}
                                        <span class="inline-flex items-center gap-1.5 px-2.5 py-1 rounded-lg text-xs font-medium bg-gray-100 text-gray-700 border border-gray-200">
                                            <svg class="w-3 h-3 text-gray-400" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                                                <path stroke-linecap="round" stroke-linejoin="round" d="M7 20l4-16m2 16l4-16M6 9h14M4 15h14"/>
                                            </svg>
                                            {{ tag }}
                                        </span>
                                    {% endfor %}
                                </div>
                            {% else %}
                                <p class="text-sm text-gray-400">No tags on this plan</p>
                            {% endif %}
                        </div>
                    </div>

                    {# ══ Actions ══════════════════════════════════════════════════ #}
                    <div class="bg-white rounded-2xl border border-gray-200 shadow-sm overflow-hidden">
                        <div class="flex items-center gap-3 px-4 sm:px-6 py-4 border-b border-gray-100">
                            <div class="flex items-center justify-center w-8 h-8 bg-gray-100 rounded-xl text-gray-500 flex-shrink-0">
                                <svg class="w-[17px] h-[17px]" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                                    <path stroke-linecap="round" stroke-linejoin="round" d="M13 10V3L4 14h7v7l9-11h-7z"/>
                                </svg>
                            </div>
                            <h2 class="text-sm font-semibold text-gray-900">Actions</h2>
                        </div>
                        <div class="divide-y divide-gray-100">
                            {% for action in [
                                'Change order date',
                                'Change billing date',
                                'Change plan',
                                'Change offer & billing',
                                'Add upsell',
                                'Send one-off order'
                            ] %}
                                <button type="button" class="flex items-center justify-between w-full px-4 sm:px-6 py-3 text-sm font-medium text-gray-800 hover:bg-gray-50 transition-colors text-left">
                                    {{ action }}
                                    <svg class="w-4 h-4 text-gray-400 flex-shrink-0" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                                        <path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7"/>
                                    </svg>
                                </button>
                            {% endfor %}
                        </div>
                        <div class="px-4 sm:px-6 py-3 border-t border-gray-100">
                            <button type="button" class="flex items-center justify-between w-full text-sm font-medium text-red-600 hover:text-red-700 transition-colors">
                                Deactivate plan
                                <svg class="w-4 h-4 flex-shrink-0" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                                    <path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7"/>
                                </svg>
                            </button>
                        </div>
                    </div>

                </div>
            </div>

        </div>
    </div>

{% endblock %}
