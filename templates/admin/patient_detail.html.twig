{% extends 'base.html.twig' %}

{% block title %}{{ patient.name }} — Patient{% endblock %}

{% block body %}

    {# ── Header ─────────────────────────────────────────────────────────────── #}
    <div class="border-b border-gray-200 bg-white sticky top-0 z-50 shadow-sm">
        <div class="mx-auto max-w-7xl px-4 sm:px-6 py-3 sm:py-4">
            <div class="flex items-center gap-3 min-w-0">
                <a href="{{ path('admin_patient_list') }}" class="flex items-center justify-center w-8 h-8 bg-gray-100 rounded-xl text-gray-500 hover:bg-gray-200 transition-colors flex-shrink-0">
                    <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M15 19l-7-7 7-7"/>
                    </svg>
                </a>
                <div class="min-w-0">
                    <div class="flex items-center gap-2 flex-wrap">
                        <h1 class="text-sm sm:text-lg font-semibold text-gray-900 leading-none">{{ patient.name }}</h1>
                        <span class="inline-flex items-center px-2 py-0.5 rounded-full text-xs font-medium bg-gray-100 text-gray-600 border border-gray-200 font-mono flex-shrink-0">{{ patient.customerId }}</span>
                    </div>
                    <p class="hidden sm:block text-xs text-gray-400 mt-1">{{ patient.plans|length }} {{ patient.plans|length == 1 ? 'plan' : 'plans' }} on record</p>
                </div>
            </div>
        </div>
    </div>

    {# ── Body ────────────────────────────────────────────────────────────────── #}
    <div class="mx-auto max-w-5xl px-4 sm:px-6 py-5 sm:py-8 space-y-6">

        {# ══ Patient info ═══════════════════════════════════════════════════════ #}
        <div class="bg-white rounded-2xl border border-gray-200 shadow-sm overflow-hidden">
            <div class="flex items-center justify-between gap-3 px-4 sm:px-6 py-3 sm:py-4 border-b border-gray-100">
                <div class="flex items-center gap-3">
                    <div class="flex items-center justify-center w-8 h-8 bg-gray-100 rounded-xl text-gray-500 flex-shrink-0">
                        <svg class="w-[17px] h-[17px]" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"/>
                        </svg>
                    </div>
                    <h2 class="text-sm font-semibold text-gray-900">Patient details</h2>
                </div>
                <a href="#" class="inline-flex items-center gap-1.5 px-3 py-1.5 text-xs font-medium text-blue-600 bg-blue-50 border border-blue-200 rounded-lg hover:bg-blue-100 transition-colors">
                    View in clinician platform
                    <svg class="w-3 h-3" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14"/>
                    </svg>
                </a>
            </div>
            <div class="p-4 sm:p-6 grid grid-cols-2 sm:grid-cols-3 gap-x-6 gap-y-4">
                <div>
                    <p class="text-xs text-gray-500 mb-1">Full name</p>
                    <p class="text-sm font-medium text-gray-900">{{ patient.name }}</p>
                </div>
                <div>
                    <p class="text-xs text-gray-500 mb-1">Email</p>
                    <p class="text-sm text-gray-900">{{ patient.email }}</p>
                </div>
                <div>
                    <p class="text-xs text-gray-500 mb-1">Phone</p>
                    <p class="text-sm text-gray-900">{{ patient.phone }}</p>
                </div>
                <div>
                    <p class="text-xs text-gray-500 mb-1">Date of birth</p>
                    <p class="text-sm text-gray-900">{{ patient.dob|date('d M Y') }}</p>
                </div>
                <div>
                    <p class="text-xs text-gray-500 mb-1">Gender</p>
                    <p class="text-sm text-gray-900">{{ patient.gender }}</p>
                </div>
                <div>
                    <p class="text-xs text-gray-500 mb-1">Customer ID</p>
                    <p class="text-sm font-mono text-gray-900">{{ patient.customerId }}</p>
                </div>
            </div>
        </div>

        {# ══ Plan history ═══════════════════════════════════════════════════════ #}
        <div class="bg-white rounded-2xl border border-gray-200 shadow-sm overflow-hidden">
            <div class="flex items-center gap-3 px-4 sm:px-6 py-3 sm:py-4 border-b border-gray-100">
                <div class="flex items-center justify-center w-8 h-8 bg-gray-100 rounded-xl text-gray-500 flex-shrink-0">
                    <svg class="w-[17px] h-[17px]" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2"/>
                    </svg>
                </div>
                <div>
                    <h2 class="text-sm font-semibold text-gray-900">Plans</h2>
                    <p class="text-xs text-gray-500">{{ patient.plans|length }} {{ patient.plans|length == 1 ? 'plan' : 'plans' }} on record</p>
                </div>
            </div>

            <div class="overflow-x-auto">
                <table class="min-w-full divide-y divide-gray-100">
                    <thead>
                        <tr class="bg-gray-50">
                            <th class="px-4 sm:px-6 py-3 text-left text-xs font-semibold text-gray-500 uppercase tracking-wide">Plan</th>
                            <th class="px-4 py-3 text-left text-xs font-semibold text-gray-500 uppercase tracking-wide hidden sm:table-cell">Plan ID</th>
                            <th class="px-4 py-3 text-left text-xs font-semibold text-gray-500 uppercase tracking-wide">Status</th>
                            <th class="px-4 py-3 text-left text-xs font-semibold text-gray-500 uppercase tracking-wide hidden md:table-cell">Started</th>
                            <th class="px-4 py-3 text-left text-xs font-semibold text-gray-500 uppercase tracking-wide hidden md:table-cell">Renewal</th>
                            <th class="px-4 py-3 text-left text-xs font-semibold text-gray-500 uppercase tracking-wide hidden sm:table-cell">Orders</th>
                            <th class="px-4 sm:px-6 py-3 text-right text-xs font-semibold text-gray-500 uppercase tracking-wide"></th>
                        </tr>
                    </thead>
                    <tbody class="divide-y divide-gray-100">
                        {% for plan in patient.plans %}
                            <tr class="hover:bg-gray-50 transition-colors {% if loop.first and plan.status not in ['expired','deactivated'] %}bg-blue-50/30{% endif %}">

                                {# Plan name + category #}
                                <td class="px-4 sm:px-6 py-4">
                                    <div class="flex items-center gap-2 flex-wrap">
                                        <p class="text-sm font-medium text-gray-900 truncate max-w-[180px]" title="{{ plan.planName }}">{{ plan.planName }}</p>
                                        {% if loop.first and plan.status not in ['expired','deactivated'] %}
                                            <span class="inline-flex items-center px-1.5 py-0.5 rounded text-xs font-medium bg-blue-100 text-blue-700 flex-shrink-0">current</span>
                                        {% endif %}
                                    </div>
                                    <span class="inline-flex items-center px-1.5 py-0.5 rounded text-xs font-medium bg-gray-100 text-gray-600 mt-1">{{ plan.category }}</span>
                                </td>

                                {# Plan ID #}
                                <td class="px-4 py-4 hidden sm:table-cell">
                                    <p class="text-xs font-mono text-gray-500">{{ plan.planId }}</p>
                                </td>

                                {# Status #}
                                <td class="px-4 py-4">
                                    {% if plan.status == 'active' %}
                                        <span class="inline-flex items-center gap-1.5 px-2.5 py-1 rounded-full text-xs font-medium bg-green-50 text-green-700 border border-green-200">
                                            <span class="w-1.5 h-1.5 rounded-full bg-green-500 flex-shrink-0"></span>active
                                        </span>
                                    {% elseif plan.status == 'requested-renew' %}
                                        <span class="inline-flex items-center gap-1.5 px-2.5 py-1 rounded-full text-xs font-medium bg-amber-50 text-amber-700 border border-amber-200">
                                            <span class="w-1.5 h-1.5 rounded-full bg-amber-500 flex-shrink-0"></span>requested-renew
                                        </span>
                                    {% elseif plan.status == 'requested-change' %}
                                        <span class="inline-flex items-center gap-1.5 px-2.5 py-1 rounded-full text-xs font-medium bg-blue-50 text-blue-700 border border-blue-200">
                                            <span class="w-1.5 h-1.5 rounded-full bg-blue-500 flex-shrink-0"></span>requested-change
                                        </span>
                                    {% elseif plan.status == 'requested-approve' %}
                                        <span class="inline-flex items-center gap-1.5 px-2.5 py-1 rounded-full text-xs font-medium bg-purple-50 text-purple-700 border border-purple-200">
                                            <span class="w-1.5 h-1.5 rounded-full bg-purple-500 flex-shrink-0"></span>requested-approve
                                        </span>
                                    {% elseif plan.status == 'deactivated' %}
                                        <span class="inline-flex items-center gap-1.5 px-2.5 py-1 rounded-full text-xs font-medium bg-red-50 text-red-700 border border-red-200">
                                            <span class="w-1.5 h-1.5 rounded-full bg-red-500 flex-shrink-0"></span>deactivated
                                        </span>
                                    {% elseif plan.status == 'expired' %}
                                        <span class="inline-flex items-center gap-1.5 px-2.5 py-1 rounded-full text-xs font-medium bg-gray-100 text-gray-500 border border-gray-200">
                                            <span class="w-1.5 h-1.5 rounded-full bg-gray-400 flex-shrink-0"></span>expired
                                        </span>
                                    {% else %}
                                        <span class="inline-flex items-center gap-1.5 px-2.5 py-1 rounded-full text-xs font-medium bg-gray-100 text-gray-500 border border-gray-200">
                                            <span class="w-1.5 h-1.5 rounded-full bg-gray-400 flex-shrink-0"></span>{{ plan.status }}
                                        </span>
                                    {% endif %}
                                </td>

                                {# Started #}
                                <td class="px-4 py-4 hidden md:table-cell">
                                    <p class="text-sm text-gray-900">{{ plan.startDate|date('d M Y') }}</p>
                                </td>

                                {# Renewal / end #}
                                <td class="px-4 py-4 hidden md:table-cell">
                                    {% if plan.renewalDate %}
                                        <p class="text-sm text-gray-900">{{ plan.renewalDate|date('d M Y') }}</p>
                                    {% else %}
                                        <p class="text-sm text-gray-400">—</p>
                                    {% endif %}
                                </td>

                                {# Orders #}
                                <td class="px-4 py-4 hidden sm:table-cell">
                                    <p class="text-sm text-gray-900">{{ plan.ordersCompleted }}/{{ plan.ordersTotal }}</p>
                                    <p class="text-xs text-gray-400">shipped</p>
                                </td>

                                {# View plan link #}
                                <td class="px-4 sm:px-6 py-4 text-right">
                                    <a
                                        href="{{ path('admin_plan_detail', {id: plan.id}) }}"
                                        class="inline-flex items-center gap-1.5 px-3 py-1.5 text-xs font-medium text-gray-700 bg-white border border-gray-200 rounded-lg hover:bg-gray-50 hover:border-gray-300 transition-colors"
                                    >
                                        View plan
                                        <svg class="w-3 h-3" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                                            <path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7"/>
                                        </svg>
                                    </a>
                                </td>

                            </tr>
                        {% endfor %}
                    </tbody>
                </table>
            </div>
        </div>

    </div>

{% endblock %}
