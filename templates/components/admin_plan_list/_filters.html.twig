<div class="flex flex-col sm:flex-row sm:items-center gap-3 mb-5">

    {# Search #}
    <div class="relative flex-1">
        <svg class="pointer-events-none absolute left-3 top-1/2 -translate-y-1/2 w-4 h-4 text-gray-400" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" d="M21 21l-4.35-4.35M17 11A6 6 0 115 11a6 6 0 0112 0z"/>
        </svg>
        <input
            type="text"
            data-model="debounce(300)|search"
            value="{{ search }}"
            placeholder="Search by name or email…"
            class="w-full pl-9 pr-3 py-2 text-sm text-gray-900 bg-white border border-gray-200 rounded-xl focus:outline-none focus:ring-2 focus:ring-gray-900/10 focus:border-gray-500 transition-colors"
        >
    </div>

    {# Status filter #}
    <select
        data-model="statusFilter"
        class="px-3 py-2 text-sm text-gray-900 bg-white border border-gray-200 rounded-xl focus:outline-none focus:ring-2 focus:ring-gray-900/10 focus:border-gray-500 transition-colors cursor-pointer"
    >
        <option value="">All statuses</option>
        <option value="active"             {% if statusFilter == 'active'             %}selected{% endif %}>Active</option>
        <option value="requested-renew"    {% if statusFilter == 'requested-renew'    %}selected{% endif %}>Renewal requested</option>
        <option value="requested-change"   {% if statusFilter == 'requested-change'   %}selected{% endif %}>Change requested</option>
        <option value="requested-approve"  {% if statusFilter == 'requested-approve'  %}selected{% endif %}>Approval required</option>
        <option value="deactivated"        {% if statusFilter == 'deactivated'        %}selected{% endif %}>Deactivated</option>
        <option value="expired"            {% if statusFilter == 'expired'            %}selected{% endif %}>Expired</option>
    </select>

    {# Result count #}
    <span class="text-sm text-gray-500 whitespace-nowrap">
        {{ filteredPlans|length }} plan{{ filteredPlans|length != 1 ? 's' : '' }}
    </span>

</div>
