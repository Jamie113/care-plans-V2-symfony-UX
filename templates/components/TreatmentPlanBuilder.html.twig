{# Root element — {{ attributes }} injects the required Live Component attributes #}
<div {{ attributes }}>

    {% include 'components/plan_builder/_header.html.twig' %}

    {# ── Body ─────────────────────────────────────────────────────────────────── #}
    <div class="mx-auto max-w-7xl px-4 sm:px-6 py-5 sm:py-8">
        <div class="grid grid-cols-12 gap-5 sm:gap-8">

            {# ── Builder column ─────────────────────────────────────────────── #}
            <div class="col-span-12 lg:col-span-8 space-y-6 relative" data-loading="addClass(opacity-60 pointer-events-none)">
                {# Loading progress bar — appears at top of column during any live re-render #}
                <div data-loading="show" class="hidden absolute inset-x-0 -top-2 h-0.5 z-10 overflow-hidden rounded-full bg-blue-100">
                    <div class="h-full animate-pulse bg-blue-500 w-2/3 rounded-full"></div>
                </div>

                {% include 'components/plan_builder/_card_plan_details.html.twig' %}
                {% include 'components/plan_builder/_card_medications.html.twig' %}
                {% include 'components/plan_builder/_card_dispatch.html.twig' %}
                {% include 'components/plan_builder/_card_clinical.html.twig' %}
                {% include 'components/plan_builder/_card_inclusions.html.twig' %}
                {% include 'components/plan_builder/_card_offers.html.twig' %}
                {% include 'components/plan_builder/_card_upsells.html.twig' %}

            </div>

            {% include 'components/plan_builder/_summary_panel.html.twig' %}

        </div>
    </div>

    {% include 'components/plan_builder/_dev_panels.html.twig' %}

    {% include 'components/plan_builder/_modal_create_plan.html.twig' %}

</div>
