{# Root element — {{ attributes }} injects the required Live Component attributes #}
<div {{ attributes }}>

    {# ── Header ──────────────────────────────────────────────────────────────── #}
    <div class="border-b border-gray-200 bg-white sticky top-0 z-50 shadow-sm">
        <div class="mx-auto max-w-7xl px-6 py-4">
            <div class="flex items-center justify-between gap-6">

                <div class="flex items-center gap-4">
                    <div class="flex items-center justify-center w-9 h-9 bg-blue-700 rounded-xl flex-shrink-0">
                        <svg class="w-[18px] h-[18px] text-white" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2m-6 9l2 2 4-4"/>
                        </svg>
                    </div>
                    <div>
                        <h1 class="text-lg font-semibold text-gray-900 leading-none">New Treatment Plan</h1>
                        <p class="text-xs text-gray-500 mt-1">Configure your plan below, then create it.</p>
                    </div>
                </div>

                <div class="flex items-center gap-3">
                    <button type="button" class="inline-flex items-center gap-2 px-4 py-2 text-sm font-medium text-gray-700 bg-white border border-gray-200 rounded-xl hover:bg-gray-50 hover:border-gray-300 transition-colors">
                        <svg class="w-[15px] h-[15px]" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" d="M8 7H5a2 2 0 00-2 2v9a2 2 0 002 2h14a2 2 0 002-2V9a2 2 0 00-2-2h-3m-1 4l-3 3m0 0l-3-3m3 3V4"/>
                        </svg>
                        Save Draft
                    </button>

                    {% if validation.canCreate %}
                        <button type="button" class="inline-flex items-center gap-2 px-5 py-2 text-sm font-semibold rounded-xl bg-blue-700 text-white hover:bg-blue-800 shadow-sm transition-colors">
                            <svg class="w-[15px] h-[15px]" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"/>
                            </svg>
                            Create Plan
                        </button>
                    {% else %}
                        <button type="button" disabled class="inline-flex items-center gap-2 px-5 py-2 text-sm font-semibold rounded-xl bg-gray-100 text-gray-400 cursor-not-allowed">
                            <svg class="w-[15px] h-[15px]" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"/>
                            </svg>
                            Complete Form
                        </button>
                    {% endif %}
                </div>

            </div>
        </div>
    </div>

    {# ── Body ─────────────────────────────────────────────────────────────────── #}
    <div class="mx-auto max-w-7xl px-6 py-8">
        <div class="grid grid-cols-12 gap-8">

            {# ── Builder column ─────────────────────────────────────────────── #}
            <div class="col-span-12 lg:col-span-8 space-y-6">

                {# ════════════════════════════════════════════════════════════ #}
                {# Plan Basics card                                             #}
                {# ════════════════════════════════════════════════════════════ #}
                <div class="bg-white rounded-2xl border border-gray-200 shadow-sm overflow-hidden">
                    <div class="flex items-center gap-3 px-6 py-4 border-b border-gray-100">
                        <div class="flex items-center justify-center w-8 h-8 bg-gray-100 rounded-xl text-gray-500">
                            <svg class="w-[18px] h-[18px]" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" d="M10.325 4.317c.426-1.756 2.924-1.756 3.35 0a1.724 1.724 0 002.573 1.066c1.543-.94 3.31.826 2.37 2.37a1.724 1.724 0 001.065 2.572c1.756.426 1.756 2.924 0 3.35a1.724 1.724 0 00-1.066 2.573c.94 1.543-.826 3.31-2.37 2.37a1.724 1.724 0 00-2.572 1.065c-.426 1.756-2.924 1.756-3.35 0a1.724 1.724 0 00-2.573-1.066c-1.543.94-3.31-.826-2.37-2.37a1.724 1.724 0 00-1.065-2.572c-1.756-.426-1.756-2.924 0-3.35a1.724 1.724 0 001.066-2.573c-.94-1.543.826-3.31 2.37-2.37.996.608 2.296.07 2.572-1.065z"/>
                                <path stroke-linecap="round" stroke-linejoin="round" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"/>
                            </svg>
                        </div>
                        <div>
                            <h2 class="text-sm font-semibold text-gray-900">Plan details</h2>
                            <p class="text-xs text-gray-500">Name your plan and set a duration</p>
                        </div>
                    </div>

                    <div class="p-6 space-y-4">

                        {# Plan name #}
                        <div>
                            <label class="block text-sm font-medium text-gray-700 mb-1.5">Plan name</label>
                            <input
                                type="text"
                                data-model="on(input)|planName"
                                placeholder="e.g. WL Starter Plan"
                                value="{{ planName }}"
                                class="w-full px-3 py-2 text-sm text-gray-900 bg-white border rounded-xl focus:outline-none focus:ring-2 focus:ring-gray-900/10 focus:border-gray-500 transition-colors {{ validation.errors.planName is defined ? 'border-red-400 bg-red-50' : 'border-gray-200' }}"
                            >
                            {% if validation.errors.planName is defined %}
                                <p class="text-xs text-red-500 mt-1.5 flex items-center gap-1.5">
                                    <svg class="w-[13px] h-[13px] flex-shrink-0" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                                        <path stroke-linecap="round" stroke-linejoin="round" d="M12 8v4m0 4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/>
                                    </svg>
                                    {{ validation.errors.planName }}
                                </p>
                            {% endif %}
                        </div>

                        {# Duration #}
                        <div>
                            <label class="block text-sm font-medium text-gray-700 mb-1.5">Duration</label>
                            {% if durationId != 'custom' %}
                                <select
                                    data-model="durationId"
                                    class="w-full px-3 py-2 text-sm text-gray-900 bg-white border border-gray-200 rounded-xl focus:outline-none focus:ring-2 focus:ring-gray-900/10 focus:border-gray-500 transition-colors cursor-pointer"
                                >
                                    <option value="">Choose duration</option>
                                    {% for opt in durationOptions %}
                                        <option value="{{ opt.id }}" {% if opt.id == durationId %}selected{% endif %}>{{ opt.label }}</option>
                                    {% endfor %}
                                </select>
                            {% else %}
                                <div class="flex items-center gap-2">
                                    <input
                                        type="number"
                                        min="1"
                                        data-model="on(input)|customDurationMonths"
                                        value="{{ customDurationMonths }}"
                                        class="w-24 px-3 py-2 text-sm text-gray-900 bg-white border border-gray-200 rounded-xl focus:outline-none focus:ring-2 focus:ring-gray-900/10 focus:border-gray-500 transition-colors"
                                    >
                                    <span class="text-sm text-gray-500">months</span>
                                </div>
                            {% endif %}
                        </div>

                        {# Auto-renew #}
                        <div class="flex items-center justify-between pt-1 border-t border-gray-100">
                            <div>
                                <p class="text-sm font-medium text-gray-700">Auto-renew</p>
                                <p class="text-xs text-gray-400 mt-0.5">Automatically restart the plan at the end of its duration</p>
                            </div>
                            <label class="flex items-center gap-2.5 cursor-pointer select-none flex-shrink-0 ml-6">
                                <input
                                    type="checkbox"
                                    data-model="autoRenew"
                                    {% if autoRenew %}checked{% endif %}
                                    class="sr-only peer"
                                >
                                <div class="relative w-10 h-5 bg-gray-200 rounded-full peer peer-checked:bg-blue-600 transition-colors after:content-[''] after:absolute after:top-0.5 after:left-0.5 after:bg-white after:rounded-full after:h-4 after:w-4 after:transition-all peer-checked:after:translate-x-5"></div>
                            </label>
                        </div>

                    </div>
                </div>

                {# ════════════════════════════════════════════════════════════ #}
                {# Medications card                                             #}
                {# ════════════════════════════════════════════════════════════ #}
                <div class="bg-white rounded-2xl border border-gray-200 shadow-sm overflow-hidden">
                    <div class="flex items-center gap-3 px-6 py-4 border-b border-gray-100">
                        <div class="flex items-center justify-center w-8 h-8 bg-gray-100 rounded-xl text-gray-500">
                            <svg class="w-[18px] h-[18px]" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" d="M19.428 15.428a2 2 0 00-1.022-.547l-2.387-.477a6 6 0 00-3.86.517l-.318.158a6 6 0 01-3.86.517L6.05 15.21a2 2 0 00-1.806.547M8 4h8l-1 1v5.172a2 2 0 00.586 1.414l5 5c1.26 1.26.367 3.414-1.415 3.414H4.828c-1.782 0-2.674-2.154-1.414-3.414l5-5A2 2 0 009 10.172V5L8 4z"/>
                            </svg>
                        </div>
                        <div>
                            <h2 class="text-sm font-semibold text-gray-900">Medications</h2>
                            <p class="text-xs text-gray-500">Add the medications included in this plan</p>
                        </div>
                    </div>

                    <div class="p-6 space-y-3">

                        {# Medication rows #}
                        {% for i, med in medications %}
                            {% set titrationError = validation.titrationErrors[i] ?? null %}
                            {% set productData = med.medicationId ? (medicationCatalogue|filter(m => m.id == med.medicationId)|first|default(null)) : null %}
                            {% set productVariants = productData ? (productData.variants ?? []) : [] %}
                            {% set selectedVariant = med.variantId ? (productVariants|filter(v => v.id == med.variantId)|first|default(null)) : null %}

                            <div class="rounded-xl border border-gray-200 bg-white shadow-sm overflow-hidden">

                                {# Header: medication count + remove #}
                                <div class="flex items-center justify-between px-4 py-3 bg-gray-50/60 border-b border-gray-100">
                                    <span class="text-xs font-semibold text-gray-400 uppercase tracking-wide">Medication {{ i + 1 }}</span>
                                    {% if medications|length > 1 %}
                                        <button
                                            type="button"
                                            data-action="live#action"
                                            data-live-action-param="removeMedication"
                                            data-live-key-param="{{ med.key }}"
                                            class="p-1.5 rounded-lg text-gray-300 hover:text-red-400 hover:bg-red-50 transition-colors"
                                        >
                                            <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                                                <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12"/>
                                            </svg>
                                        </button>
                                    {% endif %}
                                </div>

                                <div class="px-4 py-4 space-y-4">

                                    {# Product select #}
                                    <div class="pb-4 border-b border-gray-100">
                                        <label class="text-xs font-semibold text-gray-500 uppercase tracking-wide mb-2 block">Medication</label>
                                        <select
                                            data-action="change->live#action"
                                            data-live-action-param="setMedicationProduct"
                                            data-live-key-param="{{ med.key }}"
                                            data-live-medication-id-param="{{ med.medicationId }}"
                                            onchange="this.dataset.liveMedicationIdParam = this.value"
                                            class="w-full px-3 py-2 text-sm text-gray-900 bg-white border border-gray-200 rounded-xl focus:outline-none focus:ring-2 focus:ring-gray-900/10 focus:border-gray-500 transition-colors cursor-pointer"
                                        >
                                            <option value="">Select medication…</option>
                                            {% for m in medicationCatalogue %}
                                                <option value="{{ m.id }}" {% if m.id == med.medicationId %}selected{% endif %}>{{ m.name }}</option>
                                            {% endfor %}
                                        </select>
                                    </div>

                                    {% if med.medicationId %}

                                        {# Variant select #}
                                        <div class="pb-4 border-b border-gray-100">
                                            <label class="text-xs font-semibold text-gray-500 uppercase tracking-wide mb-2 block">Variant</label>
                                            <select
                                                data-model="medications.{{ i }}.variantId"
                                                class="w-full px-3 py-2 text-sm text-gray-900 bg-white border border-gray-200 rounded-xl focus:outline-none focus:ring-2 focus:ring-gray-900/10 focus:border-gray-500 transition-colors cursor-pointer"
                                            >
                                                <option value="">Select variant…</option>
                                                {% for v in productVariants %}
                                                    <option value="{{ v.id }}" {% if v.id == med.variantId %}selected{% endif %}>{{ v.name }} — £{{ v.price|number_format(2) }}</option>
                                                {% endfor %}
                                            </select>
                                            {% if selectedVariant %}
                                                <p class="text-xs text-gray-400 mt-2">Catalogue price <span class="font-semibold text-emerald-600">£{{ selectedVariant.price|number_format(2) }}</span> per order</p>
                                            {% endif %}
                                        </div>

                                        {# Quantity + Titration #}
                                        <div class="flex items-start justify-between gap-6">
                                            <div>
                                                <label class="text-xs font-semibold text-gray-500 uppercase tracking-wide mb-2 block">Qty per order</label>
                                                <input
                                                    type="number"
                                                    min="1"
                                                    data-model="on(input)|medications.{{ i }}.quantityPerOrder"
                                                    value="{{ med.quantityPerOrder }}"
                                                    class="w-24 px-3 py-2 text-sm text-gray-900 bg-white border border-gray-200 rounded-xl focus:outline-none focus:ring-2 focus:ring-gray-900/10 transition-colors"
                                                >
                                            </div>
                                            <div>
                                                <label class="text-xs font-semibold text-gray-500 uppercase tracking-wide mb-2 block">Titration</label>
                                                <label class="flex items-center gap-2.5 cursor-pointer select-none">
                                                    <span class="text-sm text-gray-600">Titrate dose over time</span>
                                                    <input
                                                        type="checkbox"
                                                        data-model="medications.{{ i }}.titrationEnabled"
                                                        {% if med.titrationEnabled %}checked{% endif %}
                                                        class="sr-only peer"
                                                    >
                                                    <div class="relative w-10 h-5 flex-shrink-0 bg-gray-200 rounded-full peer peer-checked:bg-blue-600 transition-colors after:content-[''] after:absolute after:top-0.5 after:left-0.5 after:bg-white after:rounded-full after:h-4 after:w-4 after:transition-all peer-checked:after:translate-x-5"></div>
                                                </label>
                                            </div>
                                        </div>

                                        {# Titration path (shown when toggle on) #}
                                        {% if med.titrationEnabled %}
                                            {% set availableTitrations = titrationCatalogue|filter(t => t.medicationId == med.medicationId) %}
                                            <div class="space-y-2 pt-1">
                                                <select
                                                    data-model="medications.{{ i }}.titrationPathId"
                                                    class="w-full px-3 py-2 text-sm text-gray-900 bg-white border {{ titrationError ? 'border-red-400 bg-red-50' : 'border-gray-200' }} rounded-xl focus:outline-none focus:ring-2 focus:ring-gray-900/10 transition-colors cursor-pointer"
                                                >
                                                    <option value="">Select titration path…</option>
                                                    {% for t in availableTitrations %}
                                                        <option value="{{ t.id }}" {% if t.id == med.titrationPathId %}selected{% endif %}>{{ t.name }}</option>
                                                    {% endfor %}
                                                </select>
                                                {% if titrationError %}
                                                    <p class="text-xs text-red-500 flex items-center gap-1.5">
                                                        <svg class="w-3.5 h-3.5 flex-shrink-0" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M12 8v4m0 4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
                                                        {{ titrationError }}
                                                    </p>
                                                {% endif %}
                                            </div>
                                        {% endif %}

                                    {% endif %}{# end if medicationId #}

                                </div>{# end px-4 py-4 #}

                            </div>
                        {% endfor %}

                        {# Validation banner #}
                        {% if validation.errors.medications is defined %}
                            <div class="flex items-start gap-3 rounded-xl bg-amber-50 border border-amber-200 p-4">
                                <svg class="w-4 h-4 text-amber-600 flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                                    <path stroke-linecap="round" stroke-linejoin="round" d="M12 8v4m0 4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/>
                                </svg>
                                <p class="text-sm text-amber-800 font-medium">{{ validation.errors.medications }}</p>
                            </div>
                        {% endif %}

                        {# Add medication button #}
                        <button
                            type="button"
                            data-action="live#action"
                            data-live-action-param="addMedication"
                            class="flex items-center gap-2 w-full px-4 py-2.5 text-sm font-medium text-blue-700 border border-dashed border-blue-300 rounded-xl hover:bg-blue-50 hover:border-blue-400 transition-colors"
                        >
                            <svg class="w-[15px] h-[15px]" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" d="M12 4v16m8-8H4"/>
                            </svg>
                            Add medication
                        </button>

                    </div>
                </div>

                {# ════════════════════════════════════════════════════════════ #}
                {# Dispatch schedule card                                       #}
                {# ════════════════════════════════════════════════════════════ #}
                <div class="bg-white rounded-2xl border border-gray-200 shadow-sm overflow-hidden">
                    <div class="flex items-center gap-3 px-6 py-4 border-b border-gray-100">
                        <div class="flex items-center justify-center w-8 h-8 bg-gray-100 rounded-xl text-gray-500">
                            <svg class="w-[18px] h-[18px]" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"/>
                            </svg>
                        </div>
                        <div>
                            <h2 class="text-sm font-semibold text-gray-900">Dispatch schedule</h2>
                            <p class="text-xs text-gray-500">Set how often orders are sent and how many will be generated.</p>
                        </div>
                    </div>

                    <div class="p-6 space-y-5">

                        {# Dispatch frequency #}
                        <div class="pb-5 border-b border-gray-100">
                            <label class="text-xs font-semibold text-gray-500 uppercase tracking-wide mb-3 block">Dispatch frequency</label>
                            {% if cycleId != 'custom' %}
                                <select
                                    data-model="cycleId"
                                    class="w-full px-3 py-2 text-sm text-gray-900 bg-white border border-gray-200 rounded-xl focus:outline-none focus:ring-2 focus:ring-gray-900/10 focus:border-gray-500 transition-colors cursor-pointer"
                                >
                                    <option value="">Choose frequency</option>
                                    {% for opt in cycleOptions %}
                                        <option value="{{ opt.id }}" {% if opt.id == cycleId %}selected{% endif %}>{{ opt.label }}</option>
                                    {% endfor %}
                                </select>
                            {% else %}
                                <div class="flex items-center gap-2">
                                    <input
                                        type="number"
                                        min="7"
                                        data-model="on(input)|customCycleDays"
                                        value="{{ customCycleDays }}"
                                        class="w-24 px-3 py-2 text-sm text-gray-900 bg-white border border-gray-200 rounded-xl focus:outline-none focus:ring-2 focus:ring-gray-900/10 transition-colors"
                                    >
                                    <span class="text-sm text-gray-500">days</span>
                                </div>
                            {% endif %}
                        </div>

                        {# Order count + rescheduling toggle #}
                        <div class="flex items-center justify-between gap-6 pb-5 border-b border-gray-100">
                            <div class="flex items-center gap-3">
                                <span class="text-sm text-gray-500">Total orders:</span>
                                <span class="text-2xl font-bold text-gray-900">{{ ordersCount }}</span>
                            </div>
                            <label class="flex items-center gap-2.5 cursor-pointer select-none">
                                <span class="text-sm font-medium text-gray-700">Allow patient rescheduling</span>
                                <input
                                    type="checkbox"
                                    data-model="allowPatientRescheduling"
                                    {% if allowPatientRescheduling %}checked{% endif %}
                                    class="sr-only peer"
                                >
                                <div class="relative w-10 h-5 bg-gray-200 rounded-full peer peer-checked:bg-blue-600 transition-colors after:content-[''] after:absolute after:top-0.5 after:left-0.5 after:bg-white after:rounded-full after:h-4 after:w-4 after:transition-all peer-checked:after:translate-x-5"></div>
                            </label>
                        </div>

                        {# Rescheduling window #}
                        {% if allowPatientRescheduling %}
                            <div class="pb-5 border-b border-gray-100">
                                <label class="text-xs font-semibold text-gray-500 uppercase tracking-wide mb-3 block">Rescheduling window</label>
                                <div class="flex items-center gap-3">
                                    <div class="flex items-center gap-2 flex-1 rounded-xl border border-gray-200 bg-gray-50 px-3.5 py-3">
                                        <svg class="w-3.5 h-3.5 text-amber-500 flex-shrink-0" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                                            <path stroke-linecap="round" stroke-linejoin="round" d="M10 19l-7-7m0 0l7-7m-7 7h18"/>
                                        </svg>
                                        <input
                                            type="number"
                                            min="0"
                                            data-model="on(input)|rescheduleDaysEarlier"
                                            value="{{ rescheduleDaysEarlier }}"
                                            class="w-14 text-center text-sm font-semibold text-gray-900 bg-transparent border-none outline-none focus:ring-0"
                                        >
                                        <span class="text-sm text-gray-500">days earlier</span>
                                    </div>
                                    <span class="text-gray-300 text-sm font-light">or</span>
                                    <div class="flex items-center gap-2 flex-1 rounded-xl border border-gray-200 bg-gray-50 px-3.5 py-3">
                                        <svg class="w-3.5 h-3.5 text-blue-500 flex-shrink-0" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                                            <path stroke-linecap="round" stroke-linejoin="round" d="M14 5l7 7m0 0l-7 7m7-7H3"/>
                                        </svg>
                                        <input
                                            type="number"
                                            min="0"
                                            data-model="on(input)|rescheduleDaysLater"
                                            value="{{ rescheduleDaysLater }}"
                                            class="w-14 text-center text-sm font-semibold text-gray-900 bg-transparent border-none outline-none focus:ring-0"
                                        >
                                        <span class="text-sm text-gray-500">days later</span>
                                    </div>
                                </div>
                                <p class="text-xs text-gray-400 mt-2.5">
                                    Patients can move an order up to
                                    <span class="font-medium text-gray-600">{{ rescheduleDaysEarlier }} day{{ rescheduleDaysEarlier != 1 ? 's' : '' }} earlier</span>
                                    or
                                    <span class="font-medium text-gray-600">{{ rescheduleDaysLater }} day{{ rescheduleDaysLater != 1 ? 's' : '' }} later</span>.
                                </p>
                            </div>
                        {% endif %}


                    </div>
                </div>

                {# ════════════════════════════════════════════════════════════ #}
                {# Clinical Protocols card                                      #}
                {# ════════════════════════════════════════════════════════════ #}
                {% set protocolMeds = medications|filter(m => m.medicationId != '') %}
                {% if protocolMeds|length > 0 %}
                    <div class="bg-white rounded-2xl border border-gray-200 shadow-sm overflow-hidden">
                        <div class="flex items-center gap-3 px-6 py-4 border-b border-gray-100">
                            <div class="flex items-center justify-center w-8 h-8 bg-gray-100 rounded-xl text-gray-500">
                                <svg class="w-[18px] h-[18px]" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                                    <path stroke-linecap="round" stroke-linejoin="round" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2"/>
                                </svg>
                            </div>
                            <div>
                                <h2 class="text-sm font-semibold text-gray-900">Clinical protocols</h2>
                                <p class="text-xs text-gray-500">Set prescription renewal frequency and dose-change approval rules per medication.</p>
                            </div>
                        </div>

                        <div class="p-6 space-y-4">
                            {% for i, med in medications %}
                                {% if med.medicationId %}
                                    {% set medData = medicationCatalogue|filter(m => m.id == med.medicationId)|first %}
                                    {% set variantData = med.variantId ? ((medData.variants ?? [])|filter(v => v.id == med.variantId)|first|default(null)) : null %}
                                    <div class="rounded-xl border border-gray-200 bg-gray-50/50 p-4">
                                        <div class="flex items-center gap-2 text-sm font-semibold text-gray-900 mb-4 pb-3 border-b border-gray-200">
                                            <svg class="w-[15px] h-[15px] text-gray-400" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                                                <path stroke-linecap="round" stroke-linejoin="round" d="M19.428 15.428a2 2 0 00-1.022-.547l-2.387-.477a6 6 0 00-3.86.517l-.318.158a6 6 0 01-3.86.517L6.05 15.21a2 2 0 00-1.806.547M8 4h8l-1 1v5.172a2 2 0 00.586 1.414l5 5c1.26 1.26.367 3.414-1.415 3.414H4.828c-1.782 0-2.674-2.154-1.414-3.414l5-5A2 2 0 009 10.172V5L8 4z"/>
                                            </svg>
                                            {{ variantData ? variantData.name : (medData.name ?? med.medicationId) }}
                                        </div>
                                        <div class="grid grid-cols-1 md:grid-cols-2 gap-4 items-end">
                                            <div>
                                                <label class="block text-xs font-medium text-gray-500 mb-1.5">New prescription required every</label>
                                                <select
                                                    data-model="medications.{{ i }}.prescription.renewalMonths"
                                                    class="w-full px-3 py-2 text-sm text-gray-900 bg-white border border-gray-200 rounded-xl focus:outline-none focus:ring-2 focus:ring-gray-900/10 focus:border-gray-500 transition-colors cursor-pointer"
                                                >
                                                    {% for opt in prescriptionRenewalOptions %}
                                                        <option value="{{ opt.id }}" {% if opt.id == med.prescription.renewalMonths %}selected{% endif %}>{{ opt.label }}</option>
                                                    {% endfor %}
                                                </select>
                                            </div>
                                            <label class="flex items-center gap-2.5 cursor-pointer select-none pb-1">
                                                <input
                                                    type="checkbox"
                                                    data-model="medications.{{ i }}.prescription.approvalRequiredOnDoseChange"
                                                    {% if med.prescription.approvalRequiredOnDoseChange %}checked{% endif %}
                                                    class="sr-only peer"
                                                >
                                                <div class="relative w-10 h-5 bg-gray-200 rounded-full peer peer-checked:bg-blue-600 transition-colors after:content-[''] after:absolute after:top-0.5 after:left-0.5 after:bg-white after:rounded-full after:h-4 after:w-4 after:transition-all peer-checked:after:translate-x-5"></div>
                                                <span class="text-sm font-medium text-gray-700">Approval required on dose change</span>
                                            </label>
                                        </div>
                                    </div>
                                {% endif %}
                            {% endfor %}
                        </div>
                    </div>
                {% endif %}

                {# ════════════════════════════════════════════════════════════ #}
                {# Inclusions card                                              #}
                {# ════════════════════════════════════════════════════════════ #}
                <div class="bg-white rounded-2xl border border-gray-200 shadow-sm overflow-hidden">
                    <div class="flex items-center gap-3 px-6 py-4 border-b border-gray-100">
                        <div class="flex items-center justify-center w-8 h-8 bg-gray-100 rounded-xl text-gray-500">
                            <svg class="w-[18px] h-[18px]" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"/>
                            </svg>
                        </div>
                        <div>
                            <h2 class="text-sm font-semibold text-gray-900">Inclusions</h2>
                            <p class="text-xs text-gray-500">Add items to specific orders or on their own recurring schedule.</p>
                        </div>
                    </div>
                    <div class="p-6 space-y-3">
                        {% if inclusions|length == 0 %}
                            <div class="flex flex-col items-center justify-center py-8 rounded-xl border-2 border-dashed border-gray-200 bg-gray-50/50">
                                <svg class="w-7 h-7 text-gray-300 mb-2" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"/></svg>
                                <p class="text-sm font-medium text-gray-500">No inclusions added</p>
                                <p class="text-xs text-gray-400 mt-0.5">Add blood tests, reviews, or other scheduled items</p>
                            </div>
                        {% endif %}

                        {% for i, item in inclusions %}
                            {% set incProduct = item.productId ? (inclusionProducts|filter(p => p.id == item.productId)|first|default(null)) : null %}
                            {% set incVariants = incProduct ? (incProduct.variants ?? []) : [] %}
                            {% set incVariant = item.variantId ? (incVariants|filter(v => v.id == item.variantId)|first|default(null)) : null %}

                            <div class="rounded-xl border border-gray-200 bg-white shadow-sm overflow-hidden">

                                {# Header: inclusion count + remove #}
                                <div class="flex items-center justify-between px-4 py-3 bg-gray-50/60 border-b border-gray-100">
                                    <span class="text-xs font-semibold text-gray-400 uppercase tracking-wide">Inclusion {{ i + 1 }}</span>
                                    <button
                                        type="button"
                                        data-action="live#action"
                                        data-live-action-param="removeInclusion"
                                        data-live-key-param="{{ item.key }}"
                                        class="p-1.5 rounded-lg text-gray-300 hover:text-red-400 hover:bg-red-50 transition-colors"
                                    >
                                        <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                                            <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12"/>
                                        </svg>
                                    </button>
                                </div>

                                <div class="px-4 py-4 space-y-4">

                                    {# Product select #}
                                    <div class="pb-4 border-b border-gray-100">
                                        <label class="text-xs font-semibold text-gray-500 uppercase tracking-wide mb-2 block">Product</label>
                                        <select
                                            data-action="change->live#action"
                                            data-live-action-param="setInclusionProduct"
                                            data-live-key-param="{{ item.key }}"
                                            data-live-product-id-param="{{ item.productId }}"
                                            onchange="this.dataset.liveProductIdParam = this.value"
                                            class="w-full px-3 py-2 text-sm text-gray-900 bg-white border border-gray-200 rounded-xl focus:outline-none focus:ring-2 focus:ring-gray-900/10 focus:border-gray-500 transition-colors cursor-pointer"
                                        >
                                            <option value="">Select product…</option>
                                            {% for p in inclusionProducts %}
                                                <option value="{{ p.id }}" {% if p.id == item.productId %}selected{% endif %}>{{ p.name }}</option>
                                            {% endfor %}
                                        </select>
                                    </div>

                                    {% if item.productId %}

                                        {# Variant select #}
                                        <div class="pb-4 border-b border-gray-100">
                                            <label class="text-xs font-semibold text-gray-500 uppercase tracking-wide mb-2 block">Variant</label>
                                            <select
                                                data-model="inclusions.{{ i }}.variantId"
                                                class="w-full px-3 py-2 text-sm text-gray-900 bg-white border border-gray-200 rounded-xl focus:outline-none focus:ring-2 focus:ring-gray-900/10 focus:border-gray-500 transition-colors cursor-pointer"
                                            >
                                                <option value="">Select variant…</option>
                                                {% for v in incVariants %}
                                                    <option value="{{ v.id }}" {% if v.id == item.variantId %}selected{% endif %}>{{ v.name }}{% if v.price > 0 %} — £{{ v.price|number_format(2) }}{% endif %}</option>
                                                {% endfor %}
                                            </select>
                                            {% if incVariant and incVariant.price > 0 %}
                                                <p class="text-xs text-gray-400 mt-2">Catalogue price <span class="font-semibold text-emerald-600">£{{ incVariant.price|number_format(2) }}</span> per order</p>
                                            {% endif %}
                                        </div>

                                        {# Schedule type toggle #}
                                        <div class="pb-4 border-b border-gray-100">
                                            <label class="text-xs font-semibold text-gray-500 uppercase tracking-wide mb-2 block">Schedule</label>
                                            <div class="flex items-center rounded-lg border border-gray-200 bg-white overflow-hidden">
                                                <button type="button" data-action="live#action" data-live-action-param="setInclusionScheduleType" data-live-key-param="{{ item.key }}" data-live-type-param="specific_orders" class="flex-1 px-3 py-2 text-xs font-medium transition-colors {{ item.scheduleType == 'specific_orders' ? 'bg-blue-700 text-white' : 'text-gray-500 hover:bg-gray-50' }}">Specific orders</button>
                                                <button type="button" data-action="live#action" data-live-action-param="setInclusionScheduleType" data-live-key-param="{{ item.key }}" data-live-type-param="recurring_cycle" class="flex-1 px-3 py-2 text-xs font-medium transition-colors {{ item.scheduleType == 'recurring_cycle' ? 'bg-blue-700 text-white' : 'text-gray-500 hover:bg-gray-50' }}">Recurring cycle</button>
                                            </div>
                                        </div>

                                        {# Schedule content #}
                                        <div>
                                            {% if item.scheduleType == 'specific_orders' %}
                                                <p class="text-xs font-medium text-gray-500 uppercase tracking-wide mb-2.5">Include in order</p>
                                                <div class="flex flex-wrap gap-1.5">
                                                    {% for n in 1..min(ordersCount, 24) %}
                                                        <button type="button" data-action="live#action" data-live-action-param="toggleInclusionOrder" data-live-key-param="{{ item.key }}" data-live-order-num-param="{{ n }}" class="w-8 h-8 rounded-lg text-xs font-semibold transition-colors {{ n in item.orderNumbers ? 'bg-blue-700 text-white shadow-sm' : 'bg-gray-100 text-gray-500 hover:bg-gray-200' }}">{{ n }}</button>
                                                    {% endfor %}
                                                </div>
                                                {% if item.orderNumbers|length > 0 %}<p class="text-xs text-gray-400 mt-2">Included in order{{ item.orderNumbers|length > 1 ? 's' : '' }} <span class="font-medium text-gray-600">{{ item.orderNumbers|join(', ') }}</span></p>{% endif %}

                                                {# Repeat on renewal #}
                                                <div class="flex items-center justify-between mt-4 pt-3 border-t border-gray-100">
                                                    <div>
                                                        <p class="text-xs font-semibold text-gray-600">Repeat on renewal</p>
                                                        <p class="text-xs text-gray-400 mt-0.5">Re-include in the same orders when the plan renews</p>
                                                    </div>
                                                    <label class="flex items-center gap-2 cursor-pointer select-none flex-shrink-0 ml-4">
                                                        <input
                                                            type="checkbox"
                                                            data-model="inclusions.{{ i }}.repeatOnRenewal"
                                                            {% if item.repeatOnRenewal %}checked{% endif %}
                                                            class="sr-only peer"
                                                        >
                                                        <div class="relative w-10 h-5 bg-gray-200 rounded-full peer peer-checked:bg-blue-600 transition-colors after:content-[''] after:absolute after:top-0.5 after:left-0.5 after:bg-white after:rounded-full after:h-4 after:w-4 after:transition-all peer-checked:after:translate-x-5"></div>
                                                    </label>
                                                </div>
                                            {% else %}
                                                <div class="flex items-center gap-4 flex-wrap">
                                                    <div>
                                                        <p class="text-xs font-medium text-gray-500 uppercase tracking-wide mb-2">Repeat every</p>
                                                        <select data-model="inclusions.{{ i }}.cycleId" class="px-3 py-1.5 text-sm text-gray-900 bg-white border border-gray-200 rounded-xl focus:outline-none focus:ring-2 focus:ring-gray-900/10 transition-colors cursor-pointer">
                                                            {% for o in inclusionCycleOptions %}<option value="{{ o.id }}" {% if o.id == item.cycleId %}selected{% endif %}>{{ o.label }}</option>{% endfor %}
                                                        </select>
                                                    </div>
                                                    {% if item.cycleId == 'custom' %}
                                                        <div>
                                                            <p class="text-xs font-medium text-gray-500 uppercase tracking-wide mb-2">Days</p>
                                                            <input type="number" min="1" data-model="on(input)|inclusions.{{ i }}.customCycleDays" value="{{ item.customCycleDays }}" class="w-20 px-3 py-1.5 text-sm text-center text-gray-900 bg-white border border-gray-200 rounded-lg focus:outline-none">
                                                        </div>
                                                    {% endif %}
                                                    <div class="ml-auto text-right">
                                                        <p class="text-xs text-gray-400">Approx. occurrences</p>
                                                        {% set incDays = item.cycleId == 'custom' ? item.customCycleDays : ((inclusionCycleOptions|filter(o => o.id == item.cycleId)|first).days ?? 90) %}
                                                        <p class="text-sm font-semibold text-gray-700">{{ max(1, ((duration * 30) / incDays)|round) }} over plan</p>
                                                    </div>
                                                </div>
                                            {% endif %}
                                        </div>

                                    {% endif %}{# end if productId #}

                                </div>

                            </div>
                        {% endfor %}

                        <button type="button" data-action="live#action" data-live-action-param="addInclusion" class="flex items-center gap-2 w-full px-4 py-2.5 text-sm font-medium text-blue-700 border border-dashed border-blue-300 rounded-xl hover:bg-blue-50 hover:border-blue-400 transition-colors">
                            <svg class="w-[15px] h-[15px]" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M12 4v16m8-8H4"/></svg>
                            Add inclusion
                        </button>
                    </div>
                </div>

                {# ════════════════════════════════════════════════════════════ #}
                {# Offers card                                                  #}
                {# ════════════════════════════════════════════════════════════ #}
                <div class="bg-white rounded-2xl border border-gray-200 shadow-sm overflow-hidden">
                    <div class="flex items-center gap-3 px-6 py-4 border-b border-gray-100">
                        <div class="flex items-center justify-center w-8 h-8 bg-gray-100 rounded-xl text-gray-500">
                            <svg class="w-[18px] h-[18px]" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
                        </div>
                        <div>
                            <h2 class="text-sm font-semibold text-gray-900">Offers</h2>
                            <p class="text-xs text-gray-500">Define how the plan is priced and billed to the patient.</p>
                        </div>
                    </div>
                    <div class="p-6 space-y-3">
                        {% if offers|length == 0 %}
                            <div class="flex flex-col items-center justify-center py-8 rounded-xl border-2 border-dashed border-gray-200 bg-gray-50/50">
                                <svg class="w-7 h-7 text-gray-300 mb-2" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M7 7h.01M7 3h5c.512 0 1.024.195 1.414.586l7 7a2 2 0 010 2.828l-7 7a2 2 0 01-2.828 0l-7-7A2 2 0 013 12V7a4 4 0 014-4z"/></svg>
                                <p class="text-sm font-medium text-gray-500">No offers added</p>
                                <p class="text-xs text-gray-400 mt-0.5">Add a basket value or fixed price offer</p>
                            </div>
                        {% endif %}
                        {% for i, offer in offers %}
                            <div class="rounded-xl border border-gray-200 bg-white shadow-sm overflow-hidden">
                                <div class="flex items-center gap-3 px-4 py-3 border-b border-gray-100 bg-gray-50/50">
                                    <div class="flex items-center rounded-lg border border-gray-200 bg-white overflow-hidden flex-shrink-0">
                                        <button type="button" data-action="live#action" data-live-action-param="setOfferType" data-live-key-param="{{ offer.key }}" data-live-type-param="basket_value" class="px-3 py-1.5 text-xs font-medium transition-colors {{ offer.offerType == 'basket_value' ? 'bg-blue-700 text-white' : 'text-gray-500 hover:bg-gray-50' }}">Basket value</button>
                                        <button type="button" data-action="live#action" data-live-action-param="setOfferType" data-live-key-param="{{ offer.key }}" data-live-type-param="fixed_price" class="px-3 py-1.5 text-xs font-medium transition-colors {{ offer.offerType == 'fixed_price' ? 'bg-blue-700 text-white' : 'text-gray-500 hover:bg-gray-50' }}">Fixed price</button>
                                    </div>
                                    <button type="button" data-action="live#action" data-live-action-param="removeOffer" data-live-key-param="{{ offer.key }}" class="ml-auto p-1.5 rounded-lg text-gray-400 hover:text-red-500 hover:bg-red-50 transition-colors">
                                        <svg class="w-[15px] h-[15px]" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"/></svg>
                                    </button>
                                </div>
                                {% if offer.offerType == 'basket_value' %}
                                    <div class="px-4 py-4 flex items-start gap-3">
                                        <svg class="w-4 h-4 text-blue-400 flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M16 11V7a4 4 0 00-8 0v4M5 9h14l1 12H4L5 9z"/></svg>
                                        <p class="text-sm text-gray-500">The patient is billed the <span class="font-medium text-gray-700">total value of goods</span> in each order at the point of dispatch.</p>
                                    </div>
                                {% else %}
                                    <div class="px-4 py-4 space-y-3">
                                        <div class="flex items-end gap-4 flex-wrap">
                                            <div>
                                                <p class="text-xs font-medium text-gray-500 uppercase tracking-wide mb-2">Price</p>
                                                <div class="flex items-center gap-1.5">
                                                    <span class="text-sm font-medium text-gray-600">£</span>
                                                    <input type="number" min="0" step="0.01" data-model="on(input)|offers.{{ i }}.price" value="{{ offer.price }}" placeholder="0.00" class="w-28 px-3 py-1.5 text-sm text-gray-900 bg-white border border-gray-200 rounded-lg focus:outline-none focus:ring-1 focus:ring-blue-500">
                                                </div>
                                            </div>
                                            <div>
                                                <p class="text-xs font-medium text-gray-500 uppercase tracking-wide mb-2">Billed every</p>
                                                <select data-model="offers.{{ i }}.billingCycleId" class="px-3 py-1.5 text-sm text-gray-900 bg-white border border-gray-200 rounded-xl focus:outline-none focus:ring-2 focus:ring-gray-900/10 transition-colors cursor-pointer">
                                                    {% for o in offerBillingCycleOptions %}<option value="{{ o.id }}" {% if o.id == offer.billingCycleId %}selected{% endif %}>{{ o.label }}</option>{% endfor %}
                                                </select>
                                            </div>
                                            {% if offer.billingCycleId == 'custom' %}
                                                <div>
                                                    <p class="text-xs font-medium text-gray-500 uppercase tracking-wide mb-2">Days</p>
                                                    <input type="number" min="1" data-model="on(input)|offers.{{ i }}.customBillingDays" value="{{ offer.customBillingDays }}" class="w-20 px-3 py-1.5 text-sm text-center bg-white border border-gray-200 rounded-lg focus:outline-none">
                                                </div>
                                            {% endif %}
                                        </div>
                                        {% if offer.price > 0 %}
                                            {% set offerCycleLabel = (offerBillingCycleOptions|filter(o => o.id == offer.billingCycleId)|first).label ?? '' %}
                                            <p class="text-xs text-gray-400">Patient charged <span class="font-semibold text-emerald-600">£{{ offer.price|number_format(2) }}</span> {{ offer.billingCycleId == 'custom' ? 'every ' ~ offer.customBillingDays ~ ' days' : offerCycleLabel|lower }}</p>
                                        {% endif %}

                                        {# Billing rescheduling #}
                                        <div class="pt-3 border-t border-gray-100">
                                            <div class="flex items-center justify-between">
                                                <label class="text-xs font-semibold text-gray-500 uppercase tracking-wide">Allow billing date rescheduling</label>
                                                <label class="flex items-center gap-2 cursor-pointer select-none">
                                                    <input
                                                        type="checkbox"
                                                        data-model="offers.{{ i }}.allowBillingRescheduling"
                                                        {% if offer.allowBillingRescheduling %}checked{% endif %}
                                                        class="sr-only peer"
                                                    >
                                                    <div class="relative w-10 h-5 bg-gray-200 rounded-full peer peer-checked:bg-blue-600 transition-colors after:content-[''] after:absolute after:top-0.5 after:left-0.5 after:bg-white after:rounded-full after:h-4 after:w-4 after:transition-all peer-checked:after:translate-x-5"></div>
                                                </label>
                                            </div>
                                            {% if offer.allowBillingRescheduling %}
                                                <div class="mt-3 space-y-2">
                                                    <div class="flex items-center gap-3">
                                                        <div class="flex items-center gap-2 flex-1 rounded-xl border border-gray-200 bg-gray-50 px-3.5 py-3">
                                                            <svg class="w-3.5 h-3.5 text-amber-500 flex-shrink-0" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                                                                <path stroke-linecap="round" stroke-linejoin="round" d="M10 19l-7-7m0 0l7-7m-7 7h18"/>
                                                            </svg>
                                                            <input
                                                                type="number"
                                                                min="0"
                                                                data-model="on(input)|offers.{{ i }}.billingRescheduleDaysEarlier"
                                                                value="{{ offer.billingRescheduleDaysEarlier }}"
                                                                class="w-14 text-center text-sm font-semibold text-gray-900 bg-transparent border-none outline-none focus:ring-0"
                                                            >
                                                            <span class="text-sm text-gray-500">days earlier</span>
                                                        </div>
                                                        <div class="flex items-center gap-2 flex-1 rounded-xl border border-gray-200 bg-gray-50 px-3.5 py-3">
                                                            <svg class="w-3.5 h-3.5 text-blue-500 flex-shrink-0" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                                                                <path stroke-linecap="round" stroke-linejoin="round" d="M14 5l7 7m0 0l-7 7m7-7H3"/>
                                                            </svg>
                                                            <input
                                                                type="number"
                                                                min="0"
                                                                data-model="on(input)|offers.{{ i }}.billingRescheduleDaysLater"
                                                                value="{{ offer.billingRescheduleDaysLater }}"
                                                                class="w-14 text-center text-sm font-semibold text-gray-900 bg-transparent border-none outline-none focus:ring-0"
                                                            >
                                                            <span class="text-sm text-gray-500">days later</span>
                                                        </div>
                                                    </div>
                                                    <p class="text-xs text-gray-400">
                                                        Patient can move billing up to
                                                        <span class="font-medium text-gray-600">{{ offer.billingRescheduleDaysEarlier }} day{{ offer.billingRescheduleDaysEarlier != 1 ? 's' : '' }} earlier</span>
                                                        or
                                                        <span class="font-medium text-gray-600">{{ offer.billingRescheduleDaysLater }} day{{ offer.billingRescheduleDaysLater != 1 ? 's' : '' }} later</span>.
                                                    </p>
                                                </div>
                                            {% endif %}
                                        </div>
                                    </div>
                                {% endif %}
                            </div>
                        {% endfor %}
                        <button type="button" data-action="live#action" data-live-action-param="addOffer" class="flex items-center gap-2 w-full px-4 py-2.5 text-sm font-medium text-blue-700 border border-dashed border-blue-300 rounded-xl hover:bg-blue-50 hover:border-blue-400 transition-colors">
                            <svg class="w-[15px] h-[15px]" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M12 4v16m8-8H4"/></svg>
                            Add offer
                        </button>
                    </div>
                </div>

                {# ════════════════════════════════════════════════════════════ #}
                {# Upsells card                                                 #}
                {# ════════════════════════════════════════════════════════════ #}
                <div class="bg-white rounded-2xl border border-gray-200 shadow-sm overflow-hidden">
                    <div class="flex items-center gap-3 px-6 py-4 border-b border-gray-100">
                        <div class="flex items-center justify-center w-8 h-8 bg-gray-100 rounded-xl text-gray-500">
                            <svg class="w-[18px] h-[18px]" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M3 3h2l.4 2M7 13h10l4-8H5.4M7 13L5.4 5M7 13l-2.293 2.293c-.63.63-.184 1.707.707 1.707H17m0 0a2 2 0 100 4 2 2 0 000-4zm-8 2a2 2 0 11-4 0 2 2 0 014 0z"/></svg>
                        </div>
                        <div>
                            <h2 class="text-sm font-semibold text-gray-900">Upsells</h2>
                            <p class="text-xs text-gray-500">Add products patients can purchase alongside their treatment plan.</p>
                        </div>
                    </div>
                    <div class="p-6 space-y-3">
                        {% if upsells|length == 0 %}
                            <div class="flex flex-col items-center justify-center py-8 rounded-xl border-2 border-dashed border-gray-200 bg-gray-50/50">
                                <svg class="w-7 h-7 text-gray-300 mb-2" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M3 3h2l.4 2M7 13h10l4-8H5.4M7 13L5.4 5M7 13l-2.293 2.293c-.63.63-.184 1.707.707 1.707H17m0 0a2 2 0 100 4 2 2 0 000-4zm-8 2a2 2 0 11-4 0 2 2 0 014 0z"/></svg>
                                <p class="text-sm font-medium text-gray-500">No upsells added</p>
                                <p class="text-xs text-gray-400 mt-0.5">Add vitamins, medications or supplements patients can buy</p>
                            </div>
                        {% endif %}

                        {% for i, item in upsells %}
                            {% set uProduct = item.productId ? (addonProducts|filter(p => p.id == item.productId)|first|default(null)) : null %}
                            {% set uVariants = uProduct ? (uProduct.variants ?? []) : [] %}
                            {% set uVariant = item.variantId ? (uVariants|filter(v => v.id == item.variantId)|first|default(null)) : null %}

                            <div class="rounded-xl border border-gray-200 bg-white shadow-sm overflow-hidden">

                                {# Header: upsell count + remove #}
                                <div class="flex items-center justify-between px-4 py-3 bg-gray-50/60 border-b border-gray-100">
                                    <span class="text-xs font-semibold text-gray-400 uppercase tracking-wide">Upsell {{ i + 1 }}</span>
                                    <button
                                        type="button"
                                        data-action="live#action"
                                        data-live-action-param="removeUpsell"
                                        data-live-key-param="{{ item.key }}"
                                        class="p-1.5 rounded-lg text-gray-300 hover:text-red-400 hover:bg-red-50 transition-colors"
                                    >
                                        <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                                            <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12"/>
                                        </svg>
                                    </button>
                                </div>

                                <div class="px-4 py-4 space-y-4">

                                    {# Product select #}
                                    <div class="pb-4 border-b border-gray-100">
                                        <label class="text-xs font-semibold text-gray-500 uppercase tracking-wide mb-2 block">Product</label>
                                        <select
                                            data-action="change->live#action"
                                            data-live-action-param="setUpsellProduct"
                                            data-live-key-param="{{ item.key }}"
                                            data-live-product-id-param="{{ item.productId }}"
                                            onchange="this.dataset.liveProductIdParam = this.value"
                                            class="w-full px-3 py-2 text-sm text-gray-900 bg-white border border-gray-200 rounded-xl focus:outline-none focus:ring-2 focus:ring-gray-900/10 focus:border-gray-500 transition-colors cursor-pointer"
                                        >
                                            <option value="">Select product…</option>
                                            {% for p in addonProducts %}
                                                <option value="{{ p.id }}" {% if p.id == item.productId %}selected{% endif %}>{{ p.name }}</option>
                                            {% endfor %}
                                        </select>
                                    </div>

                                    {% if item.productId %}

                                        {# Variant select #}
                                        <div class="pb-4 border-b border-gray-100">
                                            <label class="text-xs font-semibold text-gray-500 uppercase tracking-wide mb-2 block">Variant</label>
                                            <select
                                                data-model="upsells.{{ i }}.variantId"
                                                class="w-full px-3 py-2 text-sm text-gray-900 bg-white border border-gray-200 rounded-xl focus:outline-none focus:ring-2 focus:ring-gray-900/10 focus:border-gray-500 transition-colors cursor-pointer"
                                            >
                                                <option value="">Select variant…</option>
                                                {% for v in uVariants %}
                                                    <option value="{{ v.id }}" {% if v.id == item.variantId %}selected{% endif %}>{{ v.name }} — £{{ v.price|number_format(2) }}</option>
                                                {% endfor %}
                                            </select>
                                            {% if uVariant %}
                                                <p class="text-xs text-gray-400 mt-2">Catalogue price <span class="font-semibold text-emerald-600">£{{ uVariant.price|number_format(2) }}</span> per occurrence</p>
                                            {% endif %}
                                        </div>

                                        {# Schedule type toggle #}
                                        <div class="pb-4 border-b border-gray-100">
                                            <label class="text-xs font-semibold text-gray-500 uppercase tracking-wide mb-2 block">Schedule</label>
                                            <div class="flex items-center rounded-lg border border-gray-200 bg-white overflow-hidden">
                                                <button type="button" data-action="live#action" data-live-action-param="setUpsellScheduleType" data-live-key-param="{{ item.key }}" data-live-type-param="specific_orders" class="flex-1 px-3 py-2 text-xs font-medium transition-colors {{ item.scheduleType == 'specific_orders' ? 'bg-blue-700 text-white' : 'text-gray-500 hover:bg-gray-50' }}">Add to plan orders</button>
                                                <button type="button" data-action="live#action" data-live-action-param="setUpsellScheduleType" data-live-key-param="{{ item.key }}" data-live-type-param="recurring_cycle" class="flex-1 px-3 py-2 text-xs font-medium transition-colors {{ item.scheduleType == 'recurring_cycle' ? 'bg-blue-700 text-white' : 'text-gray-500 hover:bg-gray-50' }}">Unique recurring cycle</button>
                                            </div>
                                        </div>

                                        {# Schedule content #}
                                        <div class="pb-4 border-b border-gray-100">
                                            {% if item.scheduleType == 'specific_orders' %}
                                                <div class="flex items-center gap-2.5 rounded-xl bg-blue-50 border border-blue-200 px-3.5 py-3">
                                                    <svg class="w-4 h-4 text-blue-500 flex-shrink-0" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                                                        <path stroke-linecap="round" stroke-linejoin="round" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"/>
                                                    </svg>
                                                    <p class="text-xs text-blue-700">This upsell will be offered in <span class="font-semibold">every plan order</span> ({{ ordersCount }} order{{ ordersCount != 1 ? 's' : '' }} total).</p>
                                                </div>
                                            {% else %}
                                                <div class="flex items-center gap-4 flex-wrap">
                                                    <div>
                                                        <p class="text-xs font-medium text-gray-500 uppercase tracking-wide mb-2">Repeat every</p>
                                                        <select data-model="upsells.{{ i }}.cycleId" class="px-3 py-1.5 text-sm text-gray-900 bg-white border border-gray-200 rounded-xl focus:outline-none focus:ring-2 focus:ring-gray-900/10 transition-colors cursor-pointer">
                                                            {% for o in inclusionCycleOptions %}<option value="{{ o.id }}" {% if o.id == item.cycleId %}selected{% endif %}>{{ o.label }}</option>{% endfor %}
                                                        </select>
                                                    </div>
                                                    {% if item.cycleId == 'custom' %}
                                                        <div>
                                                            <p class="text-xs font-medium text-gray-500 uppercase tracking-wide mb-2">Days</p>
                                                            <input type="number" min="1" data-model="on(input)|upsells.{{ i }}.customCycleDays" value="{{ item.customCycleDays }}" class="w-20 px-3 py-1.5 text-sm text-center bg-white border border-gray-200 rounded-lg focus:outline-none">
                                                        </div>
                                                    {% endif %}
                                                    <div class="ml-auto text-right">
                                                        <p class="text-xs text-gray-400">Approx. occurrences</p>
                                                        {% set uDays = item.cycleId == 'custom' ? item.customCycleDays : ((inclusionCycleOptions|filter(o => o.id == item.cycleId)|first).days ?? 90) %}
                                                        <p class="text-sm font-semibold text-gray-700">{{ max(1, ((duration * 30) / uDays)|round) }} over plan</p>
                                                    </div>
                                                </div>
                                            {% endif %}
                                        </div>

                                        {# Pricing type #}
                                        <div>
                                            <div class="flex items-center justify-between gap-4 mb-3">
                                                <label class="text-xs font-semibold text-gray-500 uppercase tracking-wide">Price</label>
                                                <div class="flex items-center rounded-lg border border-gray-200 bg-white overflow-hidden flex-shrink-0">
                                                    <button type="button" data-action="live#action" data-live-action-param="setUpsellPricingType" data-live-key-param="{{ item.key }}" data-live-type-param="catalogue" class="px-3 py-1.5 text-xs font-medium transition-colors {{ item.pricingType == 'catalogue' ? 'bg-blue-700 text-white' : 'text-gray-500 hover:bg-gray-50' }}">Use catalogue price</button>
                                                    <button type="button" data-action="live#action" data-live-action-param="setUpsellPricingType" data-live-key-param="{{ item.key }}" data-live-type-param="custom" class="px-3 py-1.5 text-xs font-medium transition-colors {{ item.pricingType == 'custom' ? 'bg-blue-700 text-white' : 'text-gray-500 hover:bg-gray-50' }}">Custom price</button>
                                                </div>
                                            </div>
                                            {% if item.pricingType == 'custom' %}
                                                <div class="flex items-center gap-2">
                                                    <span class="text-sm font-medium text-gray-600">£</span>
                                                    <input type="number" min="0" step="0.01" data-model="on(input)|upsells.{{ i }}.customPrice" value="{{ item.customPrice }}" placeholder="0.00" class="w-28 px-3 py-1.5 text-sm text-gray-900 bg-white border border-gray-200 rounded-lg focus:outline-none focus:ring-1 focus:ring-blue-500">
                                                    <span class="text-xs text-gray-400">per occurrence</span>
                                                </div>
                                            {% elseif uVariant %}
                                                <p class="text-xs text-gray-400">Patient will be charged <span class="font-semibold text-emerald-600">£{{ uVariant.price|number_format(2) }}</span> per occurrence</p>
                                            {% endif %}
                                        </div>

                                    {% endif %}{# end if productId #}

                                </div>

                            </div>
                        {% endfor %}

                        <button type="button" data-action="live#action" data-live-action-param="addUpsell" class="flex items-center gap-2 w-full px-4 py-2.5 text-sm font-medium text-blue-700 border border-dashed border-blue-300 rounded-xl hover:bg-blue-50 hover:border-blue-400 transition-colors">
                            <svg class="w-[15px] h-[15px]" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M12 4v16m8-8H4"/></svg>
                            Add upsell
                        </button>
                    </div>
                </div>

            </div>

            {# ── Summary Panel column ────────────────────────────────────────── #}
            <div class="col-span-12 lg:col-span-4">
                <div class="sticky top-20 space-y-4">
                    <div class="bg-white rounded-2xl border border-gray-200 shadow-sm overflow-hidden">

                        <div class="flex items-center gap-3 px-6 py-4 border-b border-gray-100">
                            <div class="flex items-center justify-center w-8 h-8 bg-gray-100 rounded-xl text-gray-500">
                                <svg class="w-[18px] h-[18px]" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                                    <path stroke-linecap="round" stroke-linejoin="round" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2"/>
                                </svg>
                            </div>
                            <div>
                                <h2 class="text-sm font-semibold text-gray-900">Summary</h2>
                                <p class="text-xs text-gray-500">Live configuration preview.</p>
                            </div>
                        </div>

                        <div class="p-6 space-y-5">

                            {# Plan name #}
                            <div>
                                <p class="text-xs font-semibold text-gray-400 uppercase tracking-wide mb-1">Plan name</p>
                                {% if planName %}
                                    <p class="text-sm font-medium text-gray-900">{{ planName }}</p>
                                {% else %}
                                    <p class="text-sm text-gray-300 italic">Not set</p>
                                {% endif %}
                            </div>

                            {# Lifecycle stats #}
                            <div>
                                <p class="text-xs font-semibold text-gray-400 uppercase tracking-wide mb-2">Lifecycle</p>
                                <div class="grid grid-cols-3 gap-2">
                                    <div class="rounded-xl bg-gradient-to-br from-blue-50 to-blue-100 border border-blue-200 p-3 text-center">
                                        <div class="text-2xl font-black text-gray-900">{{ duration }}</div>
                                        <div class="text-xs font-semibold text-blue-600 mt-1 uppercase tracking-wide">months</div>
                                    </div>
                                    <div class="rounded-xl bg-gradient-to-br from-emerald-50 to-green-100 border border-green-200 p-3 text-center">
                                        <div class="text-2xl font-black text-gray-900">{{ cycleDays }}</div>
                                        <div class="text-xs font-semibold text-green-600 mt-1 uppercase tracking-wide">days</div>
                                    </div>
                                    <div class="rounded-xl bg-gradient-to-br from-purple-50 to-violet-100 border border-purple-200 p-3 text-center">
                                        <div class="text-2xl font-black text-gray-900">{{ ordersCount }}</div>
                                        <div class="text-xs font-semibold text-purple-600 mt-1 uppercase tracking-wide">orders</div>
                                    </div>
                                </div>
                                <div class="mt-2 flex items-center justify-between rounded-xl border border-gray-200 bg-gray-50 px-3 py-2">
                                    <span class="text-xs text-gray-500">Auto-renew</span>
                                    {% if autoRenew %}
                                        <span class="text-xs font-semibold text-blue-700 bg-blue-50 border border-blue-200 px-2 py-0.5 rounded-full">On</span>
                                    {% else %}
                                        <span class="text-xs font-semibold text-gray-400 bg-white border border-gray-200 px-2 py-0.5 rounded-full">Off</span>
                                    {% endif %}
                                </div>
                            </div>

                            {# Medications summary #}
                            <div class="border-t border-gray-100 pt-4">
                                <p class="text-xs font-semibold text-gray-400 uppercase tracking-wide mb-2">Medications</p>
                                {% set selectedMeds = medications|filter(m => m.medicationId != '') %}
                                {% if selectedMeds|length > 0 %}
                                    <div class="space-y-2">
                                        {% for med in selectedMeds %}
                                            {% set medData = medicationCatalogue|filter(m => m.id == med.medicationId)|first %}
                                            {% set variantData = med.variantId ? ((medData.variants ?? [])|filter(v => v.id == med.variantId)|first|default(null)) : null %}
                                            <div class="rounded-xl border border-gray-200 bg-gray-50 px-3 py-2">
                                                <div class="flex items-center justify-between gap-2">
                                                    <div class="text-sm font-medium text-gray-900 flex items-center gap-2 min-w-0">
                                                        <svg class="w-[13px] h-[13px] text-blue-400 flex-shrink-0" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M19.428 15.428a2 2 0 00-1.022-.547l-2.387-.477a6 6 0 00-3.86.517l-.318.158a6 6 0 01-3.86.517L6.05 15.21a2 2 0 00-1.806.547M8 4h8l-1 1v5.172a2 2 0 00.586 1.414l5 5c1.26 1.26.367 3.414-1.415 3.414H4.828c-1.782 0-2.674-2.154-1.414-3.414l5-5A2 2 0 009 10.172V5L8 4z"/></svg>
                                                        <span class="truncate">{{ variantData ? variantData.name : (medData.name ?? med.medicationId) }}</span>
                                                    </div>
                                                    {% if variantData %}
                                                        <span class="flex-shrink-0 text-xs font-semibold text-emerald-700 bg-emerald-50 border border-emerald-200 px-2 py-0.5 rounded-full">£{{ variantData.price|number_format(2) }}</span>
                                                    {% endif %}
                                                </div>
                                                {% if med.titrationEnabled and med.titrationPathId %}
                                                    {% set path = titrationCatalogue|filter(t => t.id == med.titrationPathId)|first %}
                                                    <div class="text-xs text-gray-500 mt-1 bg-white rounded-lg px-2 py-1 border border-gray-100">{{ path.name ?? med.titrationPathId }}</div>
                                                {% else %}
                                                    <div class="text-xs text-gray-400 italic mt-1">No titration path</div>
                                                {% endif %}
                                                <div class="text-xs text-gray-400 font-medium mt-1">
                                                    Rx: every {{ ((prescriptionRenewalOptions|filter(p => p.id == med.prescription.renewalMonths)|first).label) ?? (med.prescription.renewalMonths ~ 'm') }}
                                                </div>
                                            </div>
                                        {% endfor %}
                                    </div>
                                {% else %}
                                    <div class="rounded-xl border border-dashed border-gray-200 bg-gray-50 p-4 text-center text-sm text-gray-400">No medications yet</div>
                                {% endif %}
                            </div>

                            {# Upsells summary #}
                            {% set selectedUpsells = upsells|filter(u => u.productId != '') %}
                            {% if selectedUpsells|length > 0 %}
                                <div class="border-t border-gray-100 pt-4">
                                    <p class="text-xs font-semibold text-gray-400 uppercase tracking-wide mb-2">Upsells</p>
                                    <div class="space-y-1.5">
                                        {% for u in selectedUpsells %}
                                            {% set uProduct = addonProducts|filter(p => p.id == u.productId)|first|default(null) %}
                                            {% set uVariant = u.variantId ? ((uProduct.variants ?? [])|filter(v => v.id == u.variantId)|first|default(null)) : null %}
                                            {% set uPrice = u.pricingType == 'custom' ? u.customPrice : (uVariant.price ?? 0) %}
                                            <div class="flex items-center justify-between bg-emerald-50 border border-emerald-200 rounded-lg px-3 py-2 gap-2">
                                                <span class="text-sm font-medium text-gray-900 truncate">{{ uVariant ? uVariant.name : (uProduct.name ?? u.productId) }}</span>
                                                <span class="text-xs font-semibold text-emerald-700 bg-white px-2 py-0.5 rounded-full border border-emerald-200 flex-shrink-0">£{{ uPrice|number_format(2) }}</span>
                                            </div>
                                        {% endfor %}
                                    </div>
                                </div>
                            {% endif %}

                            {# Inclusions summary #}
                            {% set selectedInclusions = inclusions|filter(i => i.productId != '') %}
                            {% if selectedInclusions|length > 0 %}
                                <div class="border-t border-gray-100 pt-4">
                                    <p class="text-xs font-semibold text-gray-400 uppercase tracking-wide mb-2">Inclusions</p>
                                    <div class="space-y-1.5">
                                        {% for inc in selectedInclusions %}
                                            {% set incProduct = inclusionProducts|filter(p => p.id == inc.productId)|first|default(null) %}
                                            {% set incVariant = inc.variantId ? ((incProduct.variants ?? [])|filter(v => v.id == inc.variantId)|first|default(null)) : null %}
                                            {% set incCycleOpt = inclusionCycleOptions|filter(o => o.id == inc.cycleId)|first|default(null) %}
                                            <div class="bg-blue-50 border border-blue-200 rounded-lg px-3 py-2">
                                                <div class="flex items-center justify-between gap-2">
                                                    <span class="text-sm font-medium text-gray-900 truncate">{{ incVariant ? incVariant.name : (incProduct.name ?? inc.productId) }}</span>
                                                    <span class="text-xs font-semibold text-blue-700 uppercase bg-white px-2 py-0.5 rounded-full border border-blue-200 flex-shrink-0">
                                                        {% if inc.scheduleType == 'specific_orders' %}
                                                            Order{{ inc.orderNumbers|length > 1 ? 's' : '' }} {{ inc.orderNumbers|join(', ') }}
                                                        {% elseif inc.cycleId == 'custom' %}
                                                            Every {{ inc.customCycleDays }}d
                                                        {% else %}
                                                            {{ incCycleOpt.label ?? inc.cycleId }}
                                                        {% endif %}
                                                    </span>
                                                </div>
                                                {% if inc.scheduleType == 'specific_orders' and inc.repeatOnRenewal %}
                                                    <p class="text-xs text-blue-500 mt-1 font-medium">↻ Repeats on renewal</p>
                                                {% endif %}
                                            </div>
                                        {% endfor %}
                                    </div>
                                </div>
                            {% endif %}

                            {# Offers summary #}
                            {% if offers|length > 0 %}
                                <div class="border-t border-gray-100 pt-4">
                                    <p class="text-xs font-semibold text-gray-400 uppercase tracking-wide mb-2">Offers</p>
                                    <div class="space-y-1.5">
                                        {% for o in offers %}
                                            {% set oCycleOpt = offerBillingCycleOptions|filter(c => c.id == o.billingCycleId)|first %}
                                            <div class="flex items-center justify-between bg-orange-50 border border-orange-200 rounded-lg px-3 py-2 gap-2">
                                                <div class="flex items-center gap-2 truncate">
                                                    {% if o.offerType == 'basket_value' %}
                                                        <svg class="w-[13px] h-[13px] text-orange-500 flex-shrink-0" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M16 11V7a4 4 0 00-8 0v4M5 9h14l1 12H4L5 9z"/></svg>
                                                        <span class="text-sm font-medium text-gray-900 truncate">Basket value</span>
                                                    {% else %}
                                                        <svg class="w-[13px] h-[13px] text-orange-500 flex-shrink-0" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
                                                        <span class="text-sm font-medium text-gray-900 truncate">£{{ o.price|number_format(2) }}</span>
                                                    {% endif %}
                                                </div>
                                                <span class="text-xs font-semibold text-orange-700 uppercase bg-white px-2 py-0.5 rounded-full border border-orange-200 flex-shrink-0">
                                                    {% if o.offerType == 'basket_value' %}Per order
                                                    {% elseif o.billingCycleId == 'custom' %}Every {{ o.customBillingDays }}d
                                                    {% else %}{{ oCycleOpt.label ?? o.billingCycleId }}{% endif %}
                                                </span>
                                            </div>
                                        {% endfor %}
                                    </div>
                                </div>
                            {% endif %}

                        </div>
                    </div>
                </div>
            </div>

        </div>
    </div>

