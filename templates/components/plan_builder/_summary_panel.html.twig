{# ── Summary Panel column ────────────────────────────────────────── #}
<div class="col-span-12 lg:col-span-4" data-loading="addClass(opacity-60 transition-opacity duration-200)">
    <div class="sticky top-20 space-y-4">
        <div class="bg-white rounded-2xl border border-gray-200 shadow-sm overflow-hidden">

            <div class="flex items-center gap-3 px-4 sm:px-6 py-3 sm:py-4 border-b border-gray-100">
                <div class="flex items-center justify-center w-8 h-8 bg-gray-100 rounded-xl text-gray-500">
                    <svg class="w-[18px] h-[18px]" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2"/>
                    </svg>
                </div>
                <div>
                    <h2 class="text-sm font-semibold text-gray-900">Summary</h2>
                    <p class="text-xs text-gray-500">Live configuration preview.</p>
                </div>
            </div>

            <div class="p-4 sm:p-6 space-y-5">

                {# Plan name #}
                <div>
                    <p class="text-xs font-semibold text-gray-400 uppercase tracking-wide mb-1">Plan name</p>
                    {% if planName %}
                        <p class="text-sm font-medium text-gray-900">{{ planName }}</p>
                    {% else %}
                        <p class="text-sm text-gray-300 italic">Not set</p>
                    {% endif %}
                </div>

                {# Lifecycle stats #}
                <div>
                    <p class="text-xs font-semibold text-gray-400 uppercase tracking-wide mb-2">Lifecycle</p>
                    <div class="grid grid-cols-3 gap-2">
                        <div class="rounded-xl bg-gradient-to-br from-blue-50 to-blue-100 border border-blue-200 p-3 text-center">
                            <div class="text-2xl font-black text-gray-900">{{ duration }}</div>
                            <div class="text-xs font-semibold text-blue-600 mt-1 uppercase tracking-wide">months</div>
                        </div>
                        <div class="rounded-xl bg-gradient-to-br from-emerald-50 to-green-100 border border-green-200 p-3 text-center">
                            <div class="text-2xl font-black text-gray-900">{{ cycleDays }}</div>
                            <div class="text-xs font-semibold text-green-600 mt-1 uppercase tracking-wide">days</div>
                        </div>
                        <div class="rounded-xl bg-gradient-to-br from-purple-50 to-violet-100 border border-purple-200 p-3 text-center">
                            <div class="text-2xl font-black text-gray-900">{{ ordersCount }}</div>
                            <div class="text-xs font-semibold text-purple-600 mt-1 uppercase tracking-wide">orders</div>
                        </div>
                    </div>
                    <div class="mt-2 flex items-center justify-between rounded-xl border border-gray-200 bg-gray-50 px-3 py-2">
                        <span class="text-xs text-gray-500">Auto-renew</span>
                        {% if autoRenew %}
                            <span class="text-xs font-semibold text-blue-700 bg-blue-50 border border-blue-200 px-2 py-0.5 rounded-full">On</span>
                        {% else %}
                            <span class="text-xs font-semibold text-gray-400 bg-white border border-gray-200 px-2 py-0.5 rounded-full">Off</span>
                        {% endif %}
                    </div>
                </div>

                {# Medications summary #}
                <div class="border-t border-gray-100 pt-4">
                    <p class="text-xs font-semibold text-gray-400 uppercase tracking-wide mb-2">Medications</p>
                    {% set selectedMeds = medications|filter(m => m.medicationId != '') %}
                    {% if selectedMeds|length > 0 %}
                        <div class="space-y-2">
                            {% for med in selectedMeds %}
                                {% set medData = medicationCatalogue|filter(m => m.id == med.medicationId)|first %}
                                {% set variantData = med.variantId ? ((medData.variants ?? [])|filter(v => v.id == med.variantId)|first|default(null)) : null %}
                                <div class="rounded-xl border border-gray-200 bg-gray-50 px-3 py-2">
                                    <div class="flex items-center justify-between gap-2">
                                        <div class="text-sm font-medium text-gray-900 flex items-center gap-2 min-w-0">
                                            <svg class="w-[13px] h-[13px] text-blue-400 flex-shrink-0" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M19.428 15.428a2 2 0 00-1.022-.547l-2.387-.477a6 6 0 00-3.86.517l-.318.158a6 6 0 01-3.86.517L6.05 15.21a2 2 0 00-1.806.547M8 4h8l-1 1v5.172a2 2 0 00.586 1.414l5 5c1.26 1.26.367 3.414-1.415 3.414H4.828c-1.782 0-2.674-2.154-1.414-3.414l5-5A2 2 0 009 10.172V5L8 4z"/></svg>
                                            <span class="truncate">{{ variantData ? variantData.name : (medData.name ?? med.medicationId) }}</span>
                                        </div>
                                        {% if variantData %}
                                            <span class="flex-shrink-0 text-xs font-semibold text-emerald-700 bg-emerald-50 border border-emerald-200 px-2 py-0.5 rounded-full">£{{ variantData.price|number_format(2) }}</span>
                                        {% endif %}
                                    </div>
                                    {% if med.titrationEnabled and med.titrationPathId %}
                                        {% set path = titrationCatalogue|filter(t => t.id == med.titrationPathId)|first %}
                                        <div class="text-xs text-gray-500 mt-1 bg-white rounded-lg px-2 py-1 border border-gray-100">{{ path.name ?? med.titrationPathId }}</div>
                                    {% else %}
                                        <div class="text-xs text-gray-400 italic mt-1">No titration path</div>
                                    {% endif %}
                                    <div class="text-xs text-gray-400 font-medium mt-1">
                                        Rx: every {{ ((prescriptionRenewalOptions|filter(p => p.id == med.prescription.renewalMonths)|first).label) ?? (med.prescription.renewalMonths ~ 'm') }}
                                    </div>
                                </div>
                            {% endfor %}
                        </div>
                    {% else %}
                        <div class="rounded-xl border border-dashed border-gray-200 bg-gray-50 p-4 text-center text-sm text-gray-400">No medications yet</div>
                    {% endif %}
                </div>

                {# Upsells summary #}
                {% set selectedUpsells = upsells|filter(u => u.productId != '') %}
                {% if selectedUpsells|length > 0 %}
                    <div class="border-t border-gray-100 pt-4">
                        <p class="text-xs font-semibold text-gray-400 uppercase tracking-wide mb-2">Upsells</p>
                        <div class="space-y-1.5">
                            {% for u in selectedUpsells %}
                                {% set uProduct = addonProducts|filter(p => p.id == u.productId)|first|default(null) %}
                                {% set uVariant = u.variantId ? ((uProduct.variants ?? [])|filter(v => v.id == u.variantId)|first|default(null)) : null %}
                                {% set uPrice = u.pricingType == 'custom' ? u.customPrice : (uVariant.price ?? 0) %}
                                <div class="flex items-center justify-between bg-emerald-50 border border-emerald-200 rounded-lg px-3 py-2 gap-2">
                                    <span class="text-sm font-medium text-gray-900 truncate">{{ uVariant ? uVariant.name : (uProduct.name ?? u.productId) }}</span>
                                    <span class="text-xs font-semibold text-emerald-700 bg-white px-2 py-0.5 rounded-full border border-emerald-200 flex-shrink-0">£{{ uPrice|number_format(2) }}</span>
                                </div>
                            {% endfor %}
                        </div>
                    </div>
                {% endif %}

                {# Inclusions summary #}
                {% set selectedInclusions = inclusions|filter(i => i.productId != '') %}
                {% if selectedInclusions|length > 0 %}
                    <div class="border-t border-gray-100 pt-4">
                        <p class="text-xs font-semibold text-gray-400 uppercase tracking-wide mb-2">Inclusions</p>
                        <div class="space-y-1.5">
                            {% for inc in selectedInclusions %}
                                {% set incProduct = inclusionProducts|filter(p => p.id == inc.productId)|first|default(null) %}
                                {% set incVariant = inc.variantId ? ((incProduct.variants ?? [])|filter(v => v.id == inc.variantId)|first|default(null)) : null %}
                                {% set incCycleOpt = inclusionCycleOptions|filter(o => o.id == inc.cycleId)|first|default(null) %}
                                <div class="bg-blue-50 border border-blue-200 rounded-lg px-3 py-2">
                                    <div class="flex items-center justify-between gap-2">
                                        <span class="text-sm font-medium text-gray-900 truncate">{{ incVariant ? incVariant.name : (incProduct.name ?? inc.productId) }}</span>
                                        <span class="text-xs font-semibold text-blue-700 uppercase bg-white px-2 py-0.5 rounded-full border border-blue-200 flex-shrink-0">
                                            {% if inc.scheduleType == 'specific_orders' %}
                                                Order{{ inc.orderNumbers|length > 1 ? 's' : '' }} {{ inc.orderNumbers|join(', ') }}
                                            {% elseif inc.cycleId == 'custom' %}
                                                Every {{ inc.customCycleDays }}d
                                            {% else %}
                                                {{ incCycleOpt.label ?? inc.cycleId }}
                                            {% endif %}
                                        </span>
                                    </div>
                                    {% if inc.scheduleType == 'specific_orders' and inc.repeatOnRenewal %}
                                        <p class="text-xs text-blue-500 mt-1 font-medium">↻ Repeats on renewal</p>
                                    {% endif %}
                                </div>
                            {% endfor %}
                        </div>
                    </div>
                {% endif %}

                {# Offers summary #}
                {% if offers|length > 0 %}
                    <div class="border-t border-gray-100 pt-4">
                        <p class="text-xs font-semibold text-gray-400 uppercase tracking-wide mb-2">Offers</p>
                        <div class="space-y-1.5">
                            {% for o in offers %}
                                {% set oCycleOpt = offerBillingCycleOptions|filter(c => c.id == o.billingCycleId)|first %}
                                <div class="flex items-center justify-between bg-orange-50 border border-orange-200 rounded-lg px-3 py-2 gap-2">
                                    <div class="flex items-center gap-2 truncate">
                                        {% if o.offerType == 'basket_value' %}
                                            <svg class="w-[13px] h-[13px] text-orange-500 flex-shrink-0" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M16 11V7a4 4 0 00-8 0v4M5 9h14l1 12H4L5 9z"/></svg>
                                            <span class="text-sm font-medium text-gray-900 truncate">Basket value</span>
                                        {% else %}
                                            <svg class="w-[13px] h-[13px] text-orange-500 flex-shrink-0" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
                                            <span class="text-sm font-medium text-gray-900 truncate">£{{ o.price|number_format(2) }}</span>
                                        {% endif %}
                                    </div>
                                    <span class="text-xs font-semibold text-orange-700 uppercase bg-white px-2 py-0.5 rounded-full border border-orange-200 flex-shrink-0">
                                        {% if o.offerType == 'basket_value' %}Per order
                                        {% elseif o.billingCycleId == 'custom' %}Every {{ o.customBillingDays }}d
                                        {% else %}{{ oCycleOpt.label ?? o.billingCycleId }}{% endif %}
                                    </span>
                                </div>
                            {% endfor %}
                        </div>
                    </div>
                {% endif %}

            </div>
        </div>
    </div>
</div>
