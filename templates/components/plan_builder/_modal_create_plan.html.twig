{# ── Create Plan modal ─────────────────────────────────────────────────── #}
{% if showPlanModal %}
<div class="fixed inset-0 z-[100] flex items-center justify-center p-4 sm:p-6 bg-gray-900/70 backdrop-blur-sm">
    <div class="relative w-full max-w-2xl bg-white rounded-2xl shadow-2xl overflow-hidden flex flex-col" style="max-height: 85vh;">

        {# Modal header #}
        <div class="flex items-center justify-between px-5 py-4 border-b border-gray-100">
            <div class="flex items-center gap-3">
                <div class="flex items-center justify-center w-8 h-8 bg-emerald-100 rounded-xl flex-shrink-0">
                    <svg class="w-4 h-4 text-emerald-600" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"/>
                    </svg>
                </div>
                <div>
                    <h2 class="text-sm font-semibold text-gray-900">Plan created — API contract</h2>
                    <p class="text-xs text-gray-500 mt-0.5">Prototype JSON payload — share with engineering to define the scope of work</p>
                </div>
            </div>
            <button
                type="button"
                data-action="live#action"
                data-live-action-param="closePlanModal"
                class="ml-4 flex-shrink-0 p-1.5 rounded-lg text-gray-400 hover:text-gray-600 hover:bg-gray-100 transition-colors"
                aria-label="Close"
            >
                <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12"/>
                </svg>
            </button>
        </div>

        {# JSON output #}
        <div class="flex-1 overflow-y-auto bg-gray-950">
            <pre id="plan-json-output" class="px-5 py-4 text-xs text-emerald-400 leading-relaxed font-mono whitespace-pre-wrap break-words">{{ planJson }}</pre>
        </div>

        {# Modal footer #}
        <div class="flex flex-col sm:flex-row items-start sm:items-center justify-between gap-3 px-5 py-4 border-t border-gray-100 bg-gray-50">
            <p class="text-xs text-gray-500">
                <span class="inline-flex items-center gap-1.5">
                    <svg class="w-3.5 h-3.5 text-amber-500 flex-shrink-0" fill="currentColor" viewBox="0 0 20 20">
                        <path fill-rule="evenodd" d="M8.257 3.099c.765-1.36 2.722-1.36 3.486 0l5.58 9.92c.75 1.334-.213 2.98-1.742 2.98H4.42c-1.53 0-2.493-1.646-1.743-2.98l5.58-9.92zM11 13a1 1 0 11-2 0 1 1 0 012 0zm-1-8a1 1 0 00-1 1v3a1 1 0 002 0V6a1 1 0 00-1-1z" clip-rule="evenodd"/>
                    </svg>
                    Prototype only — not persisted to any database
                </span>
            </p>
            <button
                type="button"
                onclick="(function(btn){navigator.clipboard.writeText(document.getElementById('plan-json-output').textContent).then(function(){var orig=btn.innerHTML;btn.innerHTML='<svg class=\'w-3.5 h-3.5\' fill=\'none\' stroke=\'currentColor\' stroke-width=\'2\' viewBox=\'0 0 24 24\'><path stroke-linecap=\'round\' stroke-linejoin=\'round\' d=\'M5 13l4 4L19 7\'/></svg> Copied!';setTimeout(function(){btn.innerHTML=orig},2000)})})(this)"
                class="inline-flex items-center gap-2 px-4 py-2 text-xs font-semibold rounded-xl bg-gray-900 text-white hover:bg-gray-700 transition-colors flex-shrink-0"
            >
                <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M8 5H6a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2v-1M8 5a2 2 0 002 2h2a2 2 0 002-2M8 5a2 2 0 012-2h2a2 2 0 012 2m0 0h2a2 2 0 012 2v3m2 4H10m0 0l3-3m-3 3l3 3"/>
                </svg>
                Copy JSON
            </button>
        </div>

    </div>
</div>
{% endif %}
