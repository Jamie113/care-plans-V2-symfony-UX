{# ════════════════════════════════════════════════════════════ #}
{# Offers card                                                  #}
{# ════════════════════════════════════════════════════════════ #}
{#
    SCOPE — Offers
    ✓  Two offer types: basket_value (charged per plan order) and fixed_price (subscription)
    ✓  Fixed-price: amount input, billing cycle (preset or custom days)
    ✓  Billing rescheduling window — allow patient to shift billing date ± days
    ✓  Multiple offers per plan (add / remove)
    ~  Price is a raw float — no currency symbol, no rounding enforcement, no min/max
    ~  Billing cycle "custom" accepts any positive int; real system needs min billing interval
    ○  Offer eligibility rules (new patient only, plan type restriction, etc.)
    ○  Payment gateway / billing provider integration
    ○  Failed payment / dunning flow
    ○  Proration on mid-cycle plan changes
    ○  VAT / tax handling
#}
<div class="bg-white rounded-2xl border border-gray-200 shadow-sm overflow-hidden">
    <div class="flex items-center gap-3 px-4 sm:px-6 py-3 sm:py-4 border-b border-gray-100">
        <div class="flex items-center justify-center w-8 h-8 bg-gray-100 rounded-xl text-gray-500">
            <svg class="w-[18px] h-[18px]" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
        </div>
        <div>
            <h2 class="text-sm font-semibold text-gray-900">Offers</h2>
            <p class="text-xs text-gray-500">Define how the plan is priced and billed to the patient.</p>
        </div>
    </div>
    <div class="p-6 space-y-3">
        {% if offers|length == 0 %}
            <div class="flex flex-col items-center justify-center py-8 rounded-xl border-2 border-dashed border-gray-200 bg-gray-50/50">
                <svg class="w-7 h-7 text-gray-300 mb-2" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M7 7h.01M7 3h5c.512 0 1.024.195 1.414.586l7 7a2 2 0 010 2.828l-7 7a2 2 0 01-2.828 0l-7-7A2 2 0 013 12V7a4 4 0 014-4z"/></svg>
                <p class="text-sm font-medium text-gray-500">No offers added</p>
                <p class="text-xs text-gray-400 mt-0.5">Add a basket value or fixed price offer</p>
            </div>
        {% endif %}
        {% for i, offer in offers %}
            <div class="rounded-xl border border-gray-200 bg-white shadow-sm overflow-hidden">
                <div class="flex items-center gap-3 px-4 py-3 border-b border-gray-100 bg-gray-50/50">
                    <div class="flex items-center rounded-lg border border-gray-200 bg-white overflow-hidden flex-shrink-0">
                        <button type="button" data-action="live#action" data-live-action-param="setOfferType" data-live-key-param="{{ offer.key }}" data-live-type-param="basket_value" class="px-3 py-1.5 text-xs font-medium transition-colors {{ offer.offerType == 'basket_value' ? 'bg-blue-700 text-white' : 'text-gray-500 hover:bg-gray-50' }}">Basket value</button>
                        <button type="button" data-action="live#action" data-live-action-param="setOfferType" data-live-key-param="{{ offer.key }}" data-live-type-param="fixed_price" class="px-3 py-1.5 text-xs font-medium transition-colors {{ offer.offerType == 'fixed_price' ? 'bg-blue-700 text-white' : 'text-gray-500 hover:bg-gray-50' }}">Fixed price</button>
                    </div>
                    <button type="button" data-action="live#action" data-live-action-param="removeOffer" data-live-key-param="{{ offer.key }}" class="ml-auto p-1.5 rounded-lg text-gray-400 hover:text-red-500 hover:bg-red-50 transition-colors">
                        <svg class="w-[15px] h-[15px]" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"/></svg>
                    </button>
                </div>
                {% if offer.offerType == 'basket_value' %}
                    <div class="px-4 py-4 flex items-start gap-3">
                        <svg class="w-4 h-4 text-blue-400 flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M16 11V7a4 4 0 00-8 0v4M5 9h14l1 12H4L5 9z"/></svg>
                        <p class="text-sm text-gray-500">The patient is billed the <span class="font-medium text-gray-700">total value of goods</span> in each order at the point of dispatch.</p>
                    </div>
                {% else %}
                    <div class="px-4 py-4 space-y-3">
                        <div class="flex items-end gap-4 flex-wrap">
                            <div>
                                <p class="text-xs font-medium text-gray-500 uppercase tracking-wide mb-2">Price</p>
                                <div class="flex items-center gap-1.5">
                                    <span class="text-sm font-medium text-gray-600">£</span>
                                    <input type="number" min="0" step="0.01" data-model="on(input)|offers.{{ i }}.price" value="{{ offer.price }}" placeholder="0.00" class="w-28 px-3 py-1.5 text-sm text-gray-900 bg-white border border-gray-200 rounded-lg focus:outline-none focus:ring-1 focus:ring-blue-500">
                                </div>
                            </div>
                            <div>
                                <p class="text-xs font-medium text-gray-500 uppercase tracking-wide mb-2">Billed every</p>
                                <select data-model="offers.{{ i }}.billingCycleId" class="px-3 py-1.5 text-sm text-gray-900 bg-white border border-gray-200 rounded-xl focus:outline-none focus:ring-2 focus:ring-gray-900/10 transition-colors cursor-pointer">
                                    {% for o in offerBillingCycleOptions %}<option value="{{ o.id }}" {% if o.id == offer.billingCycleId %}selected{% endif %}>{{ o.label }}</option>{% endfor %}
                                </select>
                            </div>
                            {% if offer.billingCycleId == 'custom' %}
                                <div>
                                    <p class="text-xs font-medium text-gray-500 uppercase tracking-wide mb-2">Days</p>
                                    <input type="number" min="1" data-model="on(input)|offers.{{ i }}.customBillingDays" value="{{ offer.customBillingDays }}" class="w-20 px-3 py-1.5 text-sm text-center bg-white border border-gray-200 rounded-lg focus:outline-none">
                                </div>
                            {% endif %}
                        </div>
                        {% if offer.price > 0 %}
                            {% set offerCycleLabel = (offerBillingCycleOptions|filter(o => o.id == offer.billingCycleId)|first).label ?? '' %}
                            <p class="text-xs text-gray-400">Patient charged <span class="font-semibold text-emerald-600">£{{ offer.price|number_format(2) }}</span> {{ offer.billingCycleId == 'custom' ? 'every ' ~ offer.customBillingDays ~ ' days' : offerCycleLabel|lower }}</p>
                        {% endif %}

                        {# Billing rescheduling #}
                        <div class="pt-3 border-t border-gray-100">
                            <div class="flex items-center justify-between">
                                <label class="text-xs font-semibold text-gray-500 uppercase tracking-wide">Allow billing date rescheduling</label>
                                <label class="flex items-center gap-2 cursor-pointer select-none">
                                    <input
                                        type="checkbox"
                                        data-model="offers.{{ i }}.allowBillingRescheduling"
                                        {% if offer.allowBillingRescheduling %}checked{% endif %}
                                        class="sr-only peer"
                                    >
                                    <div class="relative w-10 h-5 bg-gray-200 rounded-full peer peer-checked:bg-blue-600 transition-colors after:content-[''] after:absolute after:top-0.5 after:left-0.5 after:bg-white after:rounded-full after:h-4 after:w-4 after:transition-all peer-checked:after:translate-x-5"></div>
                                </label>
                            </div>
                            {% if offer.allowBillingRescheduling %}
                                <div class="mt-3 space-y-2">
                                    <div class="flex items-center gap-3">
                                        <div class="flex items-center gap-2 flex-1 rounded-xl border border-gray-200 bg-gray-50 px-3.5 py-3">
                                            <svg class="w-3.5 h-3.5 text-amber-500 flex-shrink-0" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                                                <path stroke-linecap="round" stroke-linejoin="round" d="M10 19l-7-7m0 0l7-7m-7 7h18"/>
                                            </svg>
                                            <input
                                                type="number"
                                                min="0"
                                                data-model="on(input)|offers.{{ i }}.billingRescheduleDaysEarlier"
                                                value="{{ offer.billingRescheduleDaysEarlier }}"
                                                class="w-14 text-center text-sm font-semibold text-gray-900 bg-transparent border-none outline-none focus:ring-0"
                                            >
                                            <span class="text-sm text-gray-500">days earlier</span>
                                        </div>
                                        <div class="flex items-center gap-2 flex-1 rounded-xl border border-gray-200 bg-gray-50 px-3.5 py-3">
                                            <svg class="w-3.5 h-3.5 text-blue-500 flex-shrink-0" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                                                <path stroke-linecap="round" stroke-linejoin="round" d="M14 5l7 7m0 0l-7 7m7-7H3"/>
                                            </svg>
                                            <input
                                                type="number"
                                                min="0"
                                                data-model="on(input)|offers.{{ i }}.billingRescheduleDaysLater"
                                                value="{{ offer.billingRescheduleDaysLater }}"
                                                class="w-14 text-center text-sm font-semibold text-gray-900 bg-transparent border-none outline-none focus:ring-0"
                                            >
                                            <span class="text-sm text-gray-500">days later</span>
                                        </div>
                                    </div>
                                    <p class="text-xs text-gray-400">
                                        Patient can move billing up to
                                        <span class="font-medium text-gray-600">{{ offer.billingRescheduleDaysEarlier }} day{{ offer.billingRescheduleDaysEarlier != 1 ? 's' : '' }} earlier</span>
                                        or
                                        <span class="font-medium text-gray-600">{{ offer.billingRescheduleDaysLater }} day{{ offer.billingRescheduleDaysLater != 1 ? 's' : '' }} later</span>.
                                    </p>
                                </div>
                            {% endif %}
                        </div>
                    </div>
                {% endif %}
            </div>
        {% endfor %}
        <button type="button" data-action="live#action" data-live-action-param="addOffer" class="flex items-center gap-2 w-full px-4 py-2.5 text-sm font-medium text-blue-700 border border-dashed border-blue-300 rounded-xl hover:bg-blue-50 hover:border-blue-400 transition-colors">
            <svg class="w-[15px] h-[15px]" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M12 4v16m8-8H4"/></svg>
            Add offer
        </button>
    </div>
</div>
