{# ── Header ──────────────────────────────────────────────────────────────── #}
<div class="border-b border-gray-200 bg-white sticky top-0 z-50 shadow-sm">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 py-3 sm:py-4">
        <div class="flex items-center justify-between gap-3 sm:gap-6">

            <div class="flex items-center gap-3">
                <div class="flex items-center justify-center w-8 h-8 sm:w-9 sm:h-9 bg-blue-700 rounded-xl flex-shrink-0">
                    <svg class="w-[16px] h-[16px] sm:w-[18px] sm:h-[18px] text-white" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2m-6 9l2 2 4-4"/>
                    </svg>
                </div>
                <div>
                    <h1 class="text-sm sm:text-lg font-semibold text-gray-900 leading-none">New Treatment Plan</h1>
                    <p class="hidden sm:block text-xs text-gray-500 mt-1">Configure your plan below, then create it.</p>
                </div>
            </div>

            <div class="flex items-center gap-2 sm:gap-3">
                {# Save Draft — icon-only on mobile, icon+label on sm+ #}
                <button type="button" class="inline-flex items-center gap-2 px-2.5 sm:px-4 py-2 text-sm font-medium text-gray-700 bg-white border border-gray-200 rounded-xl hover:bg-gray-50 hover:border-gray-300 transition-colors">
                    <svg class="w-[15px] h-[15px] flex-shrink-0" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M8 7H5a2 2 0 00-2 2v9a2 2 0 002 2h14a2 2 0 002-2V9a2 2 0 00-2-2h-3m-1 4l-3 3m0 0l-3-3m3 3V4"/>
                    </svg>
                    <span class="hidden sm:inline">Save Draft</span>
                </button>

                {% if validation.canCreate %}
                    <button
                        type="button"
                        data-action="live#action"
                        data-live-action-param="createPlan"
                        data-loading="addClass(opacity-60 pointer-events-none)"
                        class="inline-flex items-center gap-2 px-3 sm:px-5 py-2 text-sm font-semibold rounded-xl bg-blue-700 text-white hover:bg-blue-800 shadow-sm transition-colors"
                    >
                        <svg class="w-[15px] h-[15px] flex-shrink-0" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"/>
                        </svg>
                        <span class="hidden xs:inline sm:inline">Create Plan</span>
                        <span class="sm:hidden">Create</span>
                    </button>
                {% else %}
                    <button type="button" disabled class="inline-flex items-center gap-2 px-3 sm:px-5 py-2 text-sm font-semibold rounded-xl bg-gray-100 text-gray-400 cursor-not-allowed">
                        <svg class="w-[15px] h-[15px] flex-shrink-0" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"/>
                        </svg>
                        <span class="hidden sm:inline">Complete Form</span>
                        <span class="sm:hidden">Incomplete</span>
                    </button>
                {% endif %}
            </div>

        </div>
    </div>
</div>
