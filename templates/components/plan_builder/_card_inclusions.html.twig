{# ════════════════════════════════════════════════════════════ #}
{# Inclusions card                                              #}
{# ════════════════════════════════════════════════════════════ #}
{#
    SCOPE — Inclusions
    ✓  Product → variant two-step selection (same pattern as medications)
    ✓  availableAsInclusion flag filters the catalogue; separate from medications
    ✓  Schedule type: specific_orders (order number picker) or recurring_cycle
    ✓  Order number pills, up to min(ordersCount, 24); multi-select toggle
    ✓  Repeat on renewal toggle (specific_orders only) — serialised to API contract
    ✓  Recurring cycle: preset intervals or custom days; approx occurrences shown
    ~  Catalogue is a static stub — needs integration with product/inventory service
    ~  No validation that selected order numbers are within plan ordersCount
    ○  Inclusion cost tracking / margin impact
    ○  Conditional inclusions (e.g. only on first order, or if patient meets criteria)
    ○  Inclusion fulfilment split from medication dispatch
#}
<div class="bg-white rounded-2xl border border-gray-200 shadow-sm overflow-hidden">
    <div class="flex items-center gap-3 px-4 sm:px-6 py-3 sm:py-4 border-b border-gray-100">
        <div class="flex items-center justify-center w-8 h-8 bg-gray-100 rounded-xl text-gray-500">
            <svg class="w-[18px] h-[18px]" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"/>
            </svg>
        </div>
        <div>
            <h2 class="text-sm font-semibold text-gray-900">Inclusions</h2>
            <p class="text-xs text-gray-500">Add items to specific orders or on their own recurring schedule.</p>
        </div>
    </div>
    <div class="p-6 space-y-3">
        {% if inclusions|length == 0 %}
            <div class="flex flex-col items-center justify-center py-8 rounded-xl border-2 border-dashed border-gray-200 bg-gray-50/50">
                <svg class="w-7 h-7 text-gray-300 mb-2" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"/></svg>
                <p class="text-sm font-medium text-gray-500">No inclusions added</p>
                <p class="text-xs text-gray-400 mt-0.5">Add blood tests, reviews, or other scheduled items</p>
            </div>
        {% endif %}

        {% for i, item in inclusions %}
            {% set incProduct = item.productId ? (inclusionProducts|filter(p => p.id == item.productId)|first|default(null)) : null %}
            {% set incVariants = incProduct ? (incProduct.variants ?? []) : [] %}
            {% set incVariant = item.variantId ? (incVariants|filter(v => v.id == item.variantId)|first|default(null)) : null %}

            <div class="rounded-xl border border-gray-200 bg-white shadow-sm overflow-hidden">

                {# Header: inclusion count + remove #}
                <div class="flex items-center justify-between px-4 py-3 bg-gray-50/60 border-b border-gray-100">
                    <span class="text-xs font-semibold text-gray-400 uppercase tracking-wide">Inclusion {{ i + 1 }}</span>
                    <button
                        type="button"
                        data-action="live#action"
                        data-live-action-param="removeInclusion"
                        data-live-key-param="{{ item.key }}"
                        class="p-1.5 rounded-lg text-gray-300 hover:text-red-400 hover:bg-red-50 transition-colors"
                    >
                        <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12"/>
                        </svg>
                    </button>
                </div>

                <div class="px-4 py-4 space-y-4">

                    {# Product select #}
                    <div class="pb-4 border-b border-gray-100">
                        <label class="text-xs font-semibold text-gray-500 uppercase tracking-wide mb-2 block">Product</label>
                        <select
                            data-action="change->live#action"
                            data-live-action-param="setInclusionProduct"
                            data-live-key-param="{{ item.key }}"
                            data-live-product-id-param="{{ item.productId }}"
                            onchange="this.dataset.liveProductIdParam = this.value"
                            class="w-full px-3 py-2 text-sm text-gray-900 bg-white border border-gray-200 rounded-xl focus:outline-none focus:ring-2 focus:ring-gray-900/10 focus:border-gray-500 transition-colors cursor-pointer"
                        >
                            <option value="">Select product…</option>
                            {% for p in inclusionProducts %}
                                <option value="{{ p.id }}" {% if p.id == item.productId %}selected{% endif %}>{{ p.name }}</option>
                            {% endfor %}
                        </select>
                    </div>

                    {% if item.productId %}

                        {# Variant select #}
                        <div class="pb-4 border-b border-gray-100">
                            <label class="text-xs font-semibold text-gray-500 uppercase tracking-wide mb-2 block">Variant</label>
                            <select
                                data-model="inclusions.{{ i }}.variantId"
                                class="w-full px-3 py-2 text-sm text-gray-900 bg-white border border-gray-200 rounded-xl focus:outline-none focus:ring-2 focus:ring-gray-900/10 focus:border-gray-500 transition-colors cursor-pointer"
                            >
                                <option value="">Select variant…</option>
                                {% for v in incVariants %}
                                    <option value="{{ v.id }}" {% if v.id == item.variantId %}selected{% endif %}>{{ v.name }}{% if v.price > 0 %} — £{{ v.price|number_format(2) }}{% endif %}</option>
                                {% endfor %}
                            </select>
                            {% if incVariant and incVariant.price > 0 %}
                                <p class="text-xs text-gray-400 mt-2">Catalogue price <span class="font-semibold text-emerald-600">£{{ incVariant.price|number_format(2) }}</span> per order</p>
                            {% endif %}
                        </div>

                        {# Schedule type toggle #}
                        <div class="pb-4 border-b border-gray-100">
                            <label class="text-xs font-semibold text-gray-500 uppercase tracking-wide mb-2 block">Schedule</label>
                            <div class="flex items-center rounded-lg border border-gray-200 bg-white overflow-hidden">
                                <button type="button" data-action="live#action" data-live-action-param="setInclusionScheduleType" data-live-key-param="{{ item.key }}" data-live-type-param="specific_orders" class="flex-1 px-3 py-2 text-xs font-medium transition-colors {{ item.scheduleType == 'specific_orders' ? 'bg-blue-700 text-white' : 'text-gray-500 hover:bg-gray-50' }}">Specific orders</button>
                                <button type="button" data-action="live#action" data-live-action-param="setInclusionScheduleType" data-live-key-param="{{ item.key }}" data-live-type-param="recurring_cycle" class="flex-1 px-3 py-2 text-xs font-medium transition-colors {{ item.scheduleType == 'recurring_cycle' ? 'bg-blue-700 text-white' : 'text-gray-500 hover:bg-gray-50' }}">Recurring cycle</button>
                            </div>
                        </div>

                        {# Schedule content #}
                        <div>
                            {% if item.scheduleType == 'specific_orders' %}
                                <p class="text-xs font-medium text-gray-500 uppercase tracking-wide mb-2.5">Include in order</p>
                                <div class="flex flex-wrap gap-1.5">
                                    {% for n in 1..min(ordersCount, 24) %}
                                        <button type="button" data-action="live#action" data-live-action-param="toggleInclusionOrder" data-live-key-param="{{ item.key }}" data-live-order-num-param="{{ n }}" class="w-8 h-8 rounded-lg text-xs font-semibold transition-colors {{ n in item.orderNumbers ? 'bg-blue-700 text-white shadow-sm' : 'bg-gray-100 text-gray-500 hover:bg-gray-200' }}">{{ n }}</button>
                                    {% endfor %}
                                </div>
                                {% if item.orderNumbers|length > 0 %}<p class="text-xs text-gray-400 mt-2">Included in order{{ item.orderNumbers|length > 1 ? 's' : '' }} <span class="font-medium text-gray-600">{{ item.orderNumbers|join(', ') }}</span></p>{% endif %}

                                {# Repeat on renewal #}
                                <div class="flex items-center justify-between mt-4 pt-3 border-t border-gray-100">
                                    <div>
                                        <p class="text-xs font-semibold text-gray-600">Repeat on renewal</p>
                                        <p class="text-xs text-gray-400 mt-0.5">Re-include in the same orders when the plan renews</p>
                                    </div>
                                    <label class="flex items-center gap-2 cursor-pointer select-none flex-shrink-0 ml-4">
                                        <input
                                            type="checkbox"
                                            data-model="inclusions.{{ i }}.repeatOnRenewal"
                                            {% if item.repeatOnRenewal %}checked{% endif %}
                                            class="sr-only peer"
                                        >
                                        <div class="relative w-10 h-5 bg-gray-200 rounded-full peer peer-checked:bg-blue-600 transition-colors after:content-[''] after:absolute after:top-0.5 after:left-0.5 after:bg-white after:rounded-full after:h-4 after:w-4 after:transition-all peer-checked:after:translate-x-5"></div>
                                    </label>
                                </div>
                            {% else %}
                                <div class="flex items-center gap-4 flex-wrap">
                                    <div>
                                        <p class="text-xs font-medium text-gray-500 uppercase tracking-wide mb-2">Repeat every</p>
                                        <select data-model="inclusions.{{ i }}.cycleId" class="px-3 py-1.5 text-sm text-gray-900 bg-white border border-gray-200 rounded-xl focus:outline-none focus:ring-2 focus:ring-gray-900/10 transition-colors cursor-pointer">
                                            {% for o in inclusionCycleOptions %}<option value="{{ o.id }}" {% if o.id == item.cycleId %}selected{% endif %}>{{ o.label }}</option>{% endfor %}
                                        </select>
                                    </div>
                                    {% if item.cycleId == 'custom' %}
                                        <div>
                                            <p class="text-xs font-medium text-gray-500 uppercase tracking-wide mb-2">Days</p>
                                            <input type="number" min="1" data-model="on(input)|inclusions.{{ i }}.customCycleDays" value="{{ item.customCycleDays }}" class="w-20 px-3 py-1.5 text-sm text-center text-gray-900 bg-white border border-gray-200 rounded-lg focus:outline-none">
                                        </div>
                                    {% endif %}
                                    <div class="ml-auto text-right">
                                        <p class="text-xs text-gray-400">Approx. occurrences</p>
                                        {% set incDays = item.cycleId == 'custom' ? item.customCycleDays : ((inclusionCycleOptions|filter(o => o.id == item.cycleId)|first).days ?? 90) %}
                                        <p class="text-sm font-semibold text-gray-700">{{ max(1, ((duration * 30) / incDays)|round) }} over plan</p>
                                    </div>
                                </div>
                            {% endif %}
                        </div>

                    {% endif %}{# end if productId #}

                </div>

            </div>
        {% endfor %}

        <button type="button" data-action="live#action" data-live-action-param="addInclusion" class="flex items-center gap-2 w-full px-4 py-2.5 text-sm font-medium text-blue-700 border border-dashed border-blue-300 rounded-xl hover:bg-blue-50 hover:border-blue-400 transition-colors">
            <svg class="w-[15px] h-[15px]" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M12 4v16m8-8H4"/></svg>
            Add inclusion
        </button>
    </div>
</div>
