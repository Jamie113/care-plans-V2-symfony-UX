{# ════════════════════════════════════════════════════════════ #}
{# Upsells card                                                 #}
{# ════════════════════════════════════════════════════════════ #}
{#
    SCOPE — Upsells
    ✓  Product → variant selection; availableAsUpsell flag filters catalogue
    ✓  Schedule type: specific_orders ("Add to plan orders" = every order, info banner)
          or recurring_cycle (unique interval independent of dispatch cycle)
    ✓  Pricing type: catalogue price (from variant) or custom price override
    ✓  Multiple upsells per plan (add / remove with UUID keys)
    ~  "Add to plan orders" currently means every order — no per-order picker for upsells
       (deliberate UX decision; revisit if partial-order upsells are needed)
    ~  Custom price is a raw float — same currency/rounding caveats as Offers
    ○  Upsell presentation logic on patient app (modal, inline, post-checkout)
    ○  Upsell acceptance / decline tracking
    ○  Offer eligibility rules (e.g. only show if patient has not purchased before)
    ○  A/B testing different upsell configurations
#}
<div class="bg-white rounded-2xl border border-gray-200 shadow-sm overflow-hidden">
    <div class="flex items-center gap-3 px-4 sm:px-6 py-3 sm:py-4 border-b border-gray-100">
        <div class="flex items-center justify-center w-8 h-8 bg-gray-100 rounded-xl text-gray-500">
            <svg class="w-[18px] h-[18px]" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M3 3h2l.4 2M7 13h10l4-8H5.4M7 13L5.4 5M7 13l-2.293 2.293c-.63.63-.184 1.707.707 1.707H17m0 0a2 2 0 100 4 2 2 0 000-4zm-8 2a2 2 0 11-4 0 2 2 0 014 0z"/></svg>
        </div>
        <div>
            <h2 class="text-sm font-semibold text-gray-900">Upsells</h2>
            <p class="text-xs text-gray-500">Add products patients can purchase alongside their treatment plan.</p>
        </div>
    </div>
    <div class="p-6 space-y-3">
        {% if upsells|length == 0 %}
            <div class="flex flex-col items-center justify-center py-8 rounded-xl border-2 border-dashed border-gray-200 bg-gray-50/50">
                <svg class="w-7 h-7 text-gray-300 mb-2" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M3 3h2l.4 2M7 13h10l4-8H5.4M7 13L5.4 5M7 13l-2.293 2.293c-.63.63-.184 1.707.707 1.707H17m0 0a2 2 0 100 4 2 2 0 000-4zm-8 2a2 2 0 11-4 0 2 2 0 014 0z"/></svg>
                <p class="text-sm font-medium text-gray-500">No upsells added</p>
                <p class="text-xs text-gray-400 mt-0.5">Add vitamins, medications or supplements patients can buy</p>
            </div>
        {% endif %}

        {% for i, item in upsells %}
            {% set uProduct = item.productId ? (addonProducts|filter(p => p.id == item.productId)|first|default(null)) : null %}
            {% set uVariants = uProduct ? (uProduct.variants ?? []) : [] %}
            {% set uVariant = item.variantId ? (uVariants|filter(v => v.id == item.variantId)|first|default(null)) : null %}

            <div class="rounded-xl border border-gray-200 bg-white shadow-sm overflow-hidden">

                {# Header: upsell count + remove #}
                <div class="flex items-center justify-between px-4 py-3 bg-gray-50/60 border-b border-gray-100">
                    <span class="text-xs font-semibold text-gray-400 uppercase tracking-wide">Upsell {{ i + 1 }}</span>
                    <button
                        type="button"
                        data-action="live#action"
                        data-live-action-param="removeUpsell"
                        data-live-key-param="{{ item.key }}"
                        class="p-1.5 rounded-lg text-gray-300 hover:text-red-400 hover:bg-red-50 transition-colors"
                    >
                        <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12"/>
                        </svg>
                    </button>
                </div>

                <div class="px-4 py-4 space-y-4">

                    {# Product select #}
                    <div class="pb-4 border-b border-gray-100">
                        <label class="text-xs font-semibold text-gray-500 uppercase tracking-wide mb-2 block">Product</label>
                        <select
                            data-action="change->live#action"
                            data-live-action-param="setUpsellProduct"
                            data-live-key-param="{{ item.key }}"
                            data-live-product-id-param="{{ item.productId }}"
                            onchange="this.dataset.liveProductIdParam = this.value"
                            class="w-full px-3 py-2 text-sm text-gray-900 bg-white border border-gray-200 rounded-xl focus:outline-none focus:ring-2 focus:ring-gray-900/10 focus:border-gray-500 transition-colors cursor-pointer"
                        >
                            <option value="">Select product…</option>
                            {% for p in addonProducts %}
                                <option value="{{ p.id }}" {% if p.id == item.productId %}selected{% endif %}>{{ p.name }}</option>
                            {% endfor %}
                        </select>
                    </div>

                    {% if item.productId %}

                        {# Variant select #}
                        <div class="pb-4 border-b border-gray-100">
                            <label class="text-xs font-semibold text-gray-500 uppercase tracking-wide mb-2 block">Variant</label>
                            <select
                                data-model="upsells.{{ i }}.variantId"
                                class="w-full px-3 py-2 text-sm text-gray-900 bg-white border border-gray-200 rounded-xl focus:outline-none focus:ring-2 focus:ring-gray-900/10 focus:border-gray-500 transition-colors cursor-pointer"
                            >
                                <option value="">Select variant…</option>
                                {% for v in uVariants %}
                                    <option value="{{ v.id }}" {% if v.id == item.variantId %}selected{% endif %}>{{ v.name }} — £{{ v.price|number_format(2) }}</option>
                                {% endfor %}
                            </select>
                            {% if uVariant %}
                                <p class="text-xs text-gray-400 mt-2">Catalogue price <span class="font-semibold text-emerald-600">£{{ uVariant.price|number_format(2) }}</span> per occurrence</p>
                            {% endif %}
                        </div>

                        {# Schedule type toggle #}
                        <div class="pb-4 border-b border-gray-100">
                            <label class="text-xs font-semibold text-gray-500 uppercase tracking-wide mb-2 block">Schedule</label>
                            <div class="flex items-center rounded-lg border border-gray-200 bg-white overflow-hidden">
                                <button type="button" data-action="live#action" data-live-action-param="setUpsellScheduleType" data-live-key-param="{{ item.key }}" data-live-type-param="specific_orders" class="flex-1 px-3 py-2 text-xs font-medium transition-colors {{ item.scheduleType == 'specific_orders' ? 'bg-blue-700 text-white' : 'text-gray-500 hover:bg-gray-50' }}">Add to plan orders</button>
                                <button type="button" data-action="live#action" data-live-action-param="setUpsellScheduleType" data-live-key-param="{{ item.key }}" data-live-type-param="recurring_cycle" class="flex-1 px-3 py-2 text-xs font-medium transition-colors {{ item.scheduleType == 'recurring_cycle' ? 'bg-blue-700 text-white' : 'text-gray-500 hover:bg-gray-50' }}">Unique recurring cycle</button>
                            </div>
                        </div>

                        {# Schedule content #}
                        <div class="pb-4 border-b border-gray-100">
                            {% if item.scheduleType == 'specific_orders' %}
                                <div class="flex items-center gap-2.5 rounded-xl bg-blue-50 border border-blue-200 px-3.5 py-3">
                                    <svg class="w-4 h-4 text-blue-500 flex-shrink-0" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                                        <path stroke-linecap="round" stroke-linejoin="round" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"/>
                                    </svg>
                                    <p class="text-xs text-blue-700">This upsell will be offered in <span class="font-semibold">every plan order</span> ({{ ordersCount }} order{{ ordersCount != 1 ? 's' : '' }} total).</p>
                                </div>
                            {% else %}
                                <div class="flex items-center gap-4 flex-wrap">
                                    <div>
                                        <p class="text-xs font-medium text-gray-500 uppercase tracking-wide mb-2">Repeat every</p>
                                        <select data-model="upsells.{{ i }}.cycleId" class="px-3 py-1.5 text-sm text-gray-900 bg-white border border-gray-200 rounded-xl focus:outline-none focus:ring-2 focus:ring-gray-900/10 transition-colors cursor-pointer">
                                            {% for o in inclusionCycleOptions %}<option value="{{ o.id }}" {% if o.id == item.cycleId %}selected{% endif %}>{{ o.label }}</option>{% endfor %}
                                        </select>
                                    </div>
                                    {% if item.cycleId == 'custom' %}
                                        <div>
                                            <p class="text-xs font-medium text-gray-500 uppercase tracking-wide mb-2">Days</p>
                                            <input type="number" min="1" data-model="on(input)|upsells.{{ i }}.customCycleDays" value="{{ item.customCycleDays }}" class="w-20 px-3 py-1.5 text-sm text-center bg-white border border-gray-200 rounded-lg focus:outline-none">
                                        </div>
                                    {% endif %}
                                    <div class="ml-auto text-right">
                                        <p class="text-xs text-gray-400">Approx. occurrences</p>
                                        {% set uDays = item.cycleId == 'custom' ? item.customCycleDays : ((inclusionCycleOptions|filter(o => o.id == item.cycleId)|first).days ?? 90) %}
                                        <p class="text-sm font-semibold text-gray-700">{{ max(1, ((duration * 30) / uDays)|round) }} over plan</p>
                                    </div>
                                </div>
                            {% endif %}
                        </div>

                        {# Pricing type #}
                        <div>
                            <div class="flex items-center justify-between gap-4 mb-3">
                                <label class="text-xs font-semibold text-gray-500 uppercase tracking-wide">Price</label>
                                <div class="flex items-center rounded-lg border border-gray-200 bg-white overflow-hidden flex-shrink-0">
                                    <button type="button" data-action="live#action" data-live-action-param="setUpsellPricingType" data-live-key-param="{{ item.key }}" data-live-type-param="catalogue" class="px-3 py-1.5 text-xs font-medium transition-colors {{ item.pricingType == 'catalogue' ? 'bg-blue-700 text-white' : 'text-gray-500 hover:bg-gray-50' }}">Use catalogue price</button>
                                    <button type="button" data-action="live#action" data-live-action-param="setUpsellPricingType" data-live-key-param="{{ item.key }}" data-live-type-param="custom" class="px-3 py-1.5 text-xs font-medium transition-colors {{ item.pricingType == 'custom' ? 'bg-blue-700 text-white' : 'text-gray-500 hover:bg-gray-50' }}">Custom price</button>
                                </div>
                            </div>
                            {% if item.pricingType == 'custom' %}
                                <div class="flex items-center gap-2">
                                    <span class="text-sm font-medium text-gray-600">£</span>
                                    <input type="number" min="0" step="0.01" data-model="on(input)|upsells.{{ i }}.customPrice" value="{{ item.customPrice }}" placeholder="0.00" class="w-28 px-3 py-1.5 text-sm text-gray-900 bg-white border border-gray-200 rounded-lg focus:outline-none focus:ring-1 focus:ring-blue-500">
                                    <span class="text-xs text-gray-400">per occurrence</span>
                                </div>
                            {% elseif uVariant %}
                                <p class="text-xs text-gray-400">Patient will be charged <span class="font-semibold text-emerald-600">£{{ uVariant.price|number_format(2) }}</span> per occurrence</p>
                            {% endif %}
                        </div>

                    {% endif %}{# end if productId #}

                </div>

            </div>
        {% endfor %}

        <button type="button" data-action="live#action" data-live-action-param="addUpsell" class="flex items-center gap-2 w-full px-4 py-2.5 text-sm font-medium text-blue-700 border border-dashed border-blue-300 rounded-xl hover:bg-blue-50 hover:border-blue-400 transition-colors">
            <svg class="w-[15px] h-[15px]" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M12 4v16m8-8H4"/></svg>
            Add upsell
        </button>
    </div>
</div>
