{# ════════════════════════════════════════════════════════════ #}
{# Dispatch schedule card                                       #}
{# ════════════════════════════════════════════════════════════ #}
{#
    SCOPE — Dispatch Schedule
    ✓  Cycle length: presets (2w/4w/6w/8w/12w) + custom days; used to derive ordersCount
    ✓  ordersCount = round((duration_months × 30) ÷ cycle_days) — shown live in summary
    ✓  Patient rescheduling window: toggle + days-earlier / days-later inputs
    ~  Days-earlier/later accepted as free integers; real system needs guardrails
       (e.g. cannot reschedule earlier than prescription run-out)
    ○  Dispatch provider / warehouse integration
    ○  Carrier / courier selection rules
    ○  Bank holiday and blackout date awareness
    ○  First-order lead time vs subsequent order timing
#}
<div class="bg-white rounded-2xl border border-gray-200 shadow-sm overflow-hidden">
    <div class="flex items-center gap-3 px-4 sm:px-6 py-3 sm:py-4 border-b border-gray-100">
        <div class="flex items-center justify-center w-8 h-8 bg-gray-100 rounded-xl text-gray-500">
            <svg class="w-[18px] h-[18px]" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"/>
            </svg>
        </div>
        <div>
            <h2 class="text-sm font-semibold text-gray-900">Dispatch schedule</h2>
            <p class="text-xs text-gray-500">Set how often orders are sent and how many will be generated.</p>
        </div>
    </div>

    <div class="p-4 sm:p-6 space-y-5">

        {# Dispatch frequency #}
        <div class="pb-5 border-b border-gray-100">
            <label class="text-xs font-semibold text-gray-500 uppercase tracking-wide mb-3 block">Dispatch frequency</label>
            {% if cycleId != 'custom' %}
                <select
                    data-model="cycleId"
                    class="w-full px-3 py-2 text-sm text-gray-900 bg-white border border-gray-200 rounded-xl focus:outline-none focus:ring-2 focus:ring-gray-900/10 focus:border-gray-500 transition-colors cursor-pointer"
                >
                    <option value="">Choose frequency</option>
                    {% for opt in cycleOptions %}
                        <option value="{{ opt.id }}" {% if opt.id == cycleId %}selected{% endif %}>{{ opt.label }}</option>
                    {% endfor %}
                </select>
            {% else %}
                <div class="flex items-center gap-2">
                    <input
                        type="number"
                        min="7"
                        data-model="on(input)|customCycleDays"
                        value="{{ customCycleDays }}"
                        class="w-24 px-3 py-2 text-sm text-gray-900 bg-white border border-gray-200 rounded-xl focus:outline-none focus:ring-2 focus:ring-gray-900/10 transition-colors"
                    >
                    <span class="text-sm text-gray-500">days</span>
                </div>
            {% endif %}
        </div>

        {# Order count + rescheduling toggle #}
        <div class="flex items-center justify-between gap-6 pb-5 border-b border-gray-100">
            <div class="flex items-center gap-3">
                <span class="text-sm text-gray-500">Total orders:</span>
                <span class="text-2xl font-bold text-gray-900">{{ ordersCount }}</span>
            </div>
            <label class="flex items-center gap-2.5 cursor-pointer select-none">
                <span class="text-sm font-medium text-gray-700">Allow patient rescheduling</span>
                <input
                    type="checkbox"
                    data-model="allowPatientRescheduling"
                    {% if allowPatientRescheduling %}checked{% endif %}
                    class="sr-only peer"
                >
                <div class="relative w-10 h-5 bg-gray-200 rounded-full peer peer-checked:bg-blue-600 transition-colors after:content-[''] after:absolute after:top-0.5 after:left-0.5 after:bg-white after:rounded-full after:h-4 after:w-4 after:transition-all peer-checked:after:translate-x-5"></div>
            </label>
        </div>

        {# Rescheduling window #}
        {% if allowPatientRescheduling %}
            <div class="pb-5 border-b border-gray-100">
                <label class="text-xs font-semibold text-gray-500 uppercase tracking-wide mb-3 block">Rescheduling window</label>
                <div class="flex items-center gap-3">
                    <div class="flex items-center gap-2 flex-1 rounded-xl border border-gray-200 bg-gray-50 px-3.5 py-3">
                        <svg class="w-3.5 h-3.5 text-amber-500 flex-shrink-0" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" d="M10 19l-7-7m0 0l7-7m-7 7h18"/>
                        </svg>
                        <input
                            type="number"
                            min="0"
                            data-model="on(input)|rescheduleDaysEarlier"
                            value="{{ rescheduleDaysEarlier }}"
                            class="w-14 text-center text-sm font-semibold text-gray-900 bg-transparent border-none outline-none focus:ring-0"
                        >
                        <span class="text-sm text-gray-500">days earlier</span>
                    </div>
                    <span class="text-gray-300 text-sm font-light">or</span>
                    <div class="flex items-center gap-2 flex-1 rounded-xl border border-gray-200 bg-gray-50 px-3.5 py-3">
                        <svg class="w-3.5 h-3.5 text-blue-500 flex-shrink-0" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" d="M14 5l7 7m0 0l-7 7m7-7H3"/>
                        </svg>
                        <input
                            type="number"
                            min="0"
                            data-model="on(input)|rescheduleDaysLater"
                            value="{{ rescheduleDaysLater }}"
                            class="w-14 text-center text-sm font-semibold text-gray-900 bg-transparent border-none outline-none focus:ring-0"
                        >
                        <span class="text-sm text-gray-500">days later</span>
                    </div>
                </div>
                <p class="text-xs text-gray-400 mt-2.5">
                    Patients can move an order up to
                    <span class="font-medium text-gray-600">{{ rescheduleDaysEarlier }} day{{ rescheduleDaysEarlier != 1 ? 's' : '' }} earlier</span>
                    or
                    <span class="font-medium text-gray-600">{{ rescheduleDaysLater }} day{{ rescheduleDaysLater != 1 ? 's' : '' }} later</span>.
                </p>
            </div>
        {% endif %}


    </div>
</div>
