{# ════════════════════════════════════════════════════════════ #}
{# Plan Basics card                                             #}
{# ════════════════════════════════════════════════════════════ #}
{#
    SCOPE — Plan Details
    ✓  Plan name: LiveProp, required validation, serialised to API contract
    ✓  Duration: preset (3m/6m/12m) + custom months; ordersCount = round((months×30) ÷ cycleDays)
    ✓  Auto-renew: boolean flag in API contract
    ✓  Start date: date picker, defaults +2 days; immediate vs future start behaviour
    ~  Plan name uniqueness — no DB check; real system needs a lookup against existing plans
    ○  Draft persistence — Save Draft is UI-only; needs DB write + Doctrine entity
    ○  Plan versioning / audit trail (created by, modified at, change history)
    ○  Template plans — clone an existing plan as a starting point
#}
<div class="bg-white rounded-2xl border border-gray-200 shadow-sm overflow-hidden">
    <div class="flex items-center gap-3 px-4 sm:px-6 py-3 sm:py-4 border-b border-gray-100">
        <div class="flex items-center justify-center w-8 h-8 bg-gray-100 rounded-xl text-gray-500">
            <svg class="w-[18px] h-[18px]" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" d="M10.325 4.317c.426-1.756 2.924-1.756 3.35 0a1.724 1.724 0 002.573 1.066c1.543-.94 3.31.826 2.37 2.37a1.724 1.724 0 001.065 2.572c1.756.426 1.756 2.924 0 3.35a1.724 1.724 0 00-1.066 2.573c.94 1.543-.826 3.31-2.37 2.37a1.724 1.724 0 00-2.572 1.065c-.426 1.756-2.924 1.756-3.35 0a1.724 1.724 0 00-2.573-1.066c-1.543.94-3.31-.826-2.37-2.37a1.724 1.724 0 00-1.065-2.572c-1.756-.426-1.756-2.924 0-3.35a1.724 1.724 0 001.066-2.573c-.94-1.543.826-3.31 2.37-2.37.996.608 2.296.07 2.572-1.065z"/>
                <path stroke-linecap="round" stroke-linejoin="round" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"/>
            </svg>
        </div>
        <div>
            <h2 class="text-sm font-semibold text-gray-900">Plan details</h2>
            <p class="text-xs text-gray-500">Name your plan and set a duration</p>
        </div>
    </div>

    <div class="p-4 sm:p-6 space-y-4">

        {# Plan name #}
        <div>
            <label class="block text-sm font-medium text-gray-700 mb-1.5">Plan name</label>
            <input
                type="text"
                data-model="on(input)|planName"
                placeholder="e.g. WL Starter Plan"
                value="{{ planName }}"
                class="w-full px-3 py-2 text-sm text-gray-900 bg-white border rounded-xl focus:outline-none focus:ring-2 focus:ring-gray-900/10 focus:border-gray-500 transition-colors {{ validation.errors.planName is defined ? 'border-red-400 bg-red-50' : 'border-gray-200' }}"
            >
            {% if validation.errors.planName is defined %}
                <p class="text-xs text-red-500 mt-1.5 flex items-center gap-1.5">
                    <svg class="w-[13px] h-[13px] flex-shrink-0" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M12 8v4m0 4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/>
                    </svg>
                    {{ validation.errors.planName }}
                </p>
            {% endif %}
        </div>

        {# Duration #}
        <div>
            <label class="block text-sm font-medium text-gray-700 mb-1.5">Duration</label>
            {% if durationId != 'custom' %}
                <select
                    data-model="durationId"
                    class="w-full px-3 py-2 text-sm text-gray-900 bg-white border border-gray-200 rounded-xl focus:outline-none focus:ring-2 focus:ring-gray-900/10 focus:border-gray-500 transition-colors cursor-pointer"
                >
                    <option value="">Choose duration</option>
                    {% for opt in durationOptions %}
                        <option value="{{ opt.id }}" {% if opt.id == durationId %}selected{% endif %}>{{ opt.label }}</option>
                    {% endfor %}
                </select>
            {% else %}
                <div class="flex items-center gap-2">
                    <input
                        type="number"
                        min="1"
                        data-model="on(input)|customDurationMonths"
                        value="{{ customDurationMonths }}"
                        class="w-24 px-3 py-2 text-sm text-gray-900 bg-white border border-gray-200 rounded-xl focus:outline-none focus:ring-2 focus:ring-gray-900/10 focus:border-gray-500 transition-colors"
                    >
                    <span class="text-sm text-gray-500">months</span>
                </div>
            {% endif %}
        </div>

        {# Auto-renew #}
        <div class="flex items-center justify-between pt-1 border-t border-gray-100">
            <div>
                <p class="text-sm font-medium text-gray-700">Auto-renew</p>
                <p class="text-xs text-gray-400 mt-0.5">Automatically restart the plan at the end of its duration</p>
            </div>
            <label class="flex items-center gap-2.5 cursor-pointer select-none flex-shrink-0 ml-6">
                <input
                    type="checkbox"
                    data-model="autoRenew"
                    {% if autoRenew %}checked{% endif %}
                    class="sr-only peer"
                >
                <div class="relative w-10 h-5 bg-gray-200 rounded-full peer peer-checked:bg-blue-600 transition-colors after:content-[''] after:absolute after:top-0.5 after:left-0.5 after:bg-white after:rounded-full after:h-4 after:w-4 after:transition-all peer-checked:after:translate-x-5"></div>
            </label>
        </div>

    </div>
</div>
