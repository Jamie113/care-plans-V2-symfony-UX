<div class="space-y-3 mb-5">

    {# ── Patient filters ────────────────────────────────────────────────── #}
    <div class="bg-white border border-gray-200 rounded-2xl p-4 space-y-3">

        <p class="text-xs font-semibold text-gray-500 uppercase tracking-wide">Find a patient</p>

        <div class="grid grid-cols-1 sm:grid-cols-4 gap-3">

            <div>
                <label class="block text-xs text-gray-500 mb-1">First name</label>
                <input
                    type="text"
                    data-model="debounce(300)|filterFirstName"
                    value="{{ filterFirstName }}"
                    placeholder="e.g. Sarah"
                    class="w-full px-3 py-2 text-sm text-gray-900 bg-gray-50 border border-gray-200 rounded-xl focus:outline-none focus:ring-2 focus:ring-gray-900/10 focus:border-gray-500 transition-colors"
                >
            </div>

            <div>
                <label class="block text-xs text-gray-500 mb-1">Last name</label>
                <input
                    type="text"
                    data-model="debounce(300)|filterLastName"
                    value="{{ filterLastName }}"
                    placeholder="e.g. Mitchell"
                    class="w-full px-3 py-2 text-sm text-gray-900 bg-gray-50 border border-gray-200 rounded-xl focus:outline-none focus:ring-2 focus:ring-gray-900/10 focus:border-gray-500 transition-colors"
                >
            </div>

            <div>
                <label class="block text-xs text-gray-500 mb-1">Email</label>
                <input
                    type="text"
                    data-model="debounce(300)|filterEmail"
                    value="{{ filterEmail }}"
                    placeholder="e.g. sarah@example.com"
                    class="w-full px-3 py-2 text-sm text-gray-900 bg-gray-50 border border-gray-200 rounded-xl focus:outline-none focus:ring-2 focus:ring-gray-900/10 focus:border-gray-500 transition-colors"
                >
            </div>

            <div>
                <label class="block text-xs text-gray-500 mb-1">Phone</label>
                <input
                    type="text"
                    data-model="debounce(300)|filterPhone"
                    value="{{ filterPhone }}"
                    placeholder="e.g. 07700 900 123"
                    class="w-full px-3 py-2 text-sm text-gray-900 bg-gray-50 border border-gray-200 rounded-xl focus:outline-none focus:ring-2 focus:ring-gray-900/10 focus:border-gray-500 transition-colors"
                >
            </div>

        </div>

    </div>

    {# ── Clear filters ────────────────────────────────────────────────────── #}
    {% if hasActiveFilters %}
        <div class="flex justify-end">
            <button
                data-action="live#action"
                data-live-action-param="clearFilters"
                type="button"
                class="text-xs text-gray-500 hover:text-gray-800 underline underline-offset-2 transition-colors"
            >Clear all filters</button>
        </div>
    {% endif %}

</div>
