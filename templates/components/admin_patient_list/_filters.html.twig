<div class="space-y-3 mb-5">

    {# ── Specific filters ───────────────────────────────────────────────── #}
    <div class="bg-white border border-gray-200 rounded-2xl p-4 space-y-3">

        <p class="text-xs font-semibold text-gray-500 uppercase tracking-wide">Filter patients</p>

        {# Row 1: Customer ID · Status · Category · Plan name #}
        <div class="grid grid-cols-1 sm:grid-cols-4 gap-3">

            <div>
                <label class="block text-xs text-gray-500 mb-1">Customer ID</label>
                <input
                    type="text"
                    data-model="debounce(300)|filterCustomerId"
                    value="{{ filterCustomerId }}"
                    placeholder="e.g. CUS-001"
                    class="w-full px-3 py-2 text-sm text-gray-900 bg-gray-50 border border-gray-200 rounded-xl focus:outline-none focus:ring-2 focus:ring-gray-900/10 focus:border-gray-500 transition-colors"
                >
            </div>

            <div>
                <label class="block text-xs text-gray-500 mb-1">Status</label>
                <select
                    data-model="statusFilter"
                    class="w-full px-3 py-2 text-sm text-gray-900 bg-gray-50 border border-gray-200 rounded-xl focus:outline-none focus:ring-2 focus:ring-gray-900/10 focus:border-gray-500 transition-colors cursor-pointer"
                >
                    <option value="">All statuses</option>
                    <option value="active"            {% if statusFilter == 'active'            %}selected{% endif %}>active</option>
                    <option value="requested-renew"   {% if statusFilter == 'requested-renew'   %}selected{% endif %}>requested-renew</option>
                    <option value="requested-change"  {% if statusFilter == 'requested-change'  %}selected{% endif %}>requested-change</option>
                    <option value="requested-approve" {% if statusFilter == 'requested-approve' %}selected{% endif %}>requested-approve</option>
                    <option value="deactivated"       {% if statusFilter == 'deactivated'       %}selected{% endif %}>deactivated</option>
                    <option value="expired"           {% if statusFilter == 'expired'           %}selected{% endif %}>expired</option>
                </select>
            </div>

            <div>
                <label class="block text-xs text-gray-500 mb-1">Category</label>
                <select
                    data-model="filterCategory"
                    class="w-full px-3 py-2 text-sm text-gray-900 bg-gray-50 border border-gray-200 rounded-xl focus:outline-none focus:ring-2 focus:ring-gray-900/10 focus:border-gray-500 transition-colors cursor-pointer"
                >
                    <option value="">All categories</option>
                    <option value="Weightloss"      {% if filterCategory == 'Weightloss'      %}selected{% endif %}>Weightloss</option>
                    <option value="TRT"             {% if filterCategory == 'TRT'             %}selected{% endif %}>TRT</option>
                    <option value="Menopause"       {% if filterCategory == 'Menopause'       %}selected{% endif %}>Menopause</option>
                    <option value="Male Hairloss"   {% if filterCategory == 'Male Hairloss'   %}selected{% endif %}>Male Hairloss</option>
                    <option value="Female Hairloss" {% if filterCategory == 'Female Hairloss' %}selected{% endif %}>Female Hairloss</option>
                    <option value="ED"              {% if filterCategory == 'ED'              %}selected{% endif %}>ED</option>
                </select>
            </div>

            <div>
                <label class="block text-xs text-gray-500 mb-1">Plan name</label>
                <select
                    data-model="filterPlanName"
                    class="w-full px-3 py-2 text-sm text-gray-900 bg-gray-50 border border-gray-200 rounded-xl focus:outline-none focus:ring-2 focus:ring-gray-900/10 focus:border-gray-500 transition-colors cursor-pointer"
                >
                    <option value="">All plans</option>
                    <option value="WL Starter 6 Month"   {% if filterPlanName == 'WL Starter 6 Month'   %}selected{% endif %}>WL Starter 6 Month</option>
                    <option value="WL Pro 3 Month"        {% if filterPlanName == 'WL Pro 3 Month'        %}selected{% endif %}>WL Pro 3 Month</option>
                    <option value="WL Advanced 12 Month"  {% if filterPlanName == 'WL Advanced 12 Month'  %}selected{% endif %}>WL Advanced 12 Month</option>
                    <option value="Testosterone 6 Month"  {% if filterPlanName == 'Testosterone 6 Month'  %}selected{% endif %}>Testosterone 6 Month</option>
                </select>
            </div>

        </div>

        {# Row 2: Next order date range · Billing date range #}
        <div class="grid grid-cols-1 sm:grid-cols-4 gap-3">

            <div>
                <label class="block text-xs text-gray-500 mb-1">Next order — from</label>
                <input
                    type="date"
                    data-model="filterDateFrom"
                    value="{{ filterDateFrom }}"
                    class="w-full px-3 py-2 text-sm text-gray-900 bg-gray-50 border border-gray-200 rounded-xl focus:outline-none focus:ring-2 focus:ring-gray-900/10 focus:border-gray-500 transition-colors"
                >
            </div>

            <div>
                <label class="block text-xs text-gray-500 mb-1">Next order — to</label>
                <input
                    type="date"
                    data-model="filterDateTo"
                    value="{{ filterDateTo }}"
                    class="w-full px-3 py-2 text-sm text-gray-900 bg-gray-50 border border-gray-200 rounded-xl focus:outline-none focus:ring-2 focus:ring-gray-900/10 focus:border-gray-500 transition-colors"
                >
            </div>

            <div>
                <label class="block text-xs text-gray-500 mb-1">Next billing — from</label>
                <input
                    type="date"
                    data-model="filterBillingDateFrom"
                    value="{{ filterBillingDateFrom }}"
                    class="w-full px-3 py-2 text-sm text-gray-900 bg-gray-50 border border-gray-200 rounded-xl focus:outline-none focus:ring-2 focus:ring-gray-900/10 focus:border-gray-500 transition-colors"
                >
            </div>

            <div>
                <label class="block text-xs text-gray-500 mb-1">Next billing — to</label>
                <input
                    type="date"
                    data-model="filterBillingDateTo"
                    value="{{ filterBillingDateTo }}"
                    class="w-full px-3 py-2 text-sm text-gray-900 bg-gray-50 border border-gray-200 rounded-xl focus:outline-none focus:ring-2 focus:ring-gray-900/10 focus:border-gray-500 transition-colors"
                >
            </div>

        </div>

    </div>

    {# ── Fuzzy search fallback ───────────────────────────────────────────── #}
    <div class="relative">
        <svg class="pointer-events-none absolute left-3 top-1/2 -translate-y-1/2 w-4 h-4 text-gray-400" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" d="M21 21l-4.35-4.35M17 11A6 6 0 115 11a6 6 0 0112 0z"/>
        </svg>
        <input
            type="text"
            data-model="debounce(300)|search"
            value="{{ search }}"
            placeholder="Search by patient name or email…"
            class="w-full pl-9 pr-3 py-2 text-sm text-gray-900 bg-white border border-gray-200 rounded-xl focus:outline-none focus:ring-2 focus:ring-gray-900/10 focus:border-gray-500 transition-colors"
        >
    </div>

    {# ── Clear filters ────────────────────────────────────────────────────── #}
    {% if hasActiveFilters %}
        <div class="flex justify-end">
            <button
                data-action="live#action"
                data-live-action-param="clearFilters"
                type="button"
                class="text-xs text-gray-500 hover:text-gray-800 underline underline-offset-2 transition-colors"
            >Clear all filters</button>
        </div>
    {% endif %}

</div>
